/* components/loading/loading.wxss */
.loading-container {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 9999;
}

.loading-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.4);
  backdrop-filter: blur(2px);
}

.loading-content {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background-color: #ffffff;
  border-radius: 12rpx;
  padding: 40rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.16);
  min-width: 280rpx;
}

.loading-spinner {
  position: relative;
  margin-bottom: 24rpx;
}

.loading-spinner .spinner-icon {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  border: 4rpx solid transparent;
  border-top-color: currentColor;
  border-left-color: currentColor;
}

/* 尺寸 */
.loading-spinner.small {
  width: 40rpx;
  height: 40rpx;
}

.loading-spinner.medium {
  width: 60rpx;
  height: 60rpx;
}

.loading-spinner.large {
  width: 80rpx;
  height: 80rpx;
}

/* 颜色 */
.loading-spinner.default {
  color: #999999;
}

.loading-spinner.primary {
  color: #007AFF;
}

.loading-spinner.success {
  color: #4CD964;
}

.loading-spinner.warning {
  color: #FF9500;
}

.loading-spinner.error {
  color: #FF3B30;
}

.loading-text {
  font-size: 28rpx;
  color: #666666;
  text-align: center;
  margin-top: 16rpx;
}

/* 动画 */
@keyframes spin {
  from {
    transform: rotate(0deg);
  }
  to {
    transform: rotate(360deg);
  }
}
