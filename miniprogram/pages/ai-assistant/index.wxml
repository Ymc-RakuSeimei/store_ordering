<view class="page">
  <view class="hero-card">
    <image class="hero-icon" src="/images/icon_ai.png" mode="aspectFit"></image>
    <view class="hero-copy">
      <view class="hero-title">{{assistantTitle}}</view>
      <view class="hero-desc">{{assistantSubtitle}}</view>
    </view>
  </view>

  <scroll-view class="message-list" scroll-y="true" scroll-into-view="{{scrollIntoView}}" enable-flex="true">
    <block wx:for="{{messages}}" wx:key="id">
      <view id="msg-{{item.id}}" class="message-row {{item.role === 'user' ? 'message-row--user' : ''}}">
        <view class="message-avatar {{item.role === 'user' ? 'message-avatar--user' : ''}}">
          <image
            class="message-avatar-image"
            src="{{item.role === 'user' ? userAvatar : '/images/icon_ai.png'}}"
            mode="aspectFill"
          ></image>
        </view>
        <view class="message-bubble {{item.role === 'user' ? 'message-bubble--user' : ''}}">
          <text selectable="true">{{item.content}}</text>
        </view>
      </view>
    </block>

    <view wx:if="{{loading}}" class="typing">AI 正在整理回答...</view>
  </scroll-view>

  <view wx:if="{{quickQuestions.length}}" class="quick-bar">
    <block wx:for="{{quickQuestions}}" wx:key="*this">
      <view class="quick-chip" bindtap="useQuickQuestion" data-question="{{item}}">{{item}}</view>
    </block>
  </view>

  <view class="composer">
    <textarea
      class="composer-input"
      placeholder="输入你想咨询的问题"
      maxlength="300"
      auto-height="true"
      value="{{inputValue}}"
      bindinput="onInput"
      confirm-type="send"
    ></textarea>
    <button class="composer-send" bindtap="sendMessage" loading="{{sending}}" disabled="{{sending}}">发送</button>
  </view>
</view>
