page {
  background: linear-gradient(180deg, #eef6ff 0%, #f8fbff 38%, #ffffff 100%);
  height: 100vh;
}

.page {
  height: 100%;
  padding: 28rpx 24rpx 32rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
}

.hero-card {
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.86);
  border: 1rpx solid rgba(135, 171, 213, 0.28);
  box-shadow: 0 20rpx 50rpx rgba(43, 90, 149, 0.08);
  border-radius: 28rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.message-list {
  flex: 1;
  min-height: 0;
  overflow: hidden;
}

.hero-icon {
  width: 88rpx;
  height: 88rpx;
  margin-right: 20rpx;
}

.hero-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #163652;
}

.hero-desc {
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.5;
  color: #5e748d;
}

.message-row {
  display: flex;
  align-items: flex-start;
  margin-bottom: 24rpx;
}

.message-row--user {
  flex-direction: row-reverse;
}

.message-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: #dceeff;
  overflow: hidden;
  box-shadow: 0 10rpx 24rpx rgba(79, 126, 190, 0.16);
}

.message-avatar--user {
  background: #d9f4ea;
}

.message-avatar-image {
  width: 100%;
  height: 100%;
}

.message-bubble {
  max-width: 78%;
  margin-left: 18rpx;
  padding: 22rpx 24rpx;
  border-radius: 24rpx 24rpx 24rpx 8rpx;
  background: rgba(255, 255, 255, 0.96);
  color: #1f3348;
  font-size: 28rpx;
  line-height: 1.7;
  white-space: pre-wrap;
  box-shadow: 0 14rpx 34rpx rgba(26, 59, 96, 0.08);
}

.message-bubble--user {
  margin-left: 0;
  margin-right: 18rpx;
  background: linear-gradient(135deg, #1677ff 0%, #2e96ff 100%);
  color: #ffffff;
  border-radius: 24rpx 24rpx 8rpx 24rpx;
}

.typing {
  font-size: 24rpx;
  color: #6b8198;
  padding: 8rpx 8rpx 24rpx;
}

.quick-bar {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  padding: 20rpx 0 16rpx;
}

.quick-chip {
  padding: 14rpx 22rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.95);
  border: 1rpx solid rgba(104, 152, 208, 0.34);
  color: #24527d;
  font-size: 24rpx;
}

.composer {
  display: flex;
  align-items: flex-end;
  gap: 18rpx;
  padding-top: 10rpx;
}

.composer-input {
  flex: 1;
  min-height: 88rpx;
  max-height: 220rpx;
  padding: 22rpx 24rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.96);
  box-sizing: border-box;
  color: #1f3348;
  font-size: 28rpx;
  box-shadow: 0 14rpx 34rpx rgba(26, 59, 96, 0.08);
}

.composer-send {
  width: 152rpx;
  height: 88rpx;
  border: none;
  border-radius: 24rpx;
  background: linear-gradient(135deg, #1e77ff 0%, #31a0ff 100%);
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 700;
  line-height: 88rpx;
  padding: 0;
}

.composer-send::after {
  border: none;
}
