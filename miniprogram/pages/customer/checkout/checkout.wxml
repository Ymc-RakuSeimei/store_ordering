<view class="container">
  <!-- 顶部导航栏 -->
  <view class="nav-bar">
    <view class="nav-back" bindtap="goBack">
      <text class="back-icon"></text>
    </view>
    <view class="nav-title">确认订单</view>
    <view class="nav-placeholder"></view>
  </view>

  <!-- 商品清单 -->
  <view class="order-goods">
    <view class="section-title">商品清单</view>
    <block wx:for="{{cartList}}" wx:key="id">
      <view class="goods-item">
        <image class="goods-image" src="{{item.image}}" mode="aspectFill"></image>
        <view class="goods-info">
          <text class="goods-name">{{item.name}}</text>
          <text class="goods-price">¥{{item.price}}</text>
        </view>
        <text class="goods-quantity">x{{item.quantity}}</text>
      </view>
    </block>
  </view>

  <!-- 订单信息 -->
  <view class="order-info">
    <view class="info-row">
      <text class="info-label">商品总价</text>
      <text class="info-value">¥{{totalPrice}}</text>
    </view>
    <view class="info-row total">
      <text class="info-label">实付金额</text>
      <text class="info-value total-price">¥{{totalPrice}}</text>
    </view>
  </view>

  <!-- 按钮组 -->
  <view class="button-group">
    <view class="cancel-btn" bindtap="goBack">
      <text>取消</text>
    </view>
    <view class="pay-btn" bindtap="pay">
      <text>立即支付 ¥{{totalPrice}}</text>
    </view>
  </view>
</view>