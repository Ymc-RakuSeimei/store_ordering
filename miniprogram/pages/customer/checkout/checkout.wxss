.container {
  background-color: #f5f5f5;
  height: 100vh;
  display: flex;
  flex-direction: column;
}

/* 顶部导航栏 */
.nav-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 120rpx;
  padding: 0 32rpx;
  background-color: transparent;
  position: relative;
  flex-shrink: 0;
  margin-top: 20rpx;
}

.nav-back {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: flex-start;
  flex-shrink: 0;
}

.back-icon {
  font-size: 56rpx;
  font-weight: 400;
  color: #000000;
  line-height: 1;
}

.nav-title {
  position: absolute;
  left: 50%;
  transform: translateX(-50%);
  font-size: 40rpx;
  font-weight: 700;
  color: #000000;
  white-space: nowrap;
  background-color: transparent;
}

.nav-placeholder {
  width: 80rpx;
  flex-shrink: 0;
  visibility: hidden;
}

/* 可滚动内容区域 */
.scroll-content {
  flex: 1;
  overflow-y: auto;
}

/* 商品清单 */
.order-goods {
  background-color: #ffffff;
  margin-top: 20rpx;
  padding: 0 32rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #333333;
  padding: 28rpx 0 16rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.goods-item {
  display: flex;
  align-items: center;
  padding: 28rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.goods-item:last-child {
  border-bottom: none;
}

.goods-image {
  width: 140rpx;
  height: 140rpx;
  border-radius: 16rpx;
  background-color: #f5f5f5;
  margin-right: 28rpx;
  flex-shrink: 0;
}

.goods-info {
  flex: 1;
}

.goods-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
  display: block;
  margin-bottom: 12rpx;
  line-height: 1.3;
}

.goods-price-row {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
}

.goods-price {
  font-size: 30rpx;
  color: #ff6b35;
  font-weight: 600;
}

.goods-quantity {
  font-size: 28rpx;
  color: #999999;
  font-weight: 500;
}

/* 订单信息 */
.order-info {
  background-color: #ffffff;
  margin-top: 20rpx;
  padding: 20rpx 32rpx 32rpx 32rpx;
}

.info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
}

.info-label {
  font-size: 28rpx;
  color: #666666;
}

.info-value {
  font-size: 28rpx;
  color: #333333;
  font-weight: 500;
}

.info-row.total {
  margin-top: 8rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #f0f0f0;
}

.total-price {
  font-size: 36rpx;
  font-weight: 700;
  color: #ff3b30;
}

/* 订单备注 */
.remark-section {
  background-color: #ffffff;
  margin-top: 20rpx;
  padding: 28rpx 32rpx;
  position: relative;
}

.remark-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 20rpx;
}

.remark-input {
  width: 100%;
  min-height: 120rpx;
  font-size: 28rpx;
  color: #333333;
  line-height: 1.5;
  padding: 20rpx 0;
  box-sizing: border-box;
  background-color: transparent;
}

.remark-placeholder {
  color: #cccccc;
  font-size: 28rpx;
}

.remark-count {
  position: absolute;
  bottom: 20rpx;
  right: 32rpx;
  font-size: 24rpx;
  color: #999999;
}

/* 底部占位 */
.bottom-placeholder {
  height: 140rpx;
}

/* 底部固定按钮组 */
.button-group {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  gap: 24rpx;
  padding: 20rpx 32rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background-color: #ffffff;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.08);
  z-index: 10;
}

.cancel-btn {
  flex: 1;
  background-color: #f5f5f5;
  padding: 28rpx 0;
  border-radius: 48rpx;
  text-align: center;
}

.cancel-btn text {
  color: #666666;
  font-size: 32rpx;
  font-weight: 500;
}

.cancel-btn:active {
  background-color: #e8e8e8;
}

.pay-btn {
  flex: 2;
  background-color: #000000;
  padding: 28rpx 0;
  border-radius: 48rpx;
  text-align: center;
}

.pay-btn text {
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 500;
}

.pay-btn:active {
  background-color: #333333;
}