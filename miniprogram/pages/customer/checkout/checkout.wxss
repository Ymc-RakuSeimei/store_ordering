.container {
  background-color: #f5f5f5;
  min-height: 100vh;
  padding-bottom: 60rpx;
  padding-top: 30rpx;
}

/* 顶部导航栏 */
.nav-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 100rpx;
  padding: 0 32rpx;
  background-color: #ffffff;
  position: relative;
  margin-top: 20rpx;
}

.nav-back {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: flex-start;
  flex-shrink: 0;
}

.back-icon {
  font-size: 56rpx;
  font-weight: 400;
  color: #000000;
  line-height: 1;
}

.nav-title {
  position: absolute;
  left: 50%;
  transform: translateX(-50%);
  font-size: 36rpx;
  font-weight: 700;
  color: #000000;
  white-space: nowrap;
}

.nav-placeholder {
  width: 80rpx;
  flex-shrink: 0;
  visibility: hidden;
}

/* 商品清单 */
.order-goods {
  background-color: #ffffff;
  margin: 30rpx 24rpx 20rpx 24rpx;
  border-radius: 24rpx;
  padding: 28rpx 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #333333;
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.goods-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.goods-item:last-child {
  border-bottom: none;
}

.goods-image {
  width: 100rpx;
  height: 100rpx;
  border-radius: 16rpx;
  background-color: #f5f5f5;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.goods-info {
  flex: 1;
}

.goods-name {
  font-size: 30rpx;
  font-weight: 500;
  color: #333333;
  display: block;
  margin-bottom: 10rpx;
}

.goods-price {
  font-size: 28rpx;
  color: #ff6b35;
  font-weight: 600;
}

.goods-quantity {
  font-size: 28rpx;
  color: #999999;
  font-weight: 500;
  flex-shrink: 0;
  margin-left: 16rpx;
}

/* 订单信息 */
.order-info {
  background-color: #ffffff;
  margin: 0 24rpx 30rpx 24rpx;
  border-radius: 24rpx;
  padding: 28rpx 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
}

.info-label {
  font-size: 28rpx;
  color: #666666;
}

.info-value {
  font-size: 28rpx;
  color: #333333;
  font-weight: 500;
}

.info-row.total {
  margin-top: 16rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #f0f0f0;
}

.total-price {
  font-size: 44rpx;
  font-weight: 700;
  color: #ff3b30;
}

/* 按钮组 */
.button-group {
  display: flex;
  gap: 20rpx;
  margin: 20rpx 24rpx 40rpx 24rpx;
}

/* 取消按钮 */
.cancel-btn {
  flex: 1;
  background-color: #ffffff;
  padding: 28rpx 0;
  border-radius: 48rpx;
  text-align: center;
  border: 1rpx solid #cccccc;
}

.cancel-btn text {
  color: #666666;
  font-size: 32rpx;
  font-weight: 500;
}

.cancel-btn:active {
  background-color: #f5f5f5;
}

/* 支付按钮 */
.pay-btn {
  flex: 2;
  background-color: #000000;
  padding: 28rpx 0;
  border-radius: 48rpx;
  text-align: center;
}

.pay-btn text {
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 500;
}

.pay-btn:active {
  background-color: #333333;
}