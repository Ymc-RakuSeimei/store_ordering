.container {
  background-color: #f5f5f5;
  min-height: 100vh;
}

.nav-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 100rpx;
  padding: 0 32rpx;
  background-color: #ffffff;
  position: relative;
}

.nav-back {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: flex-start;
}

.back-icon {
  font-size: 56rpx;
  font-weight: 400;
  color: #000000;
}

.nav-title {
  position: absolute;
  left: 50%;
  transform: translateX(-50%);
  font-size: 36rpx;
  font-weight: 700;
  color: #000000;
}

.nav-placeholder {
  width: 80rpx;
}

.order-info {
  background-color: #ffffff;
  margin: 32rpx;
  padding: 40rpx;
  border-radius: 16rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.order-label {
  font-size: 28rpx;
  color: #666666;
}

.order-price {
  font-size: 48rpx;
  font-weight: 700;
  color: #ff3b30;
}

.pay-btn {
  margin: 32rpx;
  background-color: #000000;
  padding: 28rpx;
  border-radius: 48rpx;
  text-align: center;
}

.pay-btn text {
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 500;
}