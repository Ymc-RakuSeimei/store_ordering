<view class="special-container">
  <view class="goods-grid">
    <block wx:for="{{displayList}}" wx:key="id">
      <view class="goods-card">
        <view class="goods-image-wrapper">
          <image wx:if="{{item.image}}" class="goods-image" src="{{item.image}}" mode="aspectFill"></image>
          <view wx:else class="goods-image-placeholder"></view>
          <view class="goods-badge {{item.badgeClass}}">{{item.badgeText}}</view>
        </view>
        <view class="goods-info">
          <text class="goods-name">{{item.name}}</text>
          <view class="goods-price-row">
            <text class="goods-price {{item.priceClass}}">¥{{item.price}}</text>
            <text class="goods-original-price" wx:if="{{item.originalPrice}}">¥{{item.originalPrice}}</text>
          </view>
          <text class="goods-stock">{{item.statusText}}</text>
          <text class="goods-spec">规格:{{item.spec}}</text>
        </view>
        <view class="goods-action" bindtap="onAddToCart" data-item="{{item}}">
          {{item.actionText}}
        </view>
      </view>
    </block>
  </view>
  <view class="empty-state" wx:if="{{displayList.length === 0}}">
    <text>暂无特价商品</text>
  </view>
</view>