<!-- 特价区组件 -->
<view class="special-container">
  <view class="goods-grid">
    <block wx:for="{{goodsList}}" wx:key="id">
      <view class="goods-card">
        <view class="goods-image-wrapper">
          <image class="goods-image" src="{{item.image}}" mode="aspectFill"></image>
          <view class="goods-badge special">特价</view>
        </view>
        <view class="goods-info">
          <text class="goods-name">{{item.name}}</text>
          <view class="goods-price-row">
            <text class="goods-price">¥{{item.specialPrice}}</text>
            <text class="goods-original-price">¥{{item.originalPrice}}</text>
          </view>
          <text class="goods-stock">库存剩余{{item.stock}}件</text>
          <text class="goods-spec">规格:{{item.spec}}</text>
        </view>
        <view class="goods-action" bindtap="onAddToCart" data-item="{{item}}">
          加入购物车
        </view>
      </view>
    </block>
  </view>
  <view class="empty-state" wx:if="{{goodsList.length === 0}}">
    <text>暂无特价商品</text>
  </view>
</view>