<view class="spot-container">
  <view class="goods-grid">
    <block wx:for="{{displayList}}" wx:key="id">
      <view class="goods-card" bindtap="goToDetail" data-item="{{item}}">
        <view class="goods-image-wrapper">
          <image wx:if="{{item.image}}" class="goods-image" src="{{item.image}}" mode="aspectFill"></image>
          <view wx:else class="goods-image-placeholder"></view>
          <!-- 角标：有文字才显示，无文字不显示任何东西 -->
          <!-- 强制现货角标显示：现货订购 → 黑色 -->
<view class="goods-badge spot">现货订购</view>
        </view>
        <view class="goods-info">
          <text class="goods-name">{{item.name}}</text>
          <view class="goods-price-row">
            <text class="goods-price {{item.priceClass}}">¥{{item.price}}</text>
            <text class="goods-original-price" wx:if="{{item.originalPrice}}">¥{{item.originalPrice}}</text>
          </view>
          <text class="goods-stock">{{item.statusText}}</text>
          <text class="goods-spec">规格:{{item.spec}}</text>
        </view>
        <!-- 购物车操作区域 -->
        <view wx:if="{{item.cartQuantity > 0}}" class="goods-quantity-control">
          <view class="quantity-btn minus" catchtap="decreaseQuantity" data-item="{{item}}">-</view>
          <view class="quantity-input">{{item.cartQuantity}}</view>
          <view class="quantity-btn plus" catchtap="increaseQuantity" data-item="{{item}}">+</view>
        </view>
        <view wx:else class="goods-action" catchtap="onAction" data-item="{{item}}">
          {{item.actionText}}
        </view>
      </view>
    </block>
  </view>
  <view class="empty-state" wx:if="{{displayList.length === 0}}">
    <text>暂无现货商品</text>
  </view>
</view>