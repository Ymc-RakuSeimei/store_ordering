.all-container,
.spot-container,
.preorder-container,
.special-container {
  background-color: #f5f5f5;
  width: 100%;
  padding: 0 24rpx;
  box-sizing: border-box;
}

.goods-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
  width: 100%;
}

.goods-card {
  background-color: #ffffff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
  width: 100%;
  box-sizing: border-box;
  border: 1rpx solid #f0f0f0;
}

.goods-image-wrapper {
  position: relative;
  width: 100%;
  height: 280rpx;
  background-color: #f5f5f5;
}

.goods-image {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.goods-image-placeholder {
  width: 100%;
  height: 100%;
  background-color: #f5f5f5;
}

.goods-badge {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  padding: 6rpx 16rpx;
  border-radius: 24rpx;
  font-size: 22rpx;
  font-weight: 500;
  background-color: #000000;
  color: #ffffff;
  z-index: 10;
}

/* 接龙预定角标 → 红色 */
.goods-badge.preorder {
  background-color: #ff3b30; /* 红色，和现货黑色区分 */
  color: #ffffff;
}

/* 现货订购角标 → 绿色背景（和其他页面统一） */
.goods-badge.spot {
  background-color: #4cd964;
  color: #ffffff;
}

/* 特价角标 —— 橙色背景，白色文字 */
.goods-badge.special {
  background-color: #ff9500;
  color: #ffffff;
}

.goods-badge-placeholder {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  width: 0;
  height: 0;
  visibility: hidden;
}

.goods-info {
  padding: 20rpx;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.goods-name {
  font-size: 30rpx;
  font-weight: 700;
  color: #333333;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.goods-price-row {
  display: flex;
  align-items: baseline;
  gap: 12rpx;
  flex-wrap: wrap;
}

.goods-price {
  font-size: 28rpx;
  font-weight: 600;
  color: #000000;
}

.goods-price.special-price {
  color: #ff3b30;
}

.goods-original-price {
  font-size: 24rpx;
  color: #999999;
  text-decoration: line-through;
}

.goods-stock {
  font-size: 24rpx;
  color: #999999;
}

.goods-spec {
  font-size: 24rpx;
  color: #999999;
}

.goods-action {
  margin: 0 20rpx 20rpx 20rpx;
  padding: 16rpx 0;
  text-align: center;
  border: 1rpx solid #cccccc;
  border-radius: 40rpx;
  font-size: 26rpx;
  font-weight: 500;
  color: #333333;
  background-color: #ffffff;
}

.goods-action:active {
  background-color: #f5f5f5;
}

.empty-state {
  text-align: center;
  padding: 120rpx 0;
  color: #999999;
  font-size: 28rpx;
}

/* 数量控制器样式 */
.goods-quantity-control {
  margin: 0 20rpx 20rpx 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
}

.quantity-btn {
  width: 56rpx;
  height: 56rpx;
  border-radius: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  font-weight: 500;
}

.quantity-btn.minus {
  background-color: #f5f5f5;
  color: #333333;
  border: 1rpx solid #e0e0e0;
}

.quantity-btn.plus {
  background-color: #ff3b30;
  color: #ffffff;
  border: none;
}

.quantity-btn:active {
  opacity: 0.8;
}

.quantity-input {
  min-width: 40rpx;
  text-align: center;
  font-size: 28rpx;
  font-weight: 500;
  color: #333333;
}