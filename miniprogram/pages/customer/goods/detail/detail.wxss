.container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding-top: 0;
}

/* 商品图片 - 移除 margin-top，因为不再有固定导航栏 */
.goods-image-container {
  position: relative;
  width: 100%;
  height: 320rpx;
  background-color: #ffffff;
}

.goods-image {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.goods-image-placeholder {
  width: 100%;
  height: 100%;
  background-color: #f5f5f5;
}

.goods-badge {
  position: absolute;
  top: 20rpx;
  right: 20rpx;
  padding: 8rpx 20rpx;
  border-radius: 24rpx;
  font-size: 24rpx;
  font-weight: 500;
  background-color: #000000;
  color: #ffffff;
  z-index: 10;
}

.goods-badge.preorder {
  background-color: #ff3b30;
  color: #ffffff;
}

.goods-badge.spot {
  background-color: #000000;
  color: #ffffff;
}

.goods-badge.special {
  background-color: #ff9500;
  color: #ffffff;
}

/* 商品信息 */
.goods-info {
  background-color: #ffffff;
  padding: 32rpx 24rpx;
  margin-top: 12rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  border-radius: 12rpx 12rpx 0 0;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.goods-name {
  font-size: 32rpx;
  font-weight: 700;
  color: #333333;
  line-height: 44rpx;
}

.goods-price-row {
  display: flex;
  align-items: baseline;
  gap: 16rpx;
}

.goods-price {
  font-size: 36rpx;
  font-weight: 600;
  color: #000000;
}

.goods-price.special-price {
  color: #ff3b30;
}

.goods-original-price {
  font-size: 28rpx;
  color: #999999;
  text-decoration: line-through;
}

.goods-stock {
  font-size: 26rpx;
  color: #999999;
}

.goods-spec {
  font-size: 26rpx;
  color: #999999;
}

/* 商品描述 */
.goods-description {
  background-color: #ffffff;
  padding: 32rpx 24rpx;
  margin-top: 12rpx;
  border-radius: 12rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
  margin-bottom: 140rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 16rpx;
}

.description-content {
  font-size: 26rpx;
  color: #666666;
  line-height: 40rpx;
}

/* 底部操作栏 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 140rpx;
  background-color: #ffffff;
  display: flex;
  align-items: center;
  padding: 0 32rpx;
  box-shadow: 0 -4rpx 16rpx rgba(0, 0, 0, 0.1);
  z-index: 99;
  border-top: 1rpx solid #f0f0f0;
}

.quantity-control {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-right: 32rpx;
}

.quantity-btn {
  width: 56rpx;
  height: 56rpx;
  border-radius: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  font-weight: 500;
}

.quantity-btn.minus {
  background-color: #f5f5f5;
  color: #333333;
  border: 1rpx solid #e0e0e0;
}

.quantity-btn.plus {
  background-color: #ff3b30;
  color: #ffffff;
  border: none;
}

.quantity-btn:active {
  opacity: 0.8;
}

.quantity-input {
  min-width: 40rpx;
  text-align: center;
  font-size: 28rpx;
  font-weight: 500;
  color: #333333;
}

.add-to-cart {
  flex: 1;
  height: 80rpx;
  background-color: #000000;
  color: #ffffff;
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 500;
}

.add-to-cart:active {
  background-color: #333333;
}