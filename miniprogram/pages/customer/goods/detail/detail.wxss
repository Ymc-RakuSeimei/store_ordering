.container {
  padding: 20rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
  padding-bottom: 140rpx;
  width: 100%;
  box-sizing: border-box;
  display: block !important;
  align-items: stretch !important;
}

/* 商品卡片 */
.product-card {
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  margin-bottom: 20rpx;
}

.product-img {
  width: 100%;
  height: 400rpx;
  object-fit: cover;
}

.product-info {
  padding: 24rpx;
}

.product-name {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 12rpx;
}

.product-spec {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 20rpx;
}

.price-row {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
}

.price-group {
  display: flex;
  align-items: baseline;
}

.sale-price {
  font-size: 40rpx;
  font-weight: bold;
  color: #ff4d4f;
}

.sale-price::before {
  content: '¥';
  font-size: 24rpx;
  margin-right: 4rpx;
}

.cost-price {
  font-size: 24rpx;
  color: #999;
  text-decoration: line-through;
  margin-left: 12rpx;
}

.cost-price::before {
  content: '¥';
  margin-right: 2rpx;
}

/* 库存信息 */
.stats-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.stats-row {
  display: flex;
  justify-content: space-between;
}

.stat-item {
  text-align: center;
  flex: 1;
}

.stat-value {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.stat-label {
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}

/* 表单卡片 */
.form-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.form-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 24rpx;
}

.form-item {
  margin-bottom: 24rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.form-label {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 0;
  flex: 1;
}

/* 数量选择器 - 与接龙详情页保持一致 */
.quantity-selector {
  display: flex;
  align-items: center;
}

.qty-btn {
  width: 60rpx;
  height: 60rpx;
  background: #f5f5f5;
  border: none;
  border-radius: 50%;
  font-size: 32rpx;
  color: #333;
  display: flex;
  align-items: center;
  justify-content: center;
}

.qty-btn.minus {
  background: #f5f5f5;
  color: #666;
}

.qty-btn.plus {
  background: #ff3b30;
  color: #ffffff;
}

.qty-btn:disabled {
  background: #f0f0f0;
  color: #ccc;
}

.qty-input {
  width: 80rpx;
  height: 60rpx;
  text-align: center;
  font-size: 28rpx;
  margin: 0 16rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
  border: none;
  outline: none;
}

/* 商品详情内容 */
.detail-content {
  font-size: 28rpx;
  color: #666;
  line-height: 48rpx;
}

/* 底部按钮 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  padding: 16rpx 24rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -2rpx 10rpx rgba(0, 0, 0, 0.05);
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.cart-info {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.cart-icon {
  position: relative;
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.cart-icon-image {
  width: 100%;
  height: 100%;
}

.cart-badge {
  position: absolute;
  top: -8rpx;
  right: -8rpx;
  min-width: 32rpx;
  height: 32rpx;
  background-color: #ff3b30;
  color: #ffffff;
  font-size: 20rpx;
  font-weight: 600;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 8rpx;
}

.cart-price {
  display: flex;
  flex-direction: column;
}

.cart-label {
  font-size: 20rpx;
  color: #999999;
}

.cart-amount {
  font-size: 28rpx;
  font-weight: 700;
  color: #000000;
}

.submit-btn {
  flex: 1;
  height: 88rpx;
  background: #000000;
  color: #fff;
  border: none;
  border-radius: 44rpx;
  font-size: 32rpx;
  font-weight: bold;
  margin-left: 24rpx;
}

.submit-btn:disabled {
  background: #ccc;
}

/* 状态标签 */
.status-tag {
  display: inline-block;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
}

.status-spot {
  background: #f6ffed;
  color: #52c41a;
}

.status-special {
  background: #fff7e6;
  color: #fa8c16;
}

/* 空状态 */
.empty-state,
.loading-state {
  text-align: center;
  padding: 80rpx 0;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}
