.container {
  background-color: #f5f5f5;
  min-height: 100vh;
  padding-bottom: 140rpx;
  padding-top: 20rpx;
}

/* 顶部导航栏 */
.nav-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 100rpx;
  padding: 0 32rpx;
  background-color: transparent;
  position: relative;
  margin-top: 20rpx;
}

.nav-back {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: flex-start;
  flex-shrink: 0;
}

.back-icon {
  font-size: 56rpx;
  font-weight: 400;
  color: #000000;
  line-height: 1;
}

.nav-title {
  position: absolute;
  left: 50%;
  transform: translateX(-50%);
  font-size: 40rpx;
  font-weight: 700;
  color: #000000;
  white-space: nowrap;
}

.nav-placeholder {
  width: 80rpx;
  flex-shrink: 0;
  visibility: hidden;
}

/* 搜索栏 */
.search-bar {
  background-color: transparent;
  padding: 20rpx 32rpx;
}

.search-box {
  display: flex;
  align-items: center;
  background-color: #ffffff;
  border-radius: 60rpx;
  padding: 20rpx 28rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.search-icon {
  width: 36rpx;
  height: 36rpx;
  margin-right: 16rpx;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: #333333;
}

.search-placeholder {
  color: #999999;
  font-size: 28rpx;
}

/* 标签栏 */
.tab-bar {
  display: flex;
  gap: 20rpx;
  padding: 20rpx 32rpx;
  background-color: transparent;
}

.tab-item {
  padding: 14rpx 32rpx;
  border-radius: 60rpx;
  font-size: 28rpx;
  font-weight: 500;
  color: #666666;
  background-color: #ffffff;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.tab-item.active {
  background-color: #000000;
  color: #ffffff;
}

/* 组件容器 - 统一内边距，确保所有组件卡片宽度一致 */
.component-container {
  padding: 0 24rpx;
}

/* 底部购物车栏 */
.cart-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background-color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 32rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.08);
  z-index: 20;
}

.cart-left {
  display: flex;
  align-items: center;
  flex: 1;
}

.cart-icon-wrapper {
  position: relative;
  margin-right: 20rpx;
}

.cart-icon {
  width: 56rpx;
  height: 56rpx;
}

.cart-badge {
  position: absolute;
  top: -8rpx;
  right: -8rpx;
  background-color: #ff3b30;
  color: #ffffff;
  font-size: 20rpx;
  font-weight: 600;
  min-width: 32rpx;
  height: 32rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 8rpx;
}

.cart-info {
  display: flex;
  flex-direction: column;
}

.cart-label {
  font-size: 22rpx;
  color: #999999;
}

.cart-price {
  font-size: 32rpx;
  font-weight: 700;
  color: #000000;
}

.cart-checkout {
  background-color: #000000;
  padding: 16rpx 40rpx;
  border-radius: 40rpx;
}

.cart-checkout text {
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 500;
}

/* 购物车弹窗 */
.cart-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  z-index: 100;
  display: flex;
  align-items: flex-end;
  visibility: hidden;
  opacity: 0;
  transition: all 0.3s ease;
}

.cart-modal.show {
  visibility: visible;
  opacity: 1;
}

.cart-modal-content {
  background-color: #ffffff;
  border-radius: 32rpx 32rpx 0 0;
  width: 100%;
  max-height: 70vh;
  display: flex;
  flex-direction: column;
  transform: translateY(100%);
  transition: transform 0.3s ease;
}

.cart-modal.show .cart-modal-content {
  transform: translateY(0);
}

.cart-modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.cart-modal-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #000000;
}

.cart-modal-close {
  font-size: 48rpx;
  color: #999999;
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.cart-modal-list {
  flex: 1;
  max-height: 50vh;
  padding: 0 32rpx;
}

.cart-modal-item {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.cart-modal-image {
  width: 100rpx;
  height: 100rpx;
  border-radius: 12rpx;
  margin-right: 24rpx;
  background-color: #f5f5f5;
}

.cart-modal-info {
  flex: 1;
}

.cart-modal-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 8rpx;
}

.cart-modal-tag {
  display: inline-block;
  background-color: #000000;
  color: #ffffff;
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 20rpx;
  margin-bottom: 8rpx;
}

.cart-modal-price {
  font-size: 26rpx;
  font-weight: 600;
  color: #000000;
}

.cart-modal-control {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.control-btn {
  width: 56rpx;
  height: 56rpx;
  border-radius: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  font-weight: 500;
}

.control-btn.minus {
  background-color: #f5f5f5;
  color: #333333;
  border: 1rpx solid #e0e0e0;
}

.control-btn.plus {
  background-color: #ff3b30;
  color: #ffffff;
}

.control-num {
  font-size: 28rpx;
  font-weight: 500;
  color: #333333;
  min-width: 40rpx;
  text-align: center;
}

.cart-modal-empty {
  text-align: center;
  padding: 80rpx 0;
  color: #999999;
  font-size: 28rpx;
}

.cart-modal-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx;
  border-top: 1rpx solid #f0f0f0;
  background-color: #ffffff;
}

.cart-modal-total {
  display: flex;
  align-items: baseline;
  gap: 12rpx;
}

.total-label {
  font-size: 28rpx;
  color: #666666;
}

.total-price {
  font-size: 40rpx;
  font-weight: 700;
  color: #000000;
}

.cart-modal-checkout {
  background-color: #000000;
  padding: 20rpx 48rpx;
  border-radius: 40rpx;
}

.cart-modal-checkout text {
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 500;
}