<!-- 今日上新页面 -->
<view class="container">
  <!-- 顶部导航栏 -->
  <view class="nav-bar">
    <view class="nav-back" bindtap="goBack">
      <text class="back-icon"></text>
    </view>
    <view class="nav-title">今日上新</view>
    <view class="nav-placeholder"></view>
  </view>

  <!-- 标签与统计区 -->
  <view class="stats-area">
    <view class="active-tag">今日上新</view>
    <text class="stats-count">共{{totalCount}}件新品</text>
  </view>

  <!-- 商品列表区（2列网格） -->
  <view class="goods-list">
    <block wx:for="{{goodsList}}" wx:key="id">
      <view class="goods-card">
        <view class="goods-image-wrapper">
          <image wx:if="{{item.image}}" class="goods-image" src="{{item.image}}" mode="aspectFill"></image>
          <view wx:else class="goods-image-placeholder"></view>
          
          <!-- 统一角标逻辑：和其他页面完全对齐 -->
          <!-- 1. 特价商品：强制显示「特价处理」+橙色 -->
          <view class="goods-badge special" wx:if="{{item.type === 'special'}}">特价处理</view>
          <!-- 2. 预定商品：强制显示「接龙预定」+红色 -->
          <view class="goods-badge preorder" wx:elif="{{item.type === 'preorder'}}">接龙预定</view>
          <!-- 3. 现货商品：强制显示「现货订购」+黑色 -->
          <view class="goods-badge spot" wx:elif="{{item.type === 'spot'}}">现货订购</view>
          <!-- 4. 兜底：其他类型按原数据显示 -->
          <view class="goods-badge {{item.badgeClass}}" wx:elif="{{item.badgeText}}">{{item.badgeText}}</view>
          <!-- 5. 无角标时占位，保持布局一致 -->
          <view class="goods-badge-placeholder" wx:else></view>
        </view>
        <view class="goods-info">
          <text class="goods-name">{{item.name}}</text>
          <view class="goods-price-row">
            <text class="goods-price {{item.priceClass}}">¥{{item.price}}</text>
            <text class="goods-original-price" wx:if="{{item.originalPrice}}">¥{{item.originalPrice}}</text>
          </view>
          <text class="goods-stock">{{item.statusText}}</text>
          <text class="goods-spec">规格:{{item.spec}}</text>
        </view>
        <view class="goods-action" bindtap="onAction" data-item="{{item}}">
          {{item.actionText}}
        </view>
      </view>
    </block>
  </view>

  <!-- 底部购物车栏 -->
  <view class="cart-bar" bindtap="showCartDetail">
    <view class="cart-left">
      <view class="cart-icon-wrapper">
        <image class="cart-icon" src="/images/icon_shop.png" mode="aspectFit"></image>
        <view class="cart-badge" wx:if="{{cartTotalCount > 0}}">{{cartTotalCount}}</view>
      </view>
      <view class="cart-info">
        <text class="cart-label">合计（现货+预定）</text>
        <text class="cart-price">¥{{cartTotalPrice}}</text>
      </view>
    </view>
    <view class="cart-checkout" catchtap="checkout">
      <text>合并结算</text>
    </view>
  </view>
</view>

<!-- 购物车详情弹窗 -->
<view class="cart-modal {{showCartModal ? 'show' : ''}}" bindtap="hideCartDetail">
  <view class="cart-modal-content" catchtap="stopPropagation">
    <view class="cart-modal-header">
      <text class="cart-modal-title">购物车</text>
      <view class="cart-modal-close" bindtap="hideCartDetail">×</view>
    </view>
    <scroll-view class="cart-modal-list" scroll-y>
      <block wx:for="{{cartList}}" wx:key="id">
        <view class="cart-modal-item">
          <image class="cart-modal-image" src="{{item.image}}" mode="aspectFill"></image>
          <view class="cart-modal-info">
            <view class="cart-modal-name">{{item.name}}</view>
            <view class="cart-modal-tag" wx:if="{{item.type === 'preorder'}}">接龙预定</view>
            <text class="cart-modal-price">¥{{item.price}}</text>
          </view>
          <view class="cart-modal-control">
            <view class="control-btn minus" bindtap="decreaseQuantity" data-id="{{item.id}}">-</view>
            <text class="control-num">{{item.quantity}}</text>
            <view class="control-btn plus" bindtap="increaseQuantity" data-id="{{item.id}}">+</view>
          </view>
        </view>
      </block>
      <view class="cart-modal-empty" wx:if="{{cartList.length === 0}}">
        <text>购物车是空的</text>
      </view>
    </scroll-view>
    <view class="cart-modal-footer">
      <view class="cart-modal-total">
        <text class="total-label">合计</text>
        <text class="total-price">¥{{cartTotalPrice}}</text>
      </view>
      <view class="cart-modal-checkout" catchtap="checkout">
        <text>去结算</text>
      </view>
    </view>
  </view>
</view>