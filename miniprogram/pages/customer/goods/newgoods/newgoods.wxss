/* pages/customer/goods/newgoods/newgoods.wxss */
.page {padding: 12px 8px; background: #f6f6f6; min-height: 100vh;}
.title-wrap {flex-direction: row; display: flex; justify-content: space-between; align-items: center; margin-bottom: 10px;}
.page-title {font-size: 22px; font-weight: 700; color: #111;}
.page-hot {font-size: 14px; color: #777;}
.grid {flex-direction: row; display: flex; flex-wrap: wrap; justify-content: space-between;}
.card {width: 48%; background: #fff; border-radius: 10px; overflow: hidden; margin-bottom: 10px; box-shadow: 0 4px 12px rgba(0,0,0,.08);}
.card-img {width: 100%; height: 120px;}
.card-body {padding: 8px 10px;}
.card-name {font-size: 14px; font-weight: 700; color: #1a1a1a; line-height: 1.4; display: block; margin-bottom: 6px;}
.tag-row {flex-direction: row; display: flex; margin-bottom: 6px;}
.tag {font-size: 10px; padding: 2px 5px; border-radius: 3px; margin-right: 4px; color: #fff;}
.tag-blue {background: #4f8bf9;}
.tag-red {background: #ff5e5e;}
.price-row {flex-direction: row; display: flex; justify-content: space-between; align-items: center;}
.price {font-size: 16px; color: #f63f3f; font-weight: 700;}
.spec {font-size: 12px; color: #999;}
.btn-order {margin: 0 8px 8px; height: 28px; line-height: 28px; background: #1e87f0; color: #fff; border-radius: 14px; border: none; font-size: 12px;}
.empty {text-align: center; color: #999; font-size: 14px; padding: 30px 0;}
