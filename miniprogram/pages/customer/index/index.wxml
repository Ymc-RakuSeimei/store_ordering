<!-- 买家端首页 - 纯页面结构 -->
<view class="container">
  <view class="header">
    <view class="welcome-text">
      <text>Hi，{{userInfo.nickName || '游客'}}</text>
      <text class="main-title">欢迎来到MC_store。</text>
    </view>
    <!-- 使用 button 组件包裹头像，支持选择头像 -->
    <button class="avatar-btn" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar">
      <image class="avatar" src="{{userInfo.avatarUrl}}" mode="aspectFill"></image>
    </button>
  </view>

  <!-- 昵称编辑区域（首次登录或未设置时显示） -->
  <view class="nickname-section" wx:if="{{showNicknameInput}}">
    <input 
      type="nickname" 
      class="nickname-input" 
      placeholder="点击获取微信昵称" 
      bindblur="onInputNickname"
    />
    <text class="nickname-tip">点击输入框可获取微信昵称</text>
  </view>

  <view class="card-container">
    <view class="card-item" bindtap="goToNewGoods">
      <image class="card-icon" src="cloud://cloud1-2gltiqs6a2c5cd76.636c-cloud1-2gltiqs6a2c5cd76-1411302136/icons/icon_new.png"></image>
      <text class="card-title">今日上新</text>
      <text class="card-subtitle">货品更新、新品发售</text>
      <view class="new-tag">●</view>
    </view>
    <view class="card-item" bindtap="goToShopList">
      <image class="card-icon" src="cloud://cloud1-2gltiqs6a2c5cd76.636c-cloud1-2gltiqs6a2c5cd76-1411302136/icons/icon_shop.png"></image>
      <text class="card-title">进店选购</text>
      <text class="card-subtitle">买点儿什么？</text>
    </view>
    <view class="card-item" bindtap="goToMyOrder">
      <image class="card-icon" src="cloud://cloud1-2gltiqs6a2c5cd76.636c-cloud1-2gltiqs6a2c5cd76-1411302136/icons/icon_order.png"></image>
      <text class="card-title">我的订单</text>
      <text class="card-subtitle">货品总览、到货情况、取货码</text>
    </view>
    <view class="card-item" bindtap="goToFeedback">
      <image class="card-icon" src="cloud://cloud1-2gltiqs6a2c5cd76.636c-cloud1-2gltiqs6a2c5cd76-1411302136/icons/二维码.png"></image>
      <text class="card-title">扫码取货</text>
      <text class="card-subtitle">出示身份核验码</text>
    </view>
  </view>
  <view class="card-row">
    <view class="card-item long-card-item" bindtap="goToMessage">
      <image class="card-icon" src="cloud://cloud1-2gltiqs6a2c5cd76.636c-cloud1-2gltiqs6a2c5cd76-1411302136/icons/icon_msg.png"></image>
      <text class="card-title">消息中心</text>
      <view wx:if="{{unreadMessageCount > 0}}" class="unread-badge">
        {{unreadMessageCount > 99 ? '99+' : unreadMessageCount}}
      </view>
    </view>
    <view class="card-item long-card-item" bindtap="openAiAssistant">
      <image class="card-icon" src="cloud://cloud1-2gltiqs6a2c5cd76.636c-cloud1-2gltiqs6a2c5cd76-1411302136/icons/icon_ai.png"></image>
      <text class="card-title">AI智能助手</text>
    </view>
  </view>
</view>