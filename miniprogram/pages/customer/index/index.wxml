<!-- 买家端首页 - 纯页面结构 -->
<view class="container">
  <!-- 顶部：欢迎语 + 头像 -->
  <view class="header">
    <view class="welcome-text">
      <text>Hi，派大星</text>
      <text class="main-title">欢迎来到MC_store。</text>
    </view>
    <image class="avatar" src="/images/avatar.png"></image>
  </view>

  <!-- 功能卡片区域 -->
  <view class="card-container">
    <view class="card-item" bindtap="goToNewGoods">
      <image class="card-icon" src="/images/icon_new.png"></image>
      <text class="card-title">今日上新</text>
      <text class="card-subtitle">货品更新、新品预售</text>
      <view class="new-tag">●</view>
    </view>

    <view class="card-item" bindtap="goToShopList">
      <image class="card-icon" src="/images/icon_shop.png"></image>
      <text class="card-title">进店选购</text>
      <text class="card-subtitle">买点儿什么？</text>
    </view>

    <view class="card-item" bindtap="goToMyOrder">
      <image class="card-icon" src="/images/icon_order.png"></image>
      <text class="card-title">我的订单</text>
      <text class="card-subtitle">货品总览、到货情况、取货码</text>
    </view>

    <view class="card-item" bindtap="goToFeedback">
      <image class="card-icon" src="/images/icon_back.png"></image>
      <text class="card-title">售后反馈</text>
      <text class="card-subtitle">问题反馈、售后处理</text>
    </view>
  </view>

  <!-- 消息中心长卡片 -->
  <view class="long-card" bindtap="goToMessage">
  <view class="center-box">
    <image class="long-icon" src="/images/icon_msg.png"></image>
    <text class="long-title">消息中心</text>
  </view>
</view>

  <!-- 底部标语 -->
  <text class="bottom-text">Wish you a happy shopping!</text>
</view>