page {
  background-color: #ffffff;
  font-family: PingFang SC, Helvetica Neue, Arial, sans-serif;
}

.container {
  padding: 30rpx;
  box-sizing: border-box;
}

.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin: 20rpx 0 50rpx;
}

.welcome-text {
  display: flex;
  flex-direction: column;
  color: #333;
}

.main-title {
  font-size: 50rpx;
  font-weight: bold;
  margin-top: 10rpx;
}

.avatar {
  width: 110rpx;
  height: 110rpx;
  border-radius: 16rpx;
}

.card-container {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
  position: relative;
  padding-bottom: 10rpx;
}

.card-item {
  width: 42%;
  background: #ffffff;
  border-radius: 24rpx;
  padding: 40rpx 20rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 6rpx 20rpx rgba(0, 0, 0, 0.123);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  position: relative;
  min-height: 320rpx;
}

.card-icon {
  width: 70rpx;
  height: 70rpx;
  margin-bottom: 20rpx;
}

.card-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}

.card-subtitle {
  font-size: 22rpx;
  color: #888;
  text-align: left;
}

.new-tag {
  position: absolute;
  top: 26rpx;
  right: 26rpx;
  color: #ff3b30;
  font-size: 24rpx;
}

.ai-entry {
  position: absolute;
  left: 50%;
  top: 50%;
  width: 132rpx;
  height: 132rpx;
  transform: translate(-50%, -50%);
  border-radius: 50%;
  background: linear-gradient(135deg, #1677ff 0%, #2fb0ff 100%);
  box-shadow: 0 18rpx 36rpx rgba(23, 119, 255, 0.25);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  z-index: 3;
  border: 8rpx solid rgba(255, 255, 255, 0.96);
}

.ai-entry-icon {
  width: 56rpx;
  height: 56rpx;
}

.ai-entry-label {
  margin-top: 4rpx;
  color: #ffffff;
  font-size: 20rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
}

.long-card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 30rpx;
  margin: 10rpx 0 50rpx;
  box-shadow: 0 6rpx 20rpx rgba(0, 0, 0, 0.06);
  display: flex;
  justify-content: center;
  align-items: center;
  width: 90%;
  margin-left: auto;
  margin-right: auto;
}

.center-box {
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}

.icon-container {
  position: relative;
  margin-right: 40rpx;
}

.long-icon {
  width: 60rpx;
  height: 60rpx;
}

.long-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #333;
}

.unread-badge {
  position: absolute;
  top: -15rpx;
  right: -15rpx;
  background-color: #ff3b30;
  color: white;
  font-size: 20rpx;
  font-weight: bold;
  min-width: 40rpx;
  height: 40rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 10rpx;
  box-shadow: 0 2rpx 8rpx rgba(255, 59, 48, 0.3);
}

.bottom-text {
  font-family: Georgia, 'Times New Roman', Times, serif;
  display: block;
  text-align: center;
  font-weight: bold;
  font-size: 42rpx;
  color: #333;
  font-style: italic;
}
