.all-container {
  background-color: #ffffff;
  height: 100%;
  display: flex;
  flex-direction: column;
}

/* 消息列表滚动区域 */
.message-scroll {
  flex: 1;
  height: 0;
}

/* 消息列表 */
.message-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  padding: 24rpx 0;
}

/* 消息卡片 - 统一商家端样式 */
.message-card {
  background: #fff;
  border-radius: 18rpx;
  padding: 24rpx 20rpx;
  min-height: 120rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  box-shadow: 0 6rpx 12rpx rgba(0, 0, 0, 0.05);
  border-left: 8rpx solid #ddd;
}

/* 不同类型消息的左边框颜色 */
.message-card.type-pickup {
  border-left-color: #4caf50;
}

.message-card.type-newgoods {
  border-left-color: #ff9500;
}

/* 消息内容区域 */
.message-content {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.message-title {
  font-size: 28rpx;
  color: #333;
  font-weight: 600;
  margin-bottom: 6rpx;
}

.message-sub {
  font-size: 24rpx;
  color: #999;
}

/* 未读标识 */
.unread-badge {
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  font-weight: 600;
  flex-shrink: 0;
  background: #fff5f5;
  color: #ff3b30;
  margin-right: 12rpx;
}

/* 查看按钮 */
.view-btn {
  background: #007AFF;
  color: #fff;
  border: none;
  border-radius: 14rpx;
  padding: 12rpx 20rpx;
  font-size: 24rpx;
  font-weight: 600;
  flex-shrink: 0;
}

.view-btn.green {
  background: #007AFF;
  color: #fff;
}

.view-btn.orange {
  background: #007AFF;
  color: #fff;
}

.view-btn::after {
  border: none;
}

.view-btn:active {
  opacity: 0.8;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 120rpx 0;
  color: #999999;
  font-size: 28rpx;
}

/* 加载状态 */
.loading-state {
  position: fixed !important;
  top: 0 !important;
  left: 0 !important;
  right: 0 !important;
  bottom: 0 !important;
  background-color: #fff !important;
  display: flex !important;
  flex-direction: column !important;
  align-items: center !important;
  justify-content: center !important;
  z-index: 99999 !important;
}

.loading-spinner {
  width: 80rpx !important;
  height: 80rpx !important;
  border-radius: 50% !important;
  border: 4rpx solid #f3f3f3 !important;
  border-top: 4rpx solid #ff3b30 !important;
  animation: spin 1s linear infinite !important;
  margin-bottom: 20rpx !important;
}

.loading-text {
  color: #333 !important;
  font-size: 28rpx !important;
  font-weight: 500 !important;
}

@keyframes spin {
  0% {
    transform: rotate(0deg);
  }

  100% {
    transform: rotate(360deg);
  }
}

/* 一键删除按钮 */
.delete-all-btn {
  width: 100%;
  height: 100rpx;
  background: #ff3b30;
  border-radius: 30rpx;
  margin-top: 20rpx;
  margin-bottom: 100rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  flex-shrink: 0;
}

.delete-all-btn text {
  font-size: 34rpx;
  font-weight: 600;
  color: #ffffff;
}

.delete-all-btn:active {
  opacity: 0.8;
  transform: scale(0.98);
}