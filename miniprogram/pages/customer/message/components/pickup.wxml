<!-- 取货提醒组件 -->
<view class="pickup-container">
  <!-- 加载状态 -->
  <view wx:if="{{loading}}" class="loading-state">
    <view class="loading-spinner"></view>
    <text class="loading-text">加载中...</text>
  </view>
  
  <!-- 消息列表 -->
  <view wx:else class="message-list">
    <block wx:for="{{messageList}}" wx:key="id">
      <view class="message-card" bindtap="markAsRead" data-id="{{item.id}}">
        <view class="message-content">
          <text class="message-number">{{index + 1}}.</text>
          <text class="message-text">{{item.content}}</text>
          <view wx:if="{{!item.isRead}}" class="unread-dot"></view>
        </view>
        <view class="view-btn green" bindtap="viewDetail" data-id="{{item.id}}" catchtap="viewDetail">
          {{item.btnText}}
        </view>
      </view>
    </block>
    
    <!-- 空状态 -->
    <view class="empty-state" wx:if="{{messageList.length === 0}}">
      <text>暂无取货提醒</text>
    </view>
  </view>
  
  <!-- 一键删除按钮 - 仅在有消息时显示 -->
  <view wx:if="{{messageList.length > 0}}" class="delete-all-btn" bindtap="deleteAllMessages">
    <text>一键删除</text>
  </view>
</view>