<!-- 消息中心主容器页面 -->
<view class="container">
  <!-- Tab栏 -->
  <view class="tab-header">
    <view class="tab-bar">
      <view class="tab-item {{currentTab === 'all' ? 'active' : ''}}" bindtap="switchTab" data-tab="all">
        <text>全部</text>
      </view>
      <view class="tab-item {{currentTab === 'pickup' ? 'active' : ''}}" bindtap="switchTab" data-tab="pickup">
        <text>取货提醒</text>
      </view>
      <view class="tab-item {{currentTab === 'newgoods' ? 'active' : ''}}" bindtap="switchTab" data-tab="newgoods">
        <text>上新通知</text>
      </view>
    </view>
  </view>

  <!-- 组件容器 -->
  <view class="component-container">
    <!-- 全部消息组件 -->
    <all-component id="allComponent" hidden="{{currentTab !== 'all'}}" bind:deleteAllMessages="deleteAllMessages"></all-component>
    <!-- 取货提醒组件 -->
    <pickup-component id="pickupComponent" hidden="{{currentTab !== 'pickup'}}" bind:deleteAllMessages="deleteAllMessages"></pickup-component>
    <!-- 上新通知组件 -->
    <newgoods-component id="newgoodsComponent" hidden="{{currentTab !== 'newgoods'}}" bind:deleteAllMessages="deleteAllMessages"></newgoods-component>
  </view>
</view>