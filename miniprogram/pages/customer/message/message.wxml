<!-- 消息中心主容器页面 -->
<view class="container">
  <view class="tab-header">
    <view class="tab-bar">
      <view class="tab-item {{currentTab === 'all' ? 'active' : ''}}" bindtap="switchTab" data-tab="all">
        <text>全部</text>
      </view>
      <view class="tab-item {{currentTab === 'pickup' ? 'active' : ''}}" bindtap="switchTab" data-tab="pickup">
        <text>取货提醒</text>
      </view>
      <view class="tab-item {{currentTab === 'newgoods' ? 'active' : ''}}" bindtap="switchTab" data-tab="newgoods">
        <text>上新通知</text>
      </view>
    </view>
  </view>

  <view wx:if="{{loading}}" class="loading-state">
    <view class="loading-spinner"></view>
    <text class="loading-text">加载中...</text>
  </view>

  <scroll-view wx:else class="message-scroll" scroll-y enable-flex>
    <view class="message-list">
      <block wx:for="{{filteredMessageList}}" wx:key="id">
        <view class="message-card type-{{item.type}}" bindtap="markAsRead" data-id="{{item.id}}">
          <view class="message-content">
            <text class="message-title">{{item.type === 'pickup' ? '取货提醒' : '上新通知'}}</text>
            <text class="message-sub">{{item.content}}</text>
          </view>
          <view wx:if="{{!item.isRead}}" class="unread-badge">未读</view>
          <view class="view-btn" bindtap="viewDetail" data-id="{{item.id}}" catchtap="viewDetail">
            {{item.btnText}}
          </view>
        </view>
      </block>

      <view wx:if="{{!hasFilteredMessages}}" class="empty-state">
        <text>{{currentTab === 'all' ? '暂无消息' : currentTab === 'pickup' ? '暂无取货提醒' : '暂无上新通知'}}</text>
      </view>
    </view>
  </scroll-view>

  <view wx:if="{{!loading && hasFilteredMessages}}" class="delete-all-btn" bindtap="deleteAllMessages">
    <text>一键删除</text>
  </view>
</view>
