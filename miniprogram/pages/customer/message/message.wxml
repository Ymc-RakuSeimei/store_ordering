<!-- 消息中心主容器页面 -->
<view class="container">
  <!-- 顶部导航栏 -->
  <view class="nav-bar">
    <view class="nav-back" bindtap="goBack">
      <text class="back-icon"></text>
    </view>
    <view class="nav-title">消息中心</view>
    <view class="nav-placeholder"></view>
  </view>

  <!-- Tab栏 + 一键删除 -->
  <view class="tab-header">
    <view class="tab-bar">
      <view class="tab-item {{currentTab === 'all' ? 'active' : ''}}" bindtap="switchTab" data-tab="all">
        <text>全部</text>
      </view>
      <view class="tab-item {{currentTab === 'pickup' ? 'active' : ''}}" bindtap="switchTab" data-tab="pickup">
        <text>取货提醒</text>
      </view>
      <view class="tab-item {{currentTab === 'newgoods' ? 'active' : ''}}" bindtap="switchTab" data-tab="newgoods">
        <text>上新通知</text>
      </view>
    </view>
    <view class="delete-all" bindtap="deleteAllMessages">
      <text>一键删除</text>
    </view>
  </view>

  <!-- 组件容器 -->
  <view class="component-container">
    <!-- 全部消息组件 -->
    <block wx:if="{{currentTab === 'all'}}">
      <all-component></all-component>
    </block>
    <!-- 取货提醒组件 -->
    <block wx:if="{{currentTab === 'pickup'}}">
      <pickup-component></pickup-component>
    </block>
    <!-- 上新通知组件 -->
    <block wx:if="{{currentTab === 'newgoods'}}">
      <newgoods-component></newgoods-component>
    </block>
  </view>
</view>

<!-- 底部导航栏 - 与主页统一 -->
<view class="tab-bar-bottom">
  <view class="tab-bottom-item" bindtap="goToHome">
    <image class="tab-icon" src="/images/tab_home.png" mode="aspectFit"></image>
    <text class="tab-text">首页</text>
  </view>
  <view class="tab-bottom-item" bindtap="goToGoods">
    <image class="tab-icon" src="/images/tab_goods.png" mode="aspectFit"></image>
    <text class="tab-text">商品</text>
  </view>
  <view class="tab-bottom-item" bindtap="goToMy">
    <image class="tab-icon" src="/images/tab_my.png" mode="aspectFit"></image>
    <text class="tab-text">我的</text>
  </view>
</view>