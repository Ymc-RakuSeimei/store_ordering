.container {
  background-color: #F5F7FA;
  height: 100vh;
  padding: 20rpx;
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
}

/* Tab栏 + 一键删除区域 */
.tab-header {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 20rpx 0;
}

.tab-bar {
  display: flex;
  gap: 24rpx;
  align-items: center;
  justify-content: center;
  width: 100%;
  box-sizing: border-box;
  background-color: transparent;
  margin-bottom: 14rpx;
}

.tab-item {
  padding: 12rpx 28rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
  font-weight: 500;
  color: #333333;
  background-color: #f5f5f5;
  transition: all 0.3s ease;
}

.tab-item.active {
  background-color: #000000;
  color: #ffffff;
  transform: translateY(-2rpx);
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.15);
}

.delete-all {
  font-size: 28rpx;
  font-weight: 500;
  color: #ff3b30;
  padding: 12rpx 0;
}

.delete-all:active {
  opacity: 0.6;
}

/* 组件容器 */
.component-container {
  flex: 1;
  height: 0;
  overflow: hidden;
}