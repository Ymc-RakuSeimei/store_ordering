.container {
  background-color: #ffffff;
  min-height: 100vh;
  padding-bottom: 120rpx;
  padding-top: 20rpx;
}

/* 顶部导航栏 */
.nav-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 100rpx;
  padding: 0 32rpx;
  background-color: #ffffff;
  position: relative;
  margin-top: 20rpx;
}

.nav-back {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: flex-start;
  flex-shrink: 0;
}

.back-icon {
  font-size: 56rpx;
  font-weight: 400;
  color: #000000;
  line-height: 1;
}

.nav-title {
  position: absolute;
  left: 50%;
  transform: translateX(-50%);
  font-size: 40rpx;
  font-weight: 700;
  color: #000000;
  white-space: nowrap;
}

.nav-placeholder {
  width: 80rpx;
  flex-shrink: 0;
  visibility: hidden;
}

/* Tab栏 + 一键删除区域 */
.tab-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 32rpx;
  border-bottom: 1rpx solid #f0f0f0;
  margin-top: 10rpx;
}

.tab-bar {
  display: flex;
  gap: 24rpx;
}

.tab-item {
  padding: 12rpx 28rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
  font-weight: 500;
  color: #333333;
  background-color: #f5f5f5;
  transition: all 0.2s ease;
}

.tab-item.active {
  background-color: #000000;
  color: #ffffff;
}

.delete-all {
  font-size: 28rpx;
  font-weight: 500;
  color: #ff3b30;
  padding: 12rpx 0;
}

.delete-all:active {
  opacity: 0.6;
}

/* 组件容器 */
.component-container {
  flex: 1;
  padding: 0 32rpx;
  margin-top: 20rpx;
}

/* 底部导航栏 - 与主页统一 */
.tab-bar-bottom {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 100rpx;
  background-color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: space-around;
  border-top: 1rpx solid #f0f0f0;
  padding-bottom: env(safe-area-inset-bottom);
}

.tab-bottom-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  flex: 1;
  height: 100%;
}

.tab-icon {
  width: 48rpx;
  height: 48rpx;
  margin-bottom: 6rpx;
}

.tab-text {
  font-size: 22rpx;
  color: #999999;
}

/* 选中状态 - 图标和文字变蓝色 */
.tab-bottom-item.active .tab-icon {
  filter: brightness(0) saturate(100%) invert(35%) sepia(98%) saturate(1482%) hue-rotate(200deg) brightness(98%) contrast(101%);
}

.tab-bottom-item.active .tab-text {
  color: #007aff;
}