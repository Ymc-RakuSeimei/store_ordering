.container {
  background-color: #f5f7fa;
  height: 100vh;
  padding: 20rpx;
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
}

.tab-header {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 20rpx 0;
}

.tab-bar {
  display: flex;
  gap: 24rpx;
  align-items: center;
  justify-content: center;
  width: 100%;
  box-sizing: border-box;
  background-color: transparent;
  margin-bottom: 14rpx;
}

.tab-item {
  padding: 12rpx 28rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
  font-weight: 500;
  color: #333333;
  background-color: #f5f5f5;
  transition: all 0.3s ease;
}

.tab-item.active {
  background-color: #000000;
  color: #ffffff;
  transform: translateY(-2rpx);
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.15);
}

.message-scroll {
  flex: 1;
  height: 0;
}

.message-list {
  padding-bottom: 20rpx;
}

.message-card {
  background: #fff;
  border-radius: 18rpx;
  padding: 24rpx 20rpx;
  min-height: 120rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  box-shadow: 0 6rpx 12rpx rgba(0, 0, 0, 0.05);
  border-left: 8rpx solid #ddd;
  margin-bottom: 16rpx;
  position: relative;
}

.message-card.type-pickup {
  border-left-color: #4caf50;
}

.message-card.type-newgoods {
  border-left-color: #ff9500;
}

.message-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  min-width: 0;
  margin-right: 16rpx;
}

.message-title {
  font-size: 28rpx;
  color: #333;
  font-weight: 600;
  margin-bottom: 6rpx;
  line-height: 1.3;
}

.message-sub {
  font-size: 24rpx;
  color: #999;
  line-height: 1.3;
}

.unread-badge {
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  font-weight: 600;
  flex-shrink: 0;
  background: #fff5f5;
  color: #ff3b30;
  margin-right: 12rpx;
}

.view-btn {
  background: #007aff;
  color: #fff;
  border: none;
  border-radius: 14rpx;
  padding: 12rpx 20rpx;
  font-size: 24rpx;
  font-weight: 600;
  flex-shrink: 0;
  margin-left: 12rpx;
}

.view-btn::after {
  border: none;
}

.view-btn:active {
  opacity: 0.8;
}

.empty-state {
  text-align: center;
  padding: 120rpx 0;
  color: #999999;
  font-size: 28rpx;
}

.loading-state {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: #fff;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  z-index: 99999;
}

.loading-spinner {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  border: 4rpx solid #f3f3f3;
  border-top: 4rpx solid #ff3b30;
  animation: spin 1s linear infinite;
  margin-bottom: 20rpx;
}

.loading-text {
  color: #333;
  font-size: 28rpx;
  font-weight: 500;
}

@keyframes spin {
  0% {
    transform: rotate(0deg);
  }

  100% {
    transform: rotate(360deg);
  }
}

.delete-all-btn {
  width: 100%;
  height: 84rpx;
  background: #ff3b30;
  border-radius: 30rpx;
  margin-top: 20rpx;
  margin-bottom: 100rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  flex-shrink: 0;
  transition: all 0.3s ease;
}

.delete-all-btn text {
  font-size: 30rpx;
  font-weight: 600;
  color: #ffffff;
}

.delete-all-btn:active {
  opacity: 0.8;
  transform: scale(0.98);
}
