<!-- 我的页面 -->
<view class="container">
  <!-- 加载状态 -->
  <view wx:if="{{loading || loginLoading || contactLoading}}" class="loading-state">
    <view class="loading-spinner"></view>
    <view class="loading-text">{{loginLoading ? '获取中...' : (contactLoading ? '获取商家信息...' : '加载中...')}}</view>
  </view>
  
  <!-- 顶部用户信息区 -->
  <view class="header">
    <view class="greeting">
      <text class="greeting-title">Hello, {{userInfo.nickName}}</text>
      <text class="greeting-subtitle">Wish you a happy shopping!</text>
    </view>
    <button class="avatar-btn" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar">
      <image class="avatar" src="{{userInfo.avatarUrl}}" mode="aspectFill"></image>
    </button>
  </view>

  <!-- 昵称编辑区域（首次登录或未设置时显示） -->
  <view class="nickname-section" wx:if="{{showNicknameInput}}">
    <input 
      type="nickname" 
      class="nickname-input" 
      placeholder="点击获取微信昵称" 
      bindblur="onInputNickname"
    />
    <text class="nickname-tip">点击输入框可获取微信昵称</text>
  </view>

  <!-- 功能列表卡片 -->
  <view class="function-card">
    <!-- 订单中心 -->
    <view class="list-item" bindtap="goToOrderCenter">
      <image class="item-icon" src="cloud://cloud1-2gltiqs6a2c5cd76.636c-cloud1-2gltiqs6a2c5cd76-1411302136/icons/分组1.png" mode="aspectFit"></image>
      <view class="item-content">
        <text class="item-title">订单中心</text>
        <text class="item-subtitle">查看个人订单信息</text>
      </view>
    </view>
    <view class="divider"></view>

    <!-- 用户名 -->
    <view class="list-item">
      <image class="item-icon" src="cloud://cloud1-2gltiqs6a2c5cd76.636c-cloud1-2gltiqs6a2c5cd76-1411302136/icons/名片.png" mode="aspectFit"></image>
      <view class="item-content">
        <text class="item-title">{{userInfo.nickName}}</text>
        <text class="item-subtitle">用户名</text>
      </view>
    </view>
    <view class="divider"></view>

    <!-- 消息订阅通知 -->
    <view class="list-item" bindtap="toggleNotification">
      <image class="item-icon" src="cloud://cloud1-2gltiqs6a2c5cd76.636c-cloud1-2gltiqs6a2c5cd76-1411302136/icons/喇叭.png" mode="aspectFit"></image>
      <view class="item-content">
        <text class="item-title">消息订阅通知</text>
        <text class="item-subtitle">开启后不错过新品与到货通知</text>
      </view>
    </view>
    <view class="divider"></view>

    <!-- 手机号 - 点击手动输入 -->
    <view class="list-item" bindtap="editPhoneNumber">
      <image class="item-icon" src="cloud://cloud1-2gltiqs6a2c5cd76.636c-cloud1-2gltiqs6a2c5cd76-1411302136/icons/电话.png" mode="aspectFit"></image>
      <view class="item-content">
        <text class="item-phone">{{userInfo.phoneNumber || '点击绑定手机号'}}</text>
      </view>
    </view>
    <view class="divider"></view>

    <!-- 售后/联系商家 -->
    <view class="list-item" bindtap="contactService">
      <image class="item-icon" src="cloud://cloud1-2gltiqs6a2c5cd76.636c-cloud1-2gltiqs6a2c5cd76-1411302136/icons/商务用户.png" mode="aspectFit"></image>
      <view class="item-content">
        <text class="item-title">售后/联系商家</text>
      </view>
    </view>
  </view>
</view>