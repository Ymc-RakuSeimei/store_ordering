<view class="page">
  <!-- 顶部：头像 + Hello -->
  <view class="header">
    <image class="avatar" src="{{avatarUrl}}" mode="aspectFill" />
    <text class="hello">Hello! {{helloName}}~</text>

    <!-- 右上角装饰图标（占位） -->
    <view class="header-actions">
      <text class="header-action">扫码取货</text>
      <text class="header-action">上传</text>
    </view>
  </view>

  <!-- 个人信息卡片 -->
  <view class="card">
    <view class="row">
      <text class="row-icon">🏬</text>
      <text class="row-value">{{storeName}}</text>
    </view>

    <view class="divider" />

    <view class="row">
      <text class="row-icon">📍</text>
      <text class="row-value">{{address}}</text>
    </view>

    <view class="divider" />

    <view class="row">
      <text class="row-icon">🐟</text>
      <text class="row-value">{{nickname}}</text>
    </view>

    <view class="divider" />

    <view class="row">
      <text class="row-icon">☎️</text>
      <text class="row-value">{{phone}}</text>
    </view>

    <view class="divider" />

    <view class="row">
      <text class="row-icon">🐙</text>
      <navigator class="github" url="{{githubUrl}}" open-type="redirect">
        {{githubUrl}}
      </navigator>
    </view>
  </view>

  <!-- 更改按钮 -->
  <view class="edit-btn" bindtap="onEditTap">更改</view>

  <!-- 底部标语 -->
  <text class="run-text">Run your store very well!</text>

  <!-- 编辑弹窗 -->
  <view wx:if="{{editing}}" class="modal">
    <view class="modal-mask" bindtap="onCancelEdit" />
    <view class="modal-body">
      <text class="modal-title">修改个人信息</text>

      <view class="field">
        <text class="label">店名</text>
        <input class="input" value="{{draft.storeName}}" data-key="storeName" bindinput="onDraftInput" placeholder="MC_Store" />
      </view>
      <view class="field">
        <text class="label">地址</text>
        <input class="input" value="{{draft.address}}" data-key="address" bindinput="onDraftInput" placeholder="A市B区C街D号" />
      </view>
      <view class="field">
        <text class="label">用户名</text>
        <input class="input" value="{{draft.nickname}}" data-key="nickname" bindinput="onDraftInput" placeholder="wxzh123" />
      </view>
      <view class="field">
        <text class="label">电话</text>
        <input class="input" value="{{draft.phone}}" data-key="phone" bindinput="onDraftInput" placeholder="12345678901" />
      </view>
      <view class="field">
        <text class="label">GitHub</text>
        <input class="input" value="{{draft.githubUrl}}" data-key="githubUrl" bindinput="onDraftInput" placeholder="https://github.com/..." />
      </view>

      <view class="modal-actions">
        <button class="btn" bindtap="onCancelEdit">取消</button>
        <button class="btn btn-primary" type="primary" bindtap="onSaveEdit">保存</button>
      </view>
    </view>
  </view>
</view>