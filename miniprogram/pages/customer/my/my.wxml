<!-- 我的页面 -->
<view class="container">
  <!-- 顶部用户信息区 -->
  <view class="header">
    <view class="greeting" bindtap="handleLogin">
      <text class="greeting-title">Hello, {{userInfo.nickName}}</text>
      <text class="greeting-subtitle">Wish you a happy shopping!</text>
    </view>
    <image class="qrcode" src="/images/二维码.png" mode="aspectFill"></image>
    <image class="avatar" src="{{userInfo.avatarUrl}}" mode="aspectFill" bindtap="handleLogin"></image>
  </view>

  <!-- 功能列表卡片 -->
  <view class="function-card">
    <!-- 订单中心 -->
    <view class="list-item" bindtap="goToOrderCenter">
      <image class="item-icon" src="/images/分组1.png" mode="aspectFit"></image>
      <view class="item-content">
        <text class="item-title">订单中心</text>
        <text class="item-subtitle">查看个人订单信息</text>
      </view>
    </view>
    <view class="divider"></view>

    <!-- 用户名 -->
    <view class="list-item">
      <image class="item-icon" src="/images/名片.png" mode="aspectFit"></image>
      <view class="item-content">
        <text class="item-title">{{userInfo.nickName}}</text>
        <text class="item-subtitle">用户名</text>
      </view>
    </view>
    <view class="divider"></view>

    <!-- 消息订阅通知 -->
    <view class="list-item" bindtap="toggleNotification">
      <image class="item-icon" src="/images/喇叭.png" mode="aspectFit"></image>
      <view class="item-content">
        <text class="item-title">消息订阅通知</text>
        <text class="item-subtitle">开启后不错过新品与到货通知</text>
      </view>
    </view>
    <view class="divider"></view>

    <!-- 手机号 -->
    <view class="list-item">
      <image class="item-icon" src="/images/电话.png" mode="aspectFit"></image>
      <view class="item-content">
        <text class="item-phone">{{userInfo.phoneNumber || '点击绑定'}}</text>
      </view>
    </view>
    <view class="divider"></view>

    <!-- 售后/联系商家 -->
    <view class="list-item" bindtap="contactService">
      <image class="item-icon" src="/images/商务用户.png" mode="aspectFit"></image>
      <view class="item-content">
        <text class="item-title">售后/联系商家</text>
      </view>
    </view>
  </view>
</view>