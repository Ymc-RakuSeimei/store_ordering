/* 
 * pages/customer/my/my.wxss
 * 个人中心页面样式表
 * 包含个人信息展示、功能菜单、弹窗等组件样式
 */

/* 页面整体容器 - 设置最小高度占满视口，浅蓝色背景，底部预留tab栏空间 */
.page {
  min-height: 100vh;
  background: #eff4fa;
  box-sizing: border-box;
  padding: 20rpx 26rpx 180rpx; /* 给底部tab栏留出空间 */
}

/* 头部区域 - flex布局，水平排列头像和用户信息 */
.header {
  display: flex;
  align-items: center;
  padding: 8rpx 0 20rpx;
  position: relative; /* 为绝对定位的操作按钮提供参考 */
}

/* 用户头像 - 圆形设计，带细微边框 */
.avatar {
  width: 90rpx;
  height: 90rpx;
  border-radius: 50%; /* 圆形裁剪 */
  border: 2rpx solid rgba(0, 0, 0, 0.04);
  margin-right: 18rpx;
}

/* 欢迎文字 - 突出显示用户名 */
.hello {
  font-size: 34rpx;
  color: #111;
  font-weight: 600;
}

/* 头部操作按钮容器 - 右上角绝对定位 */
.header-actions {
  position: absolute;
  right: 0;
  top: 10rpx;
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 10rpx; /* 按钮之间间距 */
}

/* 单个操作按钮文字样式 */
.header-action {
  font-size: 20rpx;
  color: #999;
}

/* 卡片容器 - 白色圆角卡片，带阴影 */
.card {
  background: #ffffff;
  border-radius: 22rpx;
  box-shadow: 0 10rpx 24rpx rgba(0, 0, 0, 0.06);
  overflow: hidden;
  margin: 10rpx 0 0;
}

/* 菜单项行 - flex布局排列图标和内容 */
.row {
  display: flex;
  align-items: center;
  padding: 18rpx 22rpx;
}

/* 菜单图标容器 - 固定宽度居中显示 */
.row-icon {
  width: 76rpx;
  font-size: 34rpx;
  text-align: center;
  color: #333;
}

/* 菜单内容区域 - 自适应占满剩余空间 */
.row-value {
  flex: 1;
  font-size: 28rpx;
  font-weight: 600;
  color: #111;
  line-height: 36rpx;
  word-break: break-all; /* 长文本自动换行 */
}

/* 分割线 - 细灰色分隔线，左侧缩进 */
.divider {
  height: 1rpx;
  background: #e9e9e9;
  margin-left: 22rpx;
}

/* GitHub链接样式 - 蓝色带下划线 */
.github {
  flex: 1;
  color: #2f6bff;
  font-size: 24rpx;
  line-height: 34rpx;
  word-break: break-all;
  text-decoration: underline;
}

/* 编辑按钮 - 右下角固定定位悬浮按钮 */
.edit-btn {
  position: fixed;
  right: 90rpx;
  bottom: 160rpx; /* 距离底部位置 */
  width: 160rpx;
  height: 72rpx;
  background: #ffffff;
  border-radius: 40rpx; /* 圆角 */
  box-shadow: 0 10rpx 24rpx rgba(0, 0, 0, 0.14);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 600;
  color: #111;
  z-index: 20; /* 提高层级防止被遮挡 */
}

/* 跑马灯文字样式 - 特殊字体斜体效果 */
.run-text {
  display: block;
  margin-top: 42rpx;
  text-align: center;
  font-family: Georgia, 'Times New Roman', Times, serif;
  font-size: 42rpx;
  font-weight: 500;
  font-style: italic;
  color: #111;
}

/* ==== 弹窗相关样式 ==== */

/* 弹窗遮罩层容器 - 全屏居中显示弹窗内容 */
.modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 100; /* 最高层级显示 */
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 背景蒙层 - 半透明黑色背景 */
.modal-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.35);
}

/* 弹窗内容主体 - 白色圆角卡片 */
.modal-body {
  position: relative;
  width: 88%;
  background: #ffffff;
  border-radius: 22rpx;
  padding: 22rpx 22rpx 18rpx;
  box-shadow: 0 16rpx 40rpx rgba(0, 0, 0, 0.25);
}

/* 弹窗标题 - 居中加粗 */
.modal-title {
  display: block;
  text-align: center;
  font-size: 30rpx;
  font-weight: 700;
  color: #111;
  margin-bottom: 18rpx;
}

/* 表单字段行 - flex布局排列标签和输入框 */
.field {
  display: flex;
  align-items: center;
  margin-bottom: 14rpx;
}

/* 表单标签 - 固定宽度 */
.label {
  width: 120rpx;
  font-size: 24rpx;
  color: #333;
}

/* 输入框 - 自适应宽度，带边框 */
.input {
  flex: 1;
  border: 1rpx solid #e5e5e5;
  border-radius: 12rpx;
  padding: 10rpx 12rpx;
  height: 52rpx;
  font-size: 24rpx;
}

/* 弹窗按钮容器 - 并排两个按钮 */
.modal-actions {
  display: flex;
  gap: 16rpx; /* 按钮间距 */
  margin-top: 22rpx;
}

/* 通用按钮样式 */
.btn {
  flex: 1;
  height: 56rpx;
  line-height: 56rpx;
  border-radius: 16rpx;
  background: #f3f3f3;
  color: #333;
  font-size: 26rpx;
  border: none;
}

/* 主按钮样式 - 蓝色背景白色文字 */
.btn-primary {
  background: #007AFF;
  color: #fff;
}