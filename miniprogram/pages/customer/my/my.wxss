/* 全局样式 */
page {
  background-color: #ffffff;
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Helvetica Neue', Arial, sans-serif;
}

.container {
  width: 90%;
  margin: 0 auto;
  padding-bottom: 40rpx;
}

/* ========= 顶部用户信息区 ========= */
.header {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  margin-top: 60rpx;
  margin-bottom: 80rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

/* 左侧问候语区域 */
.greeting {
  display: flex;
  flex-direction: column;
  flex: 1;
}

.greeting-title {
  font-size: 44rpx;
  font-weight: 700;
  color: #000000;
  line-height: 1.2;
  margin-bottom: 8rpx;
}

.greeting-subtitle {
  font-size: 26rpx;
  font-family: 'Georgia', 'Times New Roman', '华文行书', cursive;
  color: #888888;
  font-style: italic;
}

/* 右侧区域（二维码 + 头像） */
.right-area {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

/* 二维码 */
.qrcode {
  width: 100rpx;
  height: 100rpx;
  background-color: #f5f5f5;
  border-radius: 12rpx;
}

/* 头像 */
.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background-color: #f5f5f5;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
}

/* ========= 功能列表卡片 ========= */
.function-card {
  background-color: #ffffff;
  border-radius: 32rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
  padding: 0 32rpx;
  margin-top: 40rpx;
  width: 100%;
  box-sizing: border-box;
}

/* 列表项 */
.list-item {
  display: flex;
  align-items: center;
  padding: 32rpx 0;
  width: 100%;
}

/* 左侧图标 */
.item-icon {
  width: 56rpx;
  height: 56rpx;
  margin-right: 32rpx;
  flex-shrink: 0;
}

/* 右侧文字区域 */
.item-content {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.item-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #000000;
  line-height: 1.4;
}

.item-subtitle {
  font-size: 24rpx;
  font-weight: 400;
  color: #888888;
  margin-top: 6rpx;
}

.item-phone {
  font-size: 32rpx;
  font-weight: 700;
  color: #000000;
}

/* 分隔线 */
.divider {
  height: 1rpx;
  background-color: #e5e5e5;
  margin: 0;
}