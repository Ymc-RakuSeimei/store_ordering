/* 全局样式 */
page {
  background-color: #ffffff;
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Helvetica Neue', Arial, sans-serif;
}

.container {
  width: 90%;
  margin: 0 auto;
  padding-bottom: 40rpx;
}

/* ========= 顶部用户信息区 ========= */
.header {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  margin-top: 60rpx;
  margin-bottom: 80rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

/* 左侧问候语区域 */
.greeting {
  display: flex;
  flex-direction: column;
  flex: 1;
}

.greeting-title {
  font-size: 44rpx;
  font-weight: 700;
  color: #000000;
  line-height: 1.2;
  margin-bottom: 8rpx;
}

.greeting-subtitle {
  font-size: 26rpx;
  font-family: 'Georgia', 'Times New Roman', '华文行书', cursive;
  color: #888888;
  font-style: italic;
}

/* 右侧区域（二维码 + 头像） */
.right-area {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

/* 二维码 */
/* 二维码 - 圆角矩形 */
.qrcode {
  width: 120rpx;
  height: 120rpx;
  background-color: #f5f5f5;
  border-radius: 16rpx;  /* 原来是 12rpx，改为与头像一致 */
}

/* 头像 */
/* 头像 - 改为圆角矩形，与主页统一 */
.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 16rpx;  /* 原来是 50% */
  background-color: #f5f5f5;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
}

/* ========= 功能列表卡片 ========= */
.function-card {
  background-color: #ffffff;
  border-radius: 32rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
  padding: 0 32rpx;
  margin-top: 40rpx;
  width: 100%;
  box-sizing: border-box;
}

/* 列表项 */
.list-item {
  display: flex;
  align-items: center;
  padding: 32rpx 0;
  width: 100%;
}

/* 左侧图标 */
.item-icon {
  width: 56rpx;
  height: 56rpx;
  margin-right: 32rpx;
  flex-shrink: 0;
}

/* 右侧文字区域 */
.item-content {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.item-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #000000;
  line-height: 1.4;
}

.item-subtitle {
  font-size: 24rpx;
  font-weight: 400;
  color: #888888;
  margin-top: 6rpx;
}

.item-phone {
  font-size: 32rpx;
  font-weight: 700;
  color: #000000;
}

/* 分隔线 */
.divider {
  height: 1rpx;
  background-color: #e5e5e5;
  margin: 0;
}

/* 加载状态 */
.loading-state {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(255, 255, 255, 0.9);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid #e0e0e0;
  border-top-color: #ff6b35;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  margin-top: 24rpx;
  font-size: 28rpx;
  color: #999;
}

/* 登录提示 */
.login-tip {
  font-size: 22rpx;
  color: #ff6b35;
  margin-top: 12rpx;
  display: inline-block;
  background-color: rgba(255, 107, 53, 0.1);
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  width: fit-content;
}