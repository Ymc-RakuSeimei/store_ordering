<!-- 全部订单组件 -->
<view class="all-container">
  <!-- 统计信息 -->
  <view class="statistics" wx:if="{{orderStatistics}}">
    <text class="stat-text">共计{{orderStatistics.total}}件，已完成{{orderStatistics.completed}}件</text>
  </view>

  <!-- 订单列表 -->
  <view class="order-list">
    <block wx:for="{{orderList}}" wx:key="id">
      <view class="order-item">
        <!-- 序号 -->
        <view class="order-number">{{index + 1}}</view>
        
        <!-- 商品图片 -->
        <image class="order-image" src="{{item.image || '/images/placeholder.png'}}" mode="aspectFill"></image>
        
        <!-- 商品信息 -->
        <view class="order-info">
          <view class="name-quantity">
            <text class="order-name">{{item.name}}</text>
            <text class="order-quantity">x{{item.quantity}}</text>
          </view>
          <text class="order-price">¥{{item.price}}</text>
        </view>
        
        <!-- 右侧状态按钮 -->
        <view class="order-status-area">
          <!-- 待取货状态 -->
          <view class="status-btn status-arrived" wx:if="{{item.status === '待取货'}}">
            待取货
          </view>
          
          <!-- 待到货状态 -->
          <view class="status-btn status-waiting" wx:if="{{item.status === '未到货'}}">
            未到货
          </view>
          
          <!-- 已完成状态 -->
          <view class="status-btn status-completed" wx:if="{{item.status === '已取货'}}">
            已完成
          </view>
        </view>
      </view>
    </block>
    
    <!-- 空状态 -->
    <view class="empty-state" wx:if="{{orderList.length === 0}}">
      <text>暂无订单</text>
    </view>
  </view>
</view>