.waiting-container {
  background-color: #ffffff;
  min-height: 100vh;
}

/* 身份核销码区域 */
.qrcode-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background-color: #ffffff;
  border: 1rpx solid #e5e5e5;
  border-radius: 12px;
  padding: 60rpx 0;
  margin: 24rpx 0 16rpx 0;
  gap: 24rpx;
}

.qrcode-image {
  width: 320rpx;
  height: 320rpx;
  background-color: #f5f5f5;
}

.qrcode-text {
  font-size: 32rpx;
  font-weight: 500;
  color: #666666;
}

/* 统计信息 */
.statistics {
  padding: 24rpx 0 32rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.stat-text {
  font-size: 26rpx;
  font-weight: 400;
  color: #999999;
}

/* 订单列表 */
.order-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  padding: 24rpx 0;
}

/* 单个订单卡片 */
.order-item {
  background-color: #ffffff;
  border: 1rpx solid #e5e5e5;
  border-radius: 12px;
  padding: 28rpx 24rpx;
  display: flex;
  align-items: center;
  gap: 28rpx;
  box-sizing: border-box;
  width: 100%;
}

/* 序号 */
.order-number {
  width: 56rpx;
  font-size: 36rpx;
  font-weight: 700;
  color: #000000;
  text-align: center;
  flex-shrink: 0;
}

/* 商品图片 */
.order-image {
  width: 140rpx;
  height: 140rpx;
  border-radius: 8px;
  background-color: #f5f5f5;
  flex-shrink: 0;
}

/* 商品信息区域 */
.order-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.order-name {
  font-size: 32rpx;
  font-weight: 700;
  color: #000000;
  line-height: 1.3;
}

.order-price {
  font-size: 28rpx;
  font-weight: 400;
  color: #000000;
}

/* 右侧状态区域 */
.order-status-area {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 12rpx;
  flex-shrink: 0;
  min-width: 120rpx;
}

/* 状态按钮通用样式 */
.status-btn {
  padding: 10rpx 24rpx;
  border-radius: 30rpx;
  font-size: 26rpx;
  font-weight: 700;
  text-align: center;
  min-width: 110rpx;
}

/* 已到货按钮 */
.status-arrived {
  background-color: #e8f5e9;
  color: #4caf50;
}

/* 待到货按钮 */
.status-waiting {
  background-color: #f5f5f5;
  color: #9e9e9e;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 120rpx 0;
  color: #999999;
  font-size: 28rpx;
}