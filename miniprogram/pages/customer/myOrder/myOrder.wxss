.container {
  background-color: #ffffff;
  min-height: 100vh;
  padding-bottom: 120rpx;
}

/* 顶部导航栏 */
.nav-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 100rpx;
  padding: 0 32rpx;
  background-color: #ffffff;
  position: relative;
}

.nav-back {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: flex-start;
}

.back-icon {
  font-size: 56rpx;
  font-weight: 400;
  color: #000000;
  line-height: 1;
}

.nav-title {
  position: absolute;
  left: 50%;
  transform: translateX(-50%);
  font-size: 40rpx;
  font-weight: 700;
  color: #000000;
  white-space: nowrap;
}

.nav-placeholder {
  width: 80rpx;
}

/* Tab栏 */
.tab-bar {
  display: flex;
  padding: 0 32rpx;
  border-bottom: 1rpx solid #f0f0f0;
  gap: 48rpx;
}

.tab-item {
  flex: 1;
  text-align: center;
  font-size: 32rpx;
  color: #999999;
  padding: 28rpx 0;
  position: relative;
}

.tab-item.active {
  color: #000000;
  font-weight: 700;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: -1rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 48rpx;
  height: 4rpx;
  background-color: #000000;
  border-radius: 2rpx;
}

/* 组件容器 */
.component-container {
  flex: 1;
  padding: 0 24rpx;
}

/* 底部导航栏 */
.tab-bar-bottom {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 100rpx;
  background-color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: space-around;
  border-top: 1rpx solid #f0f0f0;
  padding-bottom: env(safe-area-inset-bottom);
}

.tab-bottom-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  flex: 1;
  height: 100%;
}

.tab-icon {
  width: 48rpx;
  height: 48rpx;
  margin-bottom: 6rpx;
}

