<view class="page">
  <view class="hero-card">
    <view class="hero-copy">
      <text class="hero-title">数据中心</text>
      <text class="hero-subtitle">按年、月、周、日查看门店经营表现</text>
    </view>

    <view class="period-tabs">
      <block wx:for="{{periods}}" wx:key="key">
        <view
          class="period-tab {{activePeriod === item.key ? 'period-tab--active' : ''}}"
          data-period="{{item.key}}"
          bindtap="onPeriodChange"
        >
          {{item.label}}
        </view>
      </block>
    </view>

    <view class="period-caption">{{chartMeta.periodLabel}}</view>
  </view>

  <view class="summary-grid">
    <block wx:for="{{summaryCards}}" wx:key="key">
      <view class="summary-card">
        <view class="summary-dot" style="background: {{item.color}};"></view>
        <text class="summary-label">{{item.label}}</text>
        <text class="summary-value" style="color: {{item.color}};">{{item.value}}</text>
      </view>
    </block>
  </view>

  <view class="chart-card">
    <view class="chart-header">
      <view>
        <text class="chart-title">趋势分析</text>
        <text class="chart-subtitle">横轴：{{chartMeta.xAxisTitle}}，纵轴：金额</text>
      </view>
    </view>

    <view class="chart-legend">
      <block wx:for="{{chartLegend}}" wx:key="key">
        <view class="legend-item">
          <view class="legend-dot" style="background: {{item.color}};"></view>
          <text class="legend-text">{{item.label}}</text>
        </view>
      </block>
    </view>

    <view class="chart-body">
      <canvas
        id="trend-chart"
        type="2d"
        class="trend-canvas"
      ></canvas>
      <view wx:if="{{loading}}" class="chart-state">正在加载数据...</view>
    </view>
  </view>
</view>
