page {
  min-height: 100vh;
  background:
    radial-gradient(circle at top left, rgba(116, 175, 255, 0.2), transparent 34%),
    linear-gradient(180deg, #f2f7ff 0%, #f7fafc 100%);
  color: #0f172a;
}

.page {
  padding: 28rpx 24rpx 36rpx;
}

.hero-card,
.chart-card,
.summary-card {
  background: rgba(255, 255, 255, 0.92);
  border: 1rpx solid rgba(148, 163, 184, 0.12);
  box-shadow: 0 18rpx 42rpx rgba(30, 41, 59, 0.08);
  backdrop-filter: blur(12rpx);
}

.hero-card {
  border-radius: 32rpx;
  padding: 30rpx;
  margin-bottom: 22rpx;
}

.hero-copy {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.hero-title {
  font-size: 40rpx;
  font-weight: 700;
}

.hero-subtitle {
  font-size: 24rpx;
  color: #475569;
}

.period-tabs {
  display: flex;
  gap: 14rpx;
  margin-top: 24rpx;
}

.period-tab {
  min-width: 88rpx;
  height: 68rpx;
  line-height: 68rpx;
  text-align: center;
  border-radius: 999rpx;
  background: #eef2ff;
  color: #475569;
  font-size: 26rpx;
  font-weight: 600;
  transition: all 0.2s ease;
}

.period-tab--active {
  background: linear-gradient(135deg, #2563eb 0%, #14b8a6 100%);
  color: #ffffff;
  box-shadow: 0 14rpx 26rpx rgba(37, 99, 235, 0.24);
}

.period-caption {
  margin-top: 18rpx;
  font-size: 24rpx;
  color: #64748b;
}

.summary-grid {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.summary-card {
  position: relative;
  border-radius: 28rpx;
  padding: 24rpx 26rpx;
}

.summary-dot {
  width: 18rpx;
  height: 18rpx;
  border-radius: 50%;
  margin-bottom: 14rpx;
}

.summary-label {
  display: block;
  font-size: 25rpx;
  color: #64748b;
}

.summary-value {
  display: block;
  margin-top: 12rpx;
  font-size: 44rpx;
  line-height: 1.15;
  font-weight: 700;
  word-break: break-all;
}

.chart-card {
  border-radius: 32rpx;
  padding: 28rpx 24rpx 24rpx;
  margin-top: 22rpx;
}

.chart-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
}

.chart-title {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
}

.chart-subtitle {
  display: block;
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #64748b;
}

.chart-legend {
  display: flex;
  flex-wrap: wrap;
  gap: 18rpx 24rpx;
  margin-top: 24rpx;
}

.chart-body {
  position: relative;
  margin-top: 24rpx;
}

.legend-item {
  display: flex;
  align-items: center;
}

.legend-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  margin-right: 10rpx;
}

.legend-text {
  font-size: 24rpx;
  color: #475569;
}

.trend-canvas {
  width: 100%;
  height: 440rpx;
  border-radius: 24rpx;
  overflow: hidden;
}

.chart-state {
  position: absolute;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 24rpx;
  background: linear-gradient(180deg, rgba(239, 246, 255, 0.78) 0%, rgba(248, 250, 252, 0.9) 100%);
  color: #64748b;
  font-size: 26rpx;
}
