/* pages/merchant/index/index.wxss */
/* 整体页样式 */
page {
  background-color: #f2f2f5;           /* 全局背景灰白 */
  font-family: PingFang SC, Helvetica Neue, Arial, sans-serif; /* 字体 */
  color: #333;                         /* 默认文本颜色 */
}

/* 边距容器 */
.container {
  padding: 26rpx 26rpx 190rpx;       /* 页面内边距（底部预留tab栏高度） */
  box-sizing: border-box;              /* 盒模型 */
}

/* 头部区域（无容器，融入背景） */
.topbar {
  display: flex;                       /* 弹性布局 */
  align-items: center;                 /* 垂直居中 */
  justify-content: space-between;      /* 左右分布 */
  margin: 20rpx 0 50rpx;               /* 边距 */
  background: transparent;             /* 透明背景 */
  padding: 0;                          /* 去掉内边距 */
  box-shadow: none;                    /* 去掉阴影 */
  border-radius: 0;                    /* 去掉圆角 */
}

/* 头像 */
.avatar {
  width: 110rpx;                        /* 宽度 */
  height: 110rpx;                       /* 高度 */
  border-radius: 16rpx;                /* 圆角 */
  border: none;                        /* 去掉边框 */
}

/* 头部文字 */
.topbar-text {
  flex: 1;                             /* 占剩余空间 */
  margin-left: 16rpx;                   /* 左边距 */
  text-align: center;                
}

.title {
  display: block;                      /* 块级显示，独占一行实现上下排布 */
  font-size: 32rpx;                    /* ✅ 可在此调整【Hi,店长】文字大小 */
  font-weight: normal;                 /* 正常粗细 */
  color: #333;                         /* 颜色 */
}

.subtitle {
  display: block;                      /* 块级显示，独占一行实现上下排布 */
  font-size: 46rpx;                    /* ✅ 可在此调整【欢迎管理】文字大小（已从50rpx改小） */
  font-weight: bold;                   /* 加粗 */
  color: #333;                         /* 颜色 */
  margin-top: 10rpx;                   /* 上边距 */
}

/* 扫码按钮 */
.scan-btn {
  background: transparent;
  border-radius: 14rpx;
  padding: 0;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 新增：清除按钮默认点击态边框 */
.scan-btn::after {
  border: none;
}
/* 扫码按钮外层容器：控制按钮+文字垂直排列 */
.scan-btn-wrapper {
  display: flex;
  flex-direction: column; /* 按钮在上，文字在下 */
  align-items: center;     /* 水平居中 */
}
/* 扫码按钮文字 */
.scan-text {
  font-size: 24rpx;
  color: #333;
  margin-top: 8rpx;
}

/*二维码图标*/
.scan-btn .card-icon{
  height: 60rpx;
  width: 60rpx;
}

/* 卡片容器：2列 */
.card-container {
  display: flex;                       /* 弹性布局 */
  flex-wrap: wrap;                     /* 换行 */
  justify-content: space-between;      /* 左右对称 */
  padding-bottom: 40rpx;               /* 下内边距 */
}

/* 卡片 */
.card-item {
  width: 44%;                         /* 宽度，两列留缝 */
  background: #333333;                 /* 深灰背景 */
  border-radius: 24rpx;                /* 圆角 */
  padding: 24rpx 16rpx;                /* 内边距 */
  margin-bottom: 18rpx;                /* 下边距 */
  box-shadow: 0 8rpx 20rpx rgba(0,0,0,0.28); /* 投影 */
  display: flex;                       /* 弹性布局 */
  flex-direction: column;               /* 垂直 */
  align-items: center;                 /* 水平居中 */
  justify-content: center;             /* 垂直居中（解决内容偏上问题） */
  min-height: 360rpx;                  /* 最小高度 */
}

/* 卡片 icon */
.card-icon {
  width: 60rpx;                        /* 宽度 */
  height: 60rpx;                       /* 高度 */
  margin-bottom: 16rpx;                /* 下边距 */
  filter: brightness(1.3);             /* 亮度提升 */
}

/* 卡片标题 */
.card-title {
  font-size: 50rpx;                    /* 字体大小 */
  font-weight: bold;                   /* 加粗 */
  color: #ffffff;                      /* 白字 */
  margin-bottom: 10rpx;                 /* 下边距 */
}

/* 卡片副标题 */
.card-subtitle {
  font-size: 30rpx;                    /* 字体大小 */
  color: #f2f2f2;                      /* 浅白 */
  text-align: center;                  /* 居中 */
}

/* 系统通知长卡片 */
.long-card {
  background: #333333;                 /* 深灰背景 */
  border-radius: 24rpx;                /* 圆角 */
  margin-top: 0rpx;                   /* 上边距 */
  padding: 24rpx 20rpx;                /* 内边距 */
  box-shadow: 0 8rpx 22rpx rgba(0,0,0,0.28); /* 投影 */
  width: 94%;                        /* 全宽 */
  height: 80rpx;
}

.long-holder {
  display: flex;                       /* 弹性布局 */
  align-items: center;                 /* 垂直居中 */
  justify-content: center;             /* 水平居中 */
  width: 100%;
}

.long-icon {
  width: 50rpx;                        /* 宽度 */
  height: 50rpx;                       /* 高度 */
  margin-right: 14rpx;                 /* 右边距 */
  margin-top: 15rpx;
}

.long-text {
  flex: 1;                             /* 占剩余空间 */
}

.long-title {
  font-size: 50rpx;                    /* 字体大小 */
  font-weight: bold;                   /* 加粗 */
  color: #ffffff;                      /* 白字 */
}

.long-subtitle {
  font-size: 30rpx;                    /* 字体大小 */
  color: #f1f1f1;                      /* 浅白 */
  margin-top: 4rpx;                    /* 上边距 */
}

/* 底部提示线 */
.bottom-text {
  display: block;                      /* 块级 */
  text-align: center;                  /* 居中 */
  font-size: 26rpx;                    /* 字体大小 */
  color: #666666;                      /* 灰色 */
  margin-top: 20rpx;                   /* 上边距 */
}

/* 自定义底部tab栏（参考顾客端 tabBar 配色：#007AFF / #999999） */
.merchant-tabbar {
  position: fixed;
  left: 0;
  bottom: 0;
  width: 100%;
  height: 108rpx;
  background-color: #ffffff;
  border-top: 1rpx solid #f3f3f3;
  display: flex;
  z-index: 50;
}

.tabbar-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #999999; /* 未选中 */
}

.tabbar-icon {
  width: 46rpx;
  height: 46rpx;
  margin-bottom: 6rpx;
  opacity: 0.95;
}

.tabbar-text {
  font-size: 24rpx;
  line-height: 24rpx;
}

.tabbar-item--active {
  color: #007AFF; /* selectedColor */
}

.tabbar-item--active .tabbar-icon {
  opacity: 1;
}
