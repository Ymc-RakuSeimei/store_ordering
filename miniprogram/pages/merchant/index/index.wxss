/* pages/merchant/index/index.wxss */
/* 整体页样式 */
page {
  background-color: #F5F7FA;
  /* 全局背景灰白 */
  font-family: PingFang SC, Helvetica Neue, Arial, sans-serif;
  /* 字体 */
  color: #333;
  /* 默认文本颜色 */
}

/* 边距容器 */
.container {
  padding: 30rpx;
  /* 页面内边距（底部预留tab栏高度） */
  box-sizing: border-box;
  /* 盒模型 */
}

/* 头部区域（无容器，融入背景） */
.topbar {
  display: flex;
  /* 弹性布局 */
  align-items: center;
  /* 垂直居中 */
  justify-content: space-between;
  /* 左右分布 */
  margin: 20rpx 0 50rpx;
  /* 边距 */
  background: transparent;
  /* 透明背景 */
  padding: 0;
  /* 去掉内边距 */
  box-shadow: none;
  /* 去掉阴影 */
  border-radius: 0;
  /* 去掉圆角 */
}

/* 头像 */
.avatar {
  width: 110rpx;
  /* 宽度 */
  height: 110rpx;
  /* 高度 */
  border-radius: 16rpx;
  /* 圆角 */
  border: none;
  /* 去掉边框 */
}

/* 头部文字 */
.topbar-text {
  flex: 1;
  /* 占剩余空间 */
  margin-left: 16rpx;
  /* 左边距 */
  text-align: left;

}

.title {
  display: block;
  /* 块级显示，独占一行实现上下排布 */

  font-family: "Microsoft Yahei";
  font-size: 32rpx;
  /* ✅ 可在此调整【Hi,店长】
  文字大小 */
  font-weight: normal;
  /* 正常粗细 */
  color: #1D2129;
  /* 颜色 */
}

.subtitle {
  display: block;
  /* 块级显示，独占一行实现上下排布 */
  font-size: 46rpx;
  /* ✅ 可在此调整【欢迎管理】文字大小（已从50rpx改小） */
  font-weight: bold;
  /* 加粗 */
  color: #1D2129;
  /* 颜色 */
  margin-top: 10rpx;
  /* 上边距 */
  font-family: "Microsoft Yahei";
}

/* 扫码按钮 */
.scan-btn {
  background: transparent;
  border-radius: 14rpx;
  padding: 0;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 新增：清除按钮默认点击态边框 */
.scan-btn::after {
  border: none;
}

/* 扫码按钮外层容器：控制按钮+文字垂直排列 */
.scan-btn-wrapper {
  display: flex;
  flex-direction: column;
  /* 按钮在上，文字在下 */
  align-items: center;
  /* 水平居中 */
}

/* 扫码按钮文字 */
.scan-text {
  font-size: 24rpx;
  color: #333;
  margin-top: 0rpx;
}

/*二维码图标*/
.scan-btn .card-icon {
  margin-top: 5rpx;
  height: 100rpx;
  width: 70rpx;

}

/* 卡片容器：2列 */
.card-container {
  display: flex;
  /* 弹性布局 */
  flex-wrap: wrap;
  /* 换行 */
  justify-content: space-between;
  /* 左右对称 */
  padding-bottom: 10rpx;
  /* 下内边距 */
}

/* 卡片 */
.card-item {
  width: 42%;
  /* 宽度，两列留缝 */
  background: #ffffffcc;
  /* 深灰背景 */
  border: 1rpx solid #e5e6eb;
  border-radius: 24rpx;
  /* 圆角 */
  padding: 40rpx 20rpx;
  /* 内边距 */
  margin-bottom: 24rpx;
  /* 下边距 */
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.123);
  /* 投影 */
  display: flex;
  /* 弹性布局 */
  flex-direction: column;
  /* 垂直 */
  align-items: center;
  /* 水平居中 */
  justify-content: center;
  /* 垂直居中（解决内容偏上问题） */
  min-height: 320rpx;
  /* 最小高度 */
}

/* 卡片 icon */
.card-icon {
  width: 100rpx;
  /* 宽度 */
  height: 100rpx;
  /* 高度 */
  margin-bottom: 20rpx;
  /* 下边距 */

}

/* 卡片标题 */
.card-title {
  font-size: 40rpx;
  /* 字体大小 */
  font-weight: bold;
  /* 加粗 */
  color: #4E5969;
  /* 白字 */
  margin-bottom: 8rpx;
  /* 下边距 */
}

/* 卡片副标题 */
.card-subtitle {
  font-size: 25rpx;
  /* 字体大小 */
  color: #86909C;
  /* 浅白 */
  text-align: center;
  /* 居中 */
}

/* 系统通知长卡片 */
.long-card {
  background: #ffffffcc;
  border: 1rpx solid #e5e6eb;
  border-radius: 24rpx;
  /* 圆角 */
  padding: 30rpx;
  margin: 5rpx 1 0rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.123);
  /* 投影 */
  width: 90%;
  height: 90rpx;
  display: flex;
  justify-content: center;
  /* 左右居中 */
}

.long-holder {
  display: flex;
  /* 弹性布局 */
  align-items: center;
  /* 垂直居中 */
  justify-content: center;
  /* 水平居中 */
  width: 100%;
}

.long-icon {
  width: 90rpx;
  /* 宽度 */
  height: 90rpx;
  /* 高度 */
  margin-right: 30rpx;
  /* 右边距 */
  margin-top: 15rpx;
}

.long-text {
  flex: 1;
  /* 占剩余空间 */
}

.long-title {
  font-size: 40rpx;
  /* 字体大小 */
  font-weight: bold;
  /* 加粗 */
  color: #4E5969;
  /* 白字 */

}

.long-subtitle {
  font-size: 25rpx;
  /* 字体大小 */
  color: #86909C;
  /* 浅白 */
  margin-top: 4rpx;
  /* 上边距 */
  margin-left: 20rpx;
}

/* 底部提示线 */
.bottom-text {
  font-family: 'Times New Roman', Times, serif;
  display: block;
  /* 块级 */
  text-align: center;
  /* 居中 */
  font-size: 48rpx;
  /* 字体大小 */
  color: #1D2129;
  /* 灰色 */
  margin-top: 10rpx;
  /* 上边距 */
  font-style: italic;
  font-weight: 700;
}

/* 自定义底部tab栏（参考顾客端 tabBar 配色：#007AFF / #999999） */
.merchant-tabbar {
  position: fixed;
  left: 0;
  bottom: 0;
  width: 100%;
  height: 108rpx;
  background-color: #ffffff;
  border-top: 1rpx solid #f3f3f3;
  display: flex;
  z-index: 50;
}

.tabbar-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #999999;
  /* 未选中 */
}

.tabbar-icon {
  width: 46rpx;
  height: 46rpx;
  margin-bottom: 6rpx;
  opacity: 0.95;
}

.tabbar-text {
  font-size: 24rpx;
  line-height: 24rpx;
}

.tabbar-item--active {
  color: #007AFF;
  /* selectedColor */
}

.tabbar-item--active .tabbar-icon {
  opacity: 1;
}