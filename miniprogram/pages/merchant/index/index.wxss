/* pages/merchant/index/index.wxss */
page {
  background-color: #f5f7fa;
  font-family: PingFang SC, Helvetica Neue, Arial, sans-serif;
  color: #333;
}

.container {
  padding: 30rpx;
  box-sizing: border-box;
}

.topbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin: 20rpx 0 50rpx;
  background: transparent;
  padding: 0;
  box-shadow: none;
  border-radius: 0;
}

.avatar {
  width: 110rpx;
  height: 110rpx;
  border-radius: 16rpx;
  border: none;
}

.topbar-text {
  flex: 1;
  margin-left: 16rpx;
  text-align: left;
}

.title {
  display: block;
  font-family: 'Microsoft Yahei';
  font-size: 32rpx;
  font-weight: normal;
  color: #1d2129;
}

.subtitle {
  display: block;
  font-size: 46rpx;
  font-weight: bold;
  color: #1d2129;
  margin-top: 10rpx;
  font-family: 'Microsoft Yahei';
}

.scan-btn {
  background: transparent;
  border-radius: 14rpx;
  padding: 0;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
}

.scan-btn::after {
  border: none;
}

.scan-btn-wrapper {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.scan-text {
  font-size: 24rpx;
  color: #333;
  margin-top: 0;
}

.scan-btn .card-icon {
  margin-top: 5rpx;
  height: 100rpx;
  width: 70rpx;
}

.card-container {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
  padding-bottom: 10rpx;
  position: relative;
}

.card-item {
  width: 42%;
  background: #ffffffcc;
  border: 1rpx solid #e5e6eb;
  border-radius: 24rpx;
  padding: 40rpx 20rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.123);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 320rpx;
}

.ai-entry {
  position: absolute;
  left: 50%;
  top: 50%;
  width: 132rpx;
  height: 132rpx;
  transform: translate(-50%, -50%);
  border-radius: 50%;
  background: linear-gradient(135deg, #1677ff 0%, #2fb0ff 100%);
  box-shadow: 0 18rpx 36rpx rgba(23, 119, 255, 0.25);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  z-index: 3;
  border: 8rpx solid rgba(255, 255, 255, 0.96);
}

.ai-entry-icon {
  width: 56rpx;
  height: 56rpx;
}

.ai-entry-label {
  margin-top: 4rpx;
  color: #ffffff;
  font-size: 20rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
}

.card-icon {
  width: 100rpx;
  height: 100rpx;
  margin-bottom: 20rpx;
}

.card-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #4e5969;
  margin-bottom: 8rpx;
}

.card-subtitle {
  font-size: 25rpx;
  color: #86909c;
  text-align: center;
}

.long-card {
  background: #ffffffcc;
  border: 1rpx solid #e5e6eb;
  border-radius: 24rpx;
  padding: 30rpx;
  margin: 5rpx 1rpx 0;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.123);
  width: 90%;
  height: 90rpx;
  display: flex;
  justify-content: center;
}

.long-holder {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
}

.long-icon {
  width: 90rpx;
  height: 90rpx;
  margin-right: 30rpx;
  margin-top: 15rpx;
}

.long-text {
  flex: 1;
}

.long-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #4e5969;
}

.long-subtitle {
  font-size: 25rpx;
  color: #86909c;
  margin-top: 4rpx;
  margin-left: 20rpx;
}

.bottom-text {
  font-family: 'Times New Roman', Times, serif;
  display: block;
  text-align: center;
  font-size: 48rpx;
  color: #1d2129;
  margin-top: 10rpx;
  font-style: italic;
  font-weight: 700;
}

.merchant-tabbar {
  position: fixed;
  left: 0;
  bottom: 0;
  width: 100%;
  height: 108rpx;
  background-color: #ffffff;
  border-top: 1rpx solid #f3f3f3;
  display: flex;
  z-index: 50;
}

.tabbar-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #999999;
}

.tabbar-icon {
  width: 46rpx;
  height: 46rpx;
  margin-bottom: 6rpx;
  opacity: 0.95;
}

.tabbar-text {
  font-size: 24rpx;
  line-height: 24rpx;
}

.tabbar-item--active {
  color: #007aff;
}

.tabbar-item--active .tabbar-icon {
  opacity: 1;
}
