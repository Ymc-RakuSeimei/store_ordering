/* pages/merchant/index/index.wxss */
page {
  background-color: #f5f7fa;
  font-family: PingFang SC, Helvetica Neue, Arial, sans-serif;
  color: #333;
}

.container {
  padding: 30rpx;
  box-sizing: border-box;
}

.topbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin: 20rpx 0 50rpx;
  background: transparent;
  padding: 0;
  box-shadow: none;
  border-radius: 0;
}

.avatar {
  width: 110rpx;
  height: 110rpx;
  border-radius: 16rpx;
  border: none;
}

.topbar-text {
  flex: 1;
  margin-left: 16rpx;
  text-align: left;
}

.title {
  display: block;
  font-family: 'Microsoft Yahei';
  font-size: 32rpx;
  font-weight: normal;
  color: #1d2129;
}

.subtitle {
  display: block;
  font-size: 46rpx;
  font-weight: normal;
  color: #1d2129;
  margin-top: 10rpx;
  font-family: 'Franklin Gothic Medium', 'Arial Narrow', Arial, sans-serif;
}

.scan-btn {
  background: transparent;
  border-radius: 14rpx;
  padding: 0;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
}

.scan-btn::after {
  border: none;
}

.scan-btn-wrapper {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.scan-text {
  font-size: 24rpx;
  color: #333;
  margin-top: 0;
}

.scan-btn .card-icon {
  margin-top: 5rpx;
  height: 100rpx;
  width: 70rpx;
}

.card-container {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
  padding-bottom: 10rpx;
  position: relative;
}

.card-item {
  width: 42%;
  background: #ffffffcc;
  border: 1rpx solid #e5e6eb;
  border-radius: 24rpx;
  padding: 40rpx 20rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.123);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 320rpx;
}



.card-icon {
  width: 90rpx;
  height: 90rpx;
  margin-bottom: 20rpx;
}

.card-title {
  font-size: 35rpx;
  font-weight: bold;
  color: #4e5969;
  margin-bottom: 8rpx;
}

.card-subtitle {
  font-size: 25rpx;
  color: #86909c;
  text-align: center;
}

.card-row {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
  width: 100%;
  margin: 0 0 50rpx;
  padding-bottom: 10rpx;
}

.long-card-item {
  width: 42%;
  background: #ffffffcc;
  border: 1rpx solid #e5e6eb;
  border-radius: 24rpx;
  padding: 30rpx 20rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.123);
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: flex-start;
  min-height: 100rpx;
  position: relative;
}

.long-card-item .card-icon {
  margin-right: 20rpx;
  margin-left: 10rpx;
  margin-bottom: 0;
}

.long-card-item .card-title {
  text-align: left;
}

.long-card-item .card-subtitle {
  text-align: left;
  margin-left: 0;
}



.long-holder {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  position: relative;
}

.notification-badge {
  position: absolute;
  top: 20rpx;
  left: 120rpx;
  width: 20rpx;
  height: 20rpx;
  background-color: #ff4d4f;
  border-radius: 50%;
  border: 3rpx solid #ffffff;
  box-shadow: 0 2rpx 6rpx rgba(255, 77, 79, 0.4);
}

.long-icon {
  width: 60rpx;
  height: 60rpx;
  margin-right: 30rpx;
  margin-top: 15rpx;
}

.long-text {
  flex: 1;
}

.long-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #4e5969;
}

.long-subtitle {
  font-size: 25rpx;
  color: #86909c;
  margin-top: 4rpx;
  margin-left: 20rpx;
}



.merchant-tabbar {
  position: fixed;
  left: 0;
  bottom: 0;
  width: 100%;
  height: 108rpx;
  background-color: #ffffff;
  border-top: 1rpx solid #f3f3f3;
  display: flex;
  z-index: 50;
}

.tabbar-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #999999;
}

.tabbar-icon {
  width: 46rpx;
  height: 46rpx;
  margin-bottom: 6rpx;
  opacity: 0.95;
}

.tabbar-text {
  font-size: 24rpx;
  line-height: 24rpx;
}

.tabbar-item--active {
  color: #007aff;
}

.tabbar-item--active .tabbar-icon {
  opacity: 1;
}