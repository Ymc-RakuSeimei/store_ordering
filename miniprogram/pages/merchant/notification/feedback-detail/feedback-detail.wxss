@import "../../index/index.wxss";

page {
  background-color: #F5F7FA;
  font-family: PingFang SC, Helvetica Neue, Arial, sans-serif;
  color: #333;
}

.page {
  min-height: 100vh;
  padding: 20rpx 20rpx 40rpx;
  box-sizing: border-box;
}



.loading-state,
.empty-state {
  text-align: center;
  color: #999;
  margin-top: 120rpx;
  font-size: 28rpx;
}

.card {
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 5rpx 14rpx rgba(0, 0, 0, 0.08);
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.feedback-type {
  font-size: 26rpx;
  color: #ff3b30;
  font-weight: 600;
  padding: 6rpx 16rpx;
  background: #fff5f5;
  border-radius: 10rpx;
}

.feedback-status {
  font-size: 24rpx;
  padding: 6rpx 16rpx;
  border-radius: 10rpx;
  font-weight: 600;
}

.feedback-status.status-red {
  background: #fff5f5;
  color: #ff3b30;
}

.feedback-status.status-green {
  background: #f0fff4;
  color: #34c759;
}

.feedback-status.status-gray {
  background: #f5f5f5;
  color: #8e8e93;
}

.card-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #222;
  margin-bottom: 16rpx;
}

.info-row {
  display: flex;
  padding: 12rpx 0;
  border-bottom: 1rpx solid #f8f8f8;
}

.info-row:last-child {
  border-bottom: none;
}

.info-label {
  width: 160rpx;
  font-size: 26rpx;
  color: #888;
  flex-shrink: 0;
}

.info-value {
  flex: 1;
  font-size: 26rpx;
  color: #333;
  line-height: 1.5;
}

/* 图片列表 */
.image-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.feedback-image {
  width: 200rpx;
  height: 200rpx;
  border-radius: 12rpx;
  background: #f0f0f0;
}

/* 消息列表 */
.message-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.message-item {
  background: #f8f9fa;
  border-radius: 16rpx;
  padding: 20rpx;
}

.message-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.message-sender {
  font-size: 24rpx;
  font-weight: 600;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.message-sender.customer {
  background: #e3f2fd;
  color: #1976d2;
}

.message-sender.merchant {
  background: #e8f5e9;
  color: #388e3c;
}

.message-time {
  font-size: 22rpx;
  color: #999;
}

.message-content {
  font-size: 26rpx;
  color: #333;
  line-height: 1.6;
}

/* 回复框 */
.reply-card {
  margin-top: 20rpx;
}

.reply-textarea {
  width: 100%;
  min-height: 200rpx;
  background: #f8f9fa;
  border-radius: 12rpx;
  padding: 20rpx;
  font-size: 26rpx;
  line-height: 1.6;
  box-sizing: border-box;
  margin-bottom: 20rpx;
}

.reply-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: #007AFF;
  color: #fff;
  border-radius: 12rpx;
  font-size: 30rpx;
  font-weight: 600;
  border: none;
}

.reply-btn[disabled] {
  background: #c7c7cc;
}

.reply-btn::after {
  border: none;
}
