<view class="page">

  <view class="tabbar">
    <block wx:for="{{tabs}}" wx:key="id">
      <text class="tab {{activeTab===item.id?'active':''}}" data-tab="{{item.id}}" bindtap="switchTab">{{item.label}}</text>
    </block>
  </view>

  <view class="notice-list">
    <!-- 售后反馈 tab（单独显示） -->
    <block wx:if="{{activeTab === 'feedback'}}">
      <block wx:for="{{feedbackList}}" wx:key="id">
        <view class="notice-card type-feedback">
          <view class="notice-main" bindtap="onViewFeedbackDetail" data-item="{{item}}">
            <view class="notice-content">
              <text class="notice-title">{{item.type}}：{{item.goodsName || item.name || item.orderName}}</text>
              <text class="notice-sub">{{item.reason || item.content || item.createdAt}}</text>
            </view>
            <view class="feedback-status-mini status-{{item.status === '待处理' ? 'red' : 'green'}}">{{item.status}}</view>
          </view>
          <view class="delete-btn-wrapper">
            <view class="delete-btn" data-item="{{item}}" data-type="feedback" bindtap="onDelete">
              <text class="delete-icon">×</text>
            </view>
          </view>
        </view>
      </block>

      <view wx:if="{{!feedbackList || feedbackList.length === 0}}" class="empty-state">
        暂无售后反馈
      </view>
    </block>

    <!-- 全部 tab - 使用合并排序后的列表 -->
    <block wx:elif="{{activeTab === 'all'}}">
      <block wx:for="{{allNotifications}}" wx:key="item.id">
        <view class="notice-card {{item.isFeedback ? 'type-feedback' : 'type-' + item.type}}">
          <view class="notice-main" bindtap="{{item.isFeedback ? 'onViewFeedbackDetail' : ''}}" data-item="{{item}}">
            <!-- 售后反馈类型 -->
            <view wx:if="{{item.isFeedback}}" class="notice-content">
              <text class="notice-title">{{item.type}}：{{item.goodsName || item.name || item.orderName}}</text>
              <text class="notice-sub">{{item.reason || item.content || item.createdAt}}</text>
            </view>
            <!-- 库存提醒和滞留预警类型 -->
            <view wx:else class="notice-content">
              <text class="notice-title">{{item.text}}</text>
              <text class="notice-sub" wx:if="{{item.subText}}">{{item.subText}}</text>
            </view>
            <!-- 状态/按钮 -->
            <view wx:if="{{item.isFeedback}}" class="feedback-status-mini status-{{item.status === '待处理' ? 'red' : 'green'}}">{{item.status}}</view>
            <button wx:else class="notice-btn" data-item="{{item}}" bindtap="onRemind" catchtap="true">提醒</button>
          </view>
          <view class="delete-btn-wrapper">
            <view class="delete-btn" data-item="{{item}}" data-type="{{item.isFeedback ? 'feedback' : 'notification'}}" bindtap="onDelete">
              <text class="delete-icon">×</text>
            </view>
          </view>
        </view>
      </block>

      <view wx:if="{{!allNotifications || allNotifications.length === 0}}" class="empty-state">
        暂无通知
      </view>
    </block>

    <!-- 其他单独 tab（库存提醒/滞留预警） -->
    <block wx:else>
      <block wx:for="{{notifications}}" wx:key="item.id">
        <block wx:if="{{item.type === activeTab}}">
          <view class="notice-card type-{{item.type}}">
            <view class="notice-main">
              <view class="notice-content">
                <text class="notice-title">{{item.text}}</text>
                <text class="notice-sub" wx:if="{{item.subText}}">{{item.subText}}</text>
              </view>
              <button wx:if="{{item.showRemindAction}}" class="notice-btn" data-item="{{item}}" bindtap="onRemind" catchtap="true">提醒</button>
            </view>
            <view class="delete-btn-wrapper">
              <view class="delete-btn" data-item="{{item}}" data-type="notification" bindtap="onDelete">
                <text class="delete-icon">×</text>
              </view>
            </view>
          </view>
        </block>
      </block>

      <view wx:if="{{!notifications || notifications.length === 0}}" class="empty-state">
        暂无通知
      </view>
    </block>
  </view>
</view>
