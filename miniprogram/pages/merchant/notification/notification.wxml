<view class="page">
  <view class="header">
    <text class="back" bindtap="onBack">← 返回</text>
    <text class="title">消息中心</text>
    <view class="placeholder"></view>
  </view>

  <view class="tabbar">
    <block wx:for="{{tabs}}" wx:key="id">
      <text class="tab {{activeTab===item.id?'active':''}}" data-tab="{{item.id}}" bindtap="switchTab">{{item.label}}</text>
    </block>
  </view>

  <view class="notice-list">
    <block wx:for="{{notifications}}" wx:key="id">
      <block wx:if="{{activeTab==='all' || item.type===activeTab}}">
        <view class="notice-card type-{{item.type}}">
          <view class="notice-content">
            <text class="notice-title">{{item.text}}</text>
            <text class="notice-sub" wx:if="{{item.subText}}">{{item.subText}}</text>
          </view>
          <button wx:if="{{item.showRemindAction}}" class="notice-btn" data-item="{{item}}" bindtap="onRemind">提醒</button>
        </view>
      </block>
    </block>

    <view wx:if="{{!notifications || notifications.length===0}}" class="empty-state">
      暂无通知
    </view>
  </view>
</view>