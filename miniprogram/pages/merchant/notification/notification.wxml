<view class="page">
  <view class="header">
    <text class="back" bindtap="onBack">← 返回</text>
    <text class="title">系统通知</text>
    <view class="placeholder"></view>
  </view>

  <view class="tabbar">
    <block wx:for="{{tabs}}" wx:key="id">
      <text class="tab {{activeTab===item.id?'active':''}}" data-tab="{{item.id}}" bindtap="switchTab">{{item.label}}</text>
    </block>
    <text class="delete-all" bindtap="onDeleteAll">一键删除</text>
  </view>

  <view class="notice-list">
    <block wx:for="{{notifications}}" wx:key="id">
      <block wx:if="{{activeTab==='all' || item.type===activeTab}}">
        <view class="notice-card">
                    <text class="notice-text">{{index+1}}. {{item.text}}</text>
          <button wx:if="{{item.showRemindAction}}" class="notice-btn" data-id="{{item.id}}" bindtap="onRemind">提醒</button>
        </view>
      </block>
    </block>

    <view wx:if="{{!notifications || notifications.length===0}}" class="empty-state">
      暂无通知
    </view>
  </view>
</view>