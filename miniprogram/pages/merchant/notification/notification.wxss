page {
  background: #f6f6f8;
  font-family: PingFang SC, Helvetica Neue, Arial, sans-serif;
  color: #333;
}
.page {
  padding: 20rpx;
  min-height: 100vh;
}
.header {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}
.back {
  color: #007AFF;
  font-size: 30rpx;
}
.title {
  flex: 1;
  text-align: center;
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}
.tabbar {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 18rpx;
  padding: 8rpx;
  border: 1rpx solid #ddd;
  margin-bottom: 14rpx;
}
.tab {
  flex: 1;
  padding: 8rpx 0;
  text-align: center;
  font-size: 24rpx;
  color: #666;
  border-radius: 14rpx;
  margin-right: 8rpx;
}
.tab.active {
  background: #333;
  color: #fff;
}
.delete-all {
  color: #ff3b30;
  font-weight: bold;
  font-size: 22rpx;
}
.notice-list {
  padding-bottom: 40rpx;
}
.notice-card {
  background: #fff;
  border-radius: 14rpx;
  padding: 14rpx 16rpx;
  margin-bottom: 10rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  box-shadow: 0 6rpx 12rpx rgba(0, 0, 0, 0.05);
}
.notice-text {
  font-size: 24rpx;
  color: #333;
  flex: 1;
}
.notice-btn {
  background: #00c853;
  color: #fff;
  border: none;
  border-radius: 12rpx;
  padding: 6rpx 12rpx;
  font-size: 22rpx;
}
.empty-state {
  text-align: center;
  color: #999;
  font-size: 24rpx;
  margin-top: 80rpx;
}
