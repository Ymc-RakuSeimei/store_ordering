page {
  background-color: #F5F7FA;
  font-family: PingFang SC, Helvetica Neue, Arial, sans-serif;
  color: #333;
}
.page {
  padding: 20rpx;
  min-height: 100vh;
}


.tabbar {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 18rpx;
  padding: 8rpx;
  border: 1rpx solid #ddd;
  margin-bottom: 14rpx;
}
.tab {
  flex: 1;
  padding: 10rpx 0;
  text-align: center;
  font-size: 26rpx;
  color: #666;
  border-radius: 14rpx;
  margin-right: 8rpx;
}
.tab.active {
  background: #333;
  color: #fff;
}
.notice-list {
  padding-bottom: 40rpx;
}
.notice-card {
  background: #fff;
  border-radius: 18rpx;
  padding: 24rpx 20rpx;
  margin-bottom: 16rpx;
  min-height: 120rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  box-shadow: 0 6rpx 12rpx rgba(0, 0, 0, 0.05);
  border-left: 8rpx solid #ddd;
}
.notice-card.type-inventory {
  border-left-color: #ff9500;
}
.notice-card.type-retention {
  border-left-color: #ff3b30;
}
.notice-card.type-feedback {
  border-left-color: #ff3b30;
}
.notice-content {
  flex: 1;
  display: flex;
  flex-direction: column;
}
.notice-title {
  font-size: 28rpx;
  color: #333;
  font-weight: 600;
  margin-bottom: 6rpx;
}
.notice-sub {
  font-size: 24rpx;
  color: #999;
}
.notice-btn {
  background: #007AFF;
  color: #fff;
  border: none;
  border-radius: 14rpx;
  padding: 12rpx 20rpx;
  font-size: 24rpx;
  font-weight: 600;
  flex-shrink: 0;
}
.notice-btn::after {
  border: none;
}
.empty-state {
  text-align: center;
  color: #999;
  font-size: 26rpx;
  margin-top: 100rpx;
}

/* 售后反馈小状态标签 */
.feedback-status-mini {
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  font-weight: 600;
  flex-shrink: 0;
}

.feedback-status-mini.status-red {
  background: #fff5f5;
  color: #ff3b30;
}

.feedback-status-mini.status-green {
  background: #f0fff4;
  color: #34c759;
}
