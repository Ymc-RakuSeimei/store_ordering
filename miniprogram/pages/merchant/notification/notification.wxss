page {
  background-color: #F5F7FA;
  font-family: PingFang SC, Helvetica Neue, Arial, sans-serif;
  color: #333;
}
.page {
  padding: 20rpx;
  height: 100vh;
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
}


.tabbar {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 18rpx;
  padding: 8rpx;
  border: 1rpx solid #ddd;
  margin-bottom: 14rpx;
}
.tab {
  flex: 1;
  height: 60rpx;
  line-height: 60rpx;
  text-align: center;
  font-size: 26rpx;
  color: #666;
  border-radius: 14rpx;
  margin-right: 8rpx;
}
.tab.active {
  background: #333;
  color: #fff;
}

/* 消息列表滚动区域 */
.notice-scroll {
  flex: 1;
  height: 0;
}

.notice-list {
  padding-bottom: 20rpx;
}

.notice-card {
  background: #fff;
  border-radius: 18rpx;
  padding: 24rpx 20rpx;
  margin-bottom: 16rpx;
  min-height: 120rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  box-shadow: 0 6rpx 12rpx rgba(0, 0, 0, 0.05);
  border-left: 8rpx solid #ddd;
  position: relative;
}

.notice-card.type-inventory {
  border-left-color: #ff9500;
}
.notice-card.type-retention {
  border-left-color: #ff3b30;
}
.notice-card.type-feedback {
  border-left-color: #ff3b30;
}

.notice-main {
  flex: 1;
  display: flex;
  justify-content: space-between;
  align-items: center;
  min-width: 0;
}

.notice-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  min-width: 0;
  margin-right: 16rpx;
}
.notice-title {
  font-size: 28rpx;
  color: #333;
  font-weight: 600;
  margin-bottom: 6rpx;
  line-height: 1.3;
}
.notice-sub {
  font-size: 24rpx;
  color: #999;
  line-height: 1.3;
}
.notice-btn {
  background: #007AFF;
  color: #fff;
  border: none;
  border-radius: 14rpx;
  padding: 12rpx 20rpx;
  font-size: 24rpx;
  font-weight: 600;
  flex-shrink: 0;
  margin-left: 12rpx;
}
.notice-btn::after {
  border: none;
}

/* 删除按钮 */
.delete-btn-wrapper {
  flex-shrink: 0;
  margin-left: 12rpx;
}

.delete-btn {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: #f5f5f5;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: background 0.2s;
}

.delete-btn:active {
  background: #ff3b30;
}

.delete-btn:active .delete-icon {
  color: #fff;
}

.delete-icon {
  font-size: 40rpx;
  line-height: 1;
  color: #999;
  font-weight: 300;
}

.empty-state {
  text-align: center;
  color: #999;
  font-size: 26rpx;
  margin-top: 100rpx;
}

/* 售后反馈小状态标签 */
.feedback-status-mini {
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  font-weight: 600;
  flex-shrink: 0;
  margin-left: 12rpx;
}

.feedback-status-mini.status-red {
  background: #fff5f5;
  color: #ff3b30;
}

.feedback-status-mini.status-green {
  background: #f0fff4;
  color: #34c759;
}

/* 一键删除按钮 */
.delete-all-btn {
  width: 100%;
  height: 100rpx;
  background: #ff3b30;
  border-radius: 30rpx;
  margin-top: 20rpx;
  margin-bottom: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  flex-shrink: 0;
}

.delete-all-btn text {
  font-size: 34rpx;
  font-weight: 600;
  color: #ffffff;
}

.delete-all-btn:active {
  opacity: 0.8;
  transform: scale(0.98);
}
