<view class="page">
  <view class="header">
    <text class="back" bindtap="onBack">返回</text>
    <text class="title">顾客订单详情</text>
    <text class="placeholder"></text>
  </view>

  <view class="customer-card" wx:if="{{order}}">
    <view class="customer-top">
      <text class="customer-name">{{order.customerName}}</text>
      <text class="customer-count">共{{order.orderCount}}笔</text>
    </view>
    <text class="customer-meta" wx:if="{{order.phone}}">联系电话：{{order.phone}}</text>
    <text class="customer-meta" wx:if="{{order.pickupCode}}">取货码：{{order.pickupCode}}</text>
    <text class="customer-meta" wx:if="{{order.latestOrderTimeText}}">最近下单：{{order.latestOrderTimeText}}</text>
    <text class="customer-meta">累计商品：{{order.totalQty}}件</text>
    <text class="customer-meta">累计金额：¥{{order.totalPrice}}</text>
  </view>

  <block wx:if="{{order && order.orders && order.orders.length}}">
    <block wx:for="{{order.orders}}" wx:key="orderId" wx:for-item="orderItem">
      <view class="order-card">
        <view class="order-card-header">
          <text class="order-no">{{orderItem.orderNo}}</text>
          <text class="order-time">{{orderItem.orderTimeText}}</text>
        </view>
        <text class="order-meta" wx:if="{{orderItem.pickupCode}}">取货码：{{orderItem.pickupCode}}</text>
        <text class="order-meta">订单金额：¥{{orderItem.totalPrice}}</text>
        <text class="order-meta" wx:if="{{orderItem.remark}}">备注：{{orderItem.remark}}</text>

        <block wx:for="{{orderItem.goods}}" wx:key="id" wx:for-item="goodsItem">
          <view class="goods-row">
            <image class="goods-img" src="{{goodsItem.img}}" mode="aspectFill" />
            <view class="goods-info">
              <text class="goods-name">{{goodsItem.name}}</text>
              <text class="goods-spec" wx:if="{{goodsItem.spec}}">规格：{{goodsItem.spec}}</text>
              <text class="goods-meta">数量：{{goodsItem.qty}}件</text>
              <text class="goods-meta">单价：¥{{goodsItem.price}}</text>
            </view>
            <view class="goods-right">
              <text class="goods-subtotal">¥{{goodsItem.subtotal}}</text>
              <text class="goods-status {{goodsItem.statusClass}}">{{goodsItem.pickupStatus}}</text>
            </view>
          </view>
        </block>
      </view>
    </block>
  </block>

  <view wx:elif="{{!loading}}" class="empty-state">暂无顾客订单详情</view>
</view>
