<view class="page">
  <view class="header">
    <text class="back" bindtap="onBack">← 返回</text>
    <text class="title">订单详情</text>
    <text class="placeholder"></text>
  </view>

  <view class="order-card" wx:if="{{order}}">
    <view class="order-card-header">
      <text class="customer-title">顾客 {{order.customerName}} 的订单</text>
      <text class="order-status" wx:if="{{order.status}}">{{order.status}}</text>
    </view>
    <text class="phone" wx:if="{{order.phone}}">联系电话：{{order.phone}}</text>
    <text class="order-no" wx:if="{{order.orderNo}}">订单号：{{order.orderNo}}</text>
    <text class="order-price" wx:if="{{order.totalPrice}}">订单金额：¥{{order.totalPrice}}</text>
    <text class="pickup-code" wx:if="{{order.pickupCode}}">取货码：{{order.pickupCode}}</text>
    <text class="remark" wx:if="{{order.remark}}">备注：{{order.remark}}</text>
  </view>

  <view class="section" wx:if="{{order && order.pendingPickup && order.pendingPickup.length}}">
    <text class="section-title pickable">可取货</text>
    <block wx:for="{{order.pendingPickup}}" wx:key="id">
      <view class="line">
        <text class="item-name">{{index+1}}.{{item.name}}</text>
        <text class="item-qty">×{{item.qty}}</text>
        <button class="deal-btn" bindtap="pickSingleItem" data-row="{{item}}">取</button>
      </view>
    </block>
  </view>

  <view class="section" wx:if="{{order && order.pendingArrival && order.pendingArrival.length}}">
    <text class="section-title pending">待到货</text>
    <block wx:for="{{order.pendingArrival}}" wx:key="id">
      <view class="line">
        <text class="item-name">{{index+1}}.{{item.name}}</text>
        <text class="item-qty">×{{item.qty}}</text>
      </view>
    </block>
  </view>

  <button class="primary-btn" wx:if="{{order && order.pendingPickup && order.pendingPickup.length}}" bindtap="pickAll">一键取货</button>
</view>