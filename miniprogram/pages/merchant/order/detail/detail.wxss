page{background:#f6f6f8;font-family:PingFang SC,Helvetica Neue,Arial,sans-serif;color:#333}.page{padding:20rpx;min-height:100vh}.header{display:flex;align-items:center;justify-content:space-between;margin-bottom:14rpx}.back{color:#007AFF;font-size:30rpx}.title{flex:1;text-align:center;font-size:30rpx;font-weight:600}.placeholder{width:30rpx}.order-info{background:#fff;border-radius:16rpx;padding:14rpx 16rpx;box-shadow:0 6rpx 12rpx rgba(0,0,0,.08);margin-bottom:12rpx}.customer{font-size:26rpx;font-weight:600;color:#222}.phone{font-size:20rpx;color:#666;margin-top:6rpx}.section{background:#fff;border-radius:16rpx;padding:14rpx 16rpx;box-shadow:0 6rpx 12rpx rgba(0,0,0,.08);margin-bottom:10rpx}.section-title{font-size:24rpx;font-weight:700;color:#24b24d;margin-bottom:8rpx}.line{display:flex;justify-content:space-between;align-items:center;margin-bottom:10rpx}.deal-btn{background:#24b24d;color:#fff;border:none;border-radius:10rpx;padding:4rpx 14rpx;font-size:20rpx}.primary-btn{width:100%;background:#24b24d;color:#fff;border:none;border-radius:14rpx;height:56rpx;font-size:28rpx;font-weight:700;margin-top:12rpx}