<view class="page">
  <!-- 加载状态 -->
  <view wx:if="{{loading || markLoading || reminderLoading}}" class="loading-state">
    <view class="loading-spinner"></view>
    <view class="loading-text">{{markLoading ? '处理中...' : (reminderLoading ? '发送中...' : '加载中...')}}</view>
  </view>
  <view class="header">
    <text class="title">订单处理</text>
    <button class="scan-btn" bindtap="onScanPickup">扫码取货</button>
  </view>

  <view class="pickup-code-entry">
    <input
      class="pickup-code-input"
      type="number"
      placeholder="请输入 6 位取货码"
      bindinput="onPickupCodeInput"
      value="{{pickupCode}}"
      maxlength="6"
    />
    <button class="verify-btn" bindtap="onVerifyPickupCode" disabled="{{!isPickupCodeValid || loading}}">
      {{loading ? '验证中...' : '核销'}}
    </button>
  </view>

  <view class="tabbar">
    <block wx:for="{{tabs}}" wx:key="id">
      <view class="tab {{activeTab === item.id ? 'active' : ''}}" bindtap="switchTab" data-tab="{{item.id}}">
        <text class="tab-label">{{item.label}}</text>
      </view>
    </block>
  </view>

  <view class="order-list">
    <block wx:if="{{activeTab === 'customer'}}">
      <block wx:for="{{orderData.customer}}" wx:key="_id">
        <view class="customer-order-card" bindtap="openCustomerDetail" data-customer-key="{{item.customerKey}}">
          <view class="customer-order-header">
            <text class="customer-name">{{item.customerName}}的订单</text>
            <text class="order-no">{{item.orderNo}}</text>
          </view>
          <view class="customer-order-info">
            <text class="info-item">共 {{item.totalQty}} 件，待取 {{item.pickableQty}} 件，未到货 {{item.waitingQty}} 件</text>
            <text class="arrival-status arrival-{{item.arrivalStatus}}">
              {{item.arrivalStatus === 'all' ? '全部到货' : '部分到货'}}
            </text>
          </view>
          <text class="customer-extra" wx:if="{{item.latestOrderTimeText}}">最近下单：{{item.latestOrderTimeText}}</text>
          <text class="customer-extra" wx:if="{{item.phone}}">联系电话：{{item.phone}}</text>
          <text class="customer-extra" wx:if="{{item.pickupCode}}">取货码：{{item.pickupCode}}</text>
          <text class="customer-extra" wx:if="{{item.goodsPreviewText}}">商品：{{item.goodsPreviewText}}</text>
        </view>
      </block>
    </block>

    <block wx:elif="{{activeTab === 'arrival' || activeTab === 'pickup'}}">
      <block wx:for="{{orderData[activeTab]}}" wx:key="id">
        <view
          class="goods-card goods-card--{{activeTab}}"
          bindtap="openGoodsDetail"
          data-goods-id="{{item.goodsId || item.id}}"
          data-doc-id="{{item.docId || (activeTab === 'arrival' ? item.id : '')}}"
        >
          <image class="goods-img" src="{{item.img}}" mode="aspectFill" />

          <view class="goods-info">
            <text class="name">{{item.name}}</text>
            <text class="spec" wx:if="{{item.spec}}">规格：{{item.spec}}</text>
            <text class="summary" wx:if="{{activeTab === 'arrival'}}">未到货：{{item.waitingQty}} 件</text>
            <text class="summary" wx:if="{{activeTab === 'pickup'}}">待取货：{{item.pickupQty}} 件</text>
            <text class="summary" wx:if="{{item.arrivalDate}}">
              {{activeTab === 'arrival' ? '预计到货' : '到货时间'}}：{{item.arrivalDate}}
            </text>
          </view>

          <view class="goods-action-area">
            <button
              wx:if="{{activeTab === 'arrival'}}"
              class="arrive-btn"
              catchtap="onMarkArrived"
              data-id="{{item.id}}"
              data-name="{{item.name}}"
            >
              到货
            </button>

            <view wx:elif="{{activeTab === 'pickup'}}" class="pickup-badge">
              待取货
            </view>
          </view>
        </view>
      </block>
    </block>

    <block wx:else>
      <block wx:for="{{orderData.feedback}}" wx:key="id">
        <view class="order-card">
          <text class="order-title">{{item.name || item.orderName}}</text>
          <text class="order-meta" wx:if="{{item.left}}">
            <text class="meta-label">处理状态：</text>
            <text class="status-{{item.left === '待处理' ? 'red' : 'green'}}">{{item.left}}</text>
          </text>
          <text class="order-meta" wx:if="{{item.spec}}">
            <text class="meta-label">反馈内容：</text>
            {{item.spec}}
          </text>
        </view>
      </block>
    </block>

    <view wx:if="{{!orderData[activeTab] || orderData[activeTab].length === 0}}" class="empty-state">
      暂无订单
    </view>
  </view>

  <button wx:if="{{activeTab === 'pickup'}}" class="action-btn" bindtap="oneKeyReminder">一键提醒</button>
</view>
