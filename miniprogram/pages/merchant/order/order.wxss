@import "../index/index.wxss";

page {
  background-color: #F5F7FA;
  font-family: PingFang SC, Helvetica Neue, Arial, sans-serif;
  color: #333;
}

.page {
  min-height: 100vh;
  padding: 20rpx 20rpx 190rpx;
  box-sizing: border-box;
}

.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.title {
  flex: 1;
  text-align: center;
  font-size: 34rpx;
  font-weight: 700;
  color: #222;
}

.scan-btn,
.verify-btn,
.arrive-btn,
.action-btn {
  display: flex;
  align-items: center;
  justify-content: center;
}

.scan-btn {
  min-width: 126rpx;
  font-size: 22rpx;
  color: #333;
  background: #fff;
  border: 1rpx solid #b9b9b9;
  border-radius: 12rpx;
  padding: 8rpx 18rpx;
}

.scan-btn::after,
.verify-btn::after,
.arrive-btn::after,
.action-btn::after {
  border: none;
}

.pickup-code-entry {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 18rpx;
  padding: 16rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}

.pickup-code-input {
  flex: 1;
  height: 60rpx;
  font-size: 28rpx;
  padding: 0 16rpx;
  border: 1rpx solid #ddd;
  border-radius: 8rpx;
  margin-right: 12rpx;
  background: #f9f9f9;
}

.verify-btn {
  width: 140rpx;
  height: 60rpx;
  line-height: 60rpx;
  background: #33c266;
  color: #fff;
  border: none;
  border-radius: 8rpx;
  font-size: 26rpx;
  text-align: center;
}

.verify-btn:disabled {
  background: #ccc;
  color: #fff;
}

.tab-bar {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 24rpx;
  padding: 20rpx 0;
  width: 100%;
  box-sizing: border-box;
  background-color: transparent;
  margin-bottom: 14rpx;
}

.tab-item {
  padding: 12rpx 28rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
  font-weight: 500;
  color: #333333;
  background-color: #f5f5f5;
  transition: all 0.3s ease;
}

.tab-item.active {
  color: #ffffff;
  background-color: #000000;
  transform: translateY(-2rpx);
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.15);
}

.tab-label {
  font-size: 28rpx;
  font-weight: 500;
  color: inherit;
  line-height: 1;
  white-space: nowrap;
}

.order-list {
  min-height: 500rpx;
}

/* 商品卡片直接复用商品管理页的视觉骨架 */
.goods-card {
  display: flex;
  align-items: center;
  background: #ffffff;
  border-radius: 20rpx;
  box-shadow: 0 5rpx 14rpx rgba(0, 0, 0, 0.08);
  overflow: hidden;
  margin-bottom: 14rpx;
  min-height: 176rpx;
  padding: 10rpx 14rpx 10rpx 10rpx;
  box-sizing: border-box;
}

.goods-card:active {
  opacity: 0.94;
}

.goods-img {
  width: 146rpx;
  height: 146rpx;
  flex-shrink: 0;
  border-radius: 18rpx;
  display: block;
  background: #f0f0f0;
}

.goods-info {
  flex: 1;
  margin-left: 16rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
  min-width: 0;
}

.name {
  font-size: 29rpx;
  font-weight: 600;
  color: #020202;
  margin-bottom: 2rpx;
  line-height: 1.14;
}

.spec,
.summary {
  font-size: 23rpx;
  color: #666;
  margin-bottom: 2rpx;
  line-height: 1.12;
}

.summary {
  color: #111;
  font-weight: 500;
}

.goods-info text:last-child {
  margin-bottom: 0;
}

.goods-action-area {
  width: 124rpx;
  min-height: 146rpx;
  margin-left: 10rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.arrive-btn {
  width: 110rpx;
  height: 74rpx;
  line-height: 74rpx;
  border-radius: 14rpx;
  background: #33c266;
  color: #fff;
  font-size: 28rpx;
  font-weight: 600;
  text-align: center;
  border: none;
  padding: 0;
}

.pickup-badge {
  width: 110rpx;
  height: 74rpx;
  line-height: 74rpx;
  border-radius: 14rpx;
  background: #e9f7ee;
  color: #2c9b54;
  font-size: 25rpx;
  font-weight: 600;
  text-align: center;
  box-sizing: border-box;
}

.order-card {
  background: #fff;
  border-radius: 18rpx;
  padding: 24rpx;
  margin-bottom: 18rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
}

.order-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #222;
}

.order-meta {
  display: block;
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #777;
}

.meta-label {
  font-weight: 600;
}

.status-red {
  color: #ff3b30;
  font-weight: 700;
}

.status-green {
  color: #34c759;
  font-weight: 700;
}

.customer-order-card {
  background: #fff;
  border-radius: 18rpx;
  padding: 24rpx;
  margin-bottom: 18rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
}

.customer-order-card:active {
  opacity: 0.92;
}

.customer-order-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.customer-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #222;
}

.order-no {
  font-size: 22rpx;
  color: #999;
}

.customer-order-info {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 12rpx;
}

.info-item {
  flex: 1;
  min-width: 0;
  font-size: 26rpx;
  color: #666;
  line-height: 1.45;
}

.customer-extra {
  display: block;
  margin-top: 10rpx;
  font-size: 23rpx;
  color: #7a7a7a;
  line-height: 1.4;
}

.arrival-status {
  flex-shrink: 0;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
  font-weight: 500;
}

.arrival-partial {
  background: #fff7e6;
  color: #faad14;
}

.arrival-all {
  background: #f6ffed;
  color: #52c41a;
}

.empty-state {
  text-align: center;
  color: #999;
  margin-top: 80rpx;
  font-size: 24rpx;
}

.action-btn {
  width: 100%;
  height: 84rpx;
  line-height: 84rpx;
  margin: 20rpx auto 0;
  border-radius: 30rpx;
  background: #33c266;
  color: #fff;
  font-size: 30rpx;
  font-weight: 600;
  text-align: center;
  border: none;
  transition: all 0.3s ease;
}

.action-btn:active {
  background: #28a745;
  transform: scale(0.98);
}
