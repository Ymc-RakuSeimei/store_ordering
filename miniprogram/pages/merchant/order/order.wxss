page {
  background: #f6f6f8;
  font-family: PingFang SC, Helvetica Neue, Arial, sans-serif;
  color: #333;
}
.page {
  padding: 20rpx;
  min-height: 100vh;
}
.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}
.back {
  color: #333;
  font-size: 30rpx;
}
.title {
  flex: 1;
  text-align: center;
  font-size: 32rpx;
  font-weight: bold;
  color: #222;
}
.scan-btn {
  font-size: 22rpx;
  color: #000;
  background: none;
  border: 1rpx solid #333;
  border-radius: 12rpx;
  padding: 6rpx 10rpx;
}
.tabbar {
  display: flex;
  justify-content: space-between;
  background: #fff;
  border: 1rpx solid #ddd;
  border-radius: 30rpx;
  padding: 6rpx;
  margin-bottom: 16rpx;
}
.tab {
  flex: 1;
  text-align: center;
  background: #f5f5f5;
  color: #666;
  font-size: 22rpx;
  line-height: 40rpx;
  border-radius: 24rpx;
  margin: 0 4rpx;
}
.tab.active {
  background: #333;
  color: #fff;
}
.order-list {
  min-height: 360rpx;
}
.order-card {
  background: #fff;
  border-radius: 18rpx;
  padding: 14rpx 16rpx;
  margin-bottom: 12rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.order-content {
  flex: 1;
}
.order-title {
  font-size: 24rpx;
  font-weight: 600;
  color: #222;
}
.order-qty {
  font-size: 22rpx;
  color: #24b24d;
  font-weight: bold;
  margin-left: 8rpx;
}
.order-meta {
  font-size: 20rpx;
  color: #777;
  margin-top: 6rpx;
}
.order-action {
  background: #33c266;
  color: #fff;
  border-radius: 20rpx;
  padding: 8rpx 14rpx;
  font-size: 20rpx;
}
.empty-state {
  text-align: center;
  color: #999;
  margin-top: 80rpx;
  font-size: 24rpx;
}
.action-btn {
  width: 60%;
  height: 58rpx;
  line-height: 58rpx;
  margin: 16rpx auto 0;
  border-radius: 16rpx;
  background: #33c266;
  color: #fff;
  font-size: 26rpx;
  display: block;
  text-align: center;
  border: none;
}

.empty-state {
  text-align: center;
  color: #999;
  margin-top: 60rpx;
  font-size: 24rpx;
}

.action-btn {
  width: 60%;
  height: 58rpx;
  line-height: 58rpx;
  margin: 16rpx auto 0;
