<view class="page">
  <!-- 加载状态 -->
  <view wx:if="{{loading}}" class="loading-state">
    <view class="loading-spinner"></view>
    <view class="loading-text">创建中...</view>
  </view>
  <view class="header">
    <text class="back" bindtap="onBack">← 返回</text>
    <text class="title">创建接龙</text>
    <view class="placeholder"></view>
  </view>

  <view class="form-card">
    <!-- 商品图片上传 -->
    <view class="field">
      <text class="label">商品图片：</text>
      <view class="img-upload" bindtap="chooseProductImage">
        <image wx:if="{{form.img}}" class="preview-img" src="{{form.img}}" mode="aspectFill" />
        <view wx:else class="img-placeholder">
          <text class="plus-icon">+</text>
          <text class="img-tip">点击上传图片</text>
        </view>
      </view>
    </view>

    <view class="field">
      <text class="label">商品名称：</text>
      <input class="input" placeholder="输入商品名称" data-key="name" value="{{form.name}}" bindinput="onInputChange" />
    </view>

    <view class="field">
      <text class="label">商品描述：</text>
      <textarea class="textarea" placeholder="输入商品详情" data-key="description" value="{{form.description}}" bindinput="onInputChange"></textarea>
    </view>

    <view class="field">
      <text class="label">规格：</text>
      <input class="input" placeholder="输入规格（如：50个/袋）" data-key="spec" value="{{form.spec}}" bindinput="onInputChange" />
    </view>

    <view class="field-row">
      <view class="field half">
        <text class="label">售价：</text>
        <input class="input" type="digit" placeholder="输入售价" data-key="salePrice" value="{{form.salePrice}}" bindinput="onInputChange" />
      </view>
      <view class="field half">
        <text class="label">进价：</text>
        <input class="input" type="digit" placeholder="输入进价" data-key="costPrice" value="{{form.costPrice}}" bindinput="onInputChange" />
      </view>
    </view>

    <view class="field-row">
      <view class="field half">
        <text class="label">库存：</text>
        <input class="input" type="number" placeholder="输入库存" data-key="stock" value="{{form.stock}}" bindinput="onInputChange" />
      </view>
      <view class="field half">
        <text class="label">每人限购：</text>
        <input class="input" type="number" placeholder="输入限购数量" data-key="limitPerPerson" value="{{form.limitPerPerson}}" bindinput="onInputChange" />
      </view>
    </view>

    <view class="field">
      <text class="label">预计到货时间：</text>
      <picker mode="date" value="{{form.arrivalDate}}" start="{{today}}" bindchange="onArrivalDateChange">
        <view class="select">{{form.arrivalDate || '请选择到货时间'}}</view>
      </picker>
    </view>

    <view class="field">
      <text class="label">截单方式：</text>
      <picker mode="selector" range="{{form.closeTypeLabels}}" range-key="label" value="{{form.closeTypeIndex}}" bindchange="onCloseTypeChange">
        <view class="select">{{form.closeTypeLabels[form.closeTypeIndex].label}}</view>
      </picker>
    </view>

    <view class="field" wx:if="{{form.closeType === 'timed'}}">
      <text class="label">截单时间：</text>
      <picker mode="multiSelector" range="{{timeRange}}" value="{{form.closeTime}}" bindchange="onCloseTimeChange">
        <view class="select">{{form.closeTimeStr || '请选择截单时间'}}</view>
      </picker>
    </view>

    <view class="button-row">
      <button class="secondary-btn" bindtap="onCancel">取消</button>
      <button class="primary-btn" bindtap="onCreatePreorder">创建接龙</button>
    </view>
  </view>
</view>
