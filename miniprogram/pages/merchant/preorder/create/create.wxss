/* 引入商家首页公共样式 */
@import "../../index/index.wxss";

page {
  background: #f2f2f5;
  font-family: PingFang SC, Helvetica Neue, Arial, sans-serif;
  color: #333;
  min-height: 100vh;
}
.page {
  padding: 20rpx 20rpx 40rpx;
  box-sizing: border-box;
}


.form-card {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 24rpx;
  box-shadow: 0 6rpx 16rpx rgba(0, 0, 0, 0.08);
}
.field {
  margin-bottom: 20rpx;
}
.field-row {
  display: flex;
  justify-content: space-between;
}
.field.half {
  width: 48%;
}
.label {
  font-size: 26rpx;
  color: #333;
  margin-bottom: 10rpx;
  display: block;
  font-weight: 500;
}
.input {
  width: 100%;
  height: 56rpx;
  border: 1rpx solid #e0e0e0;
  border-radius: 12rpx;
  padding: 0 16rpx;
  font-size: 26rpx;
  box-sizing: border-box;
  background: #fafafa;
}
.textarea {
  width: 100%;
  min-height: 140rpx;
  border: 1rpx solid #e0e0e0;
  border-radius: 12rpx;
  padding: 16rpx;
  font-size: 26rpx;
  box-sizing: border-box;
  background: #fafafa;
}
.select {
  height: 56rpx;
  line-height: 56rpx;
  border: 1rpx solid #e0e0e0;
  border-radius: 12rpx;
  padding: 0 16rpx;
  font-size: 26rpx;
  color: #333;
  background: #fafafa;
}

/* 图片上传区域 */
.img-upload {
  width: 200rpx;
  height: 200rpx;
  border: 2rpx dashed #ddd;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #fafafa;
  overflow: hidden;
}
.preview-img {
  width: 100%;
  height: 100%;
}
.img-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}
.plus-icon {
  font-size: 60rpx;
  color: #999;
  line-height: 1;
}
.img-tip {
  font-size: 22rpx;
  color: #999;
  margin-top: 8rpx;
}

.button-row {
  display: flex;
  justify-content: space-between;
  margin-top: 30rpx;
}
.primary-btn {
  width: 56%;
  height: 70rpx;
  background: #33c266;
  color: #fff;
  border: none;
  border-radius: 16rpx;
  font-size: 28rpx;
  font-weight: bold;
}
.primary-btn::after {
  border: none;
}
.secondary-btn {
  width: 38%;
  height: 70rpx;
  background: #f0f0f0;
  color: #333;
  border: none;
  border-radius: 16rpx;
  font-size: 28rpx;
  font-weight: bold;
}
.secondary-btn::after {
  border: none;
}
