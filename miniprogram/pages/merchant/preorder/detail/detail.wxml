<view class="page">
  <view class="header">
    <text class="back" bindtap="onBack">← 返回</text>
    <text class="title">接龙详情</text>
    <view class="placeholder"></view>
  </view>

  <!-- 接龙基本信息 -->
  <view class="info-card" wx:if="{{dragon}}">
    <image class="dragon-img" src="{{dragon.img}}" mode="aspectFill" />
    <view class="info-content">
      <text class="dragon-name">{{dragon.name}}</text>
      <text class="dragon-spec">规格：{{dragon.spec}}</text>
      <view class="price-row">
        <text class="price">售价：¥{{dragon.salePrice}}</text>
        <text class="price">进价：¥{{dragon.costPrice}}</text>
      </view>
      <view class="stats-row">
        <text class="stat">👥 {{dragon.participantCount}}人参与</text>
        <text class="stat">📦 共{{dragon.totalQty}}件</text>
      </view>
      <text class="arrival">📅 预计{{dragon.arrivalDate}}到货</text>
      <view class="status-badge {{dragon.status === 'ongoing' ? 'status-ongoing' : 'status-completed'}}">
        {{dragon.status === 'ongoing' ? '正在接龙' : '已截单'}}
      </view>
    </view>
  </view>

  <!-- 操作按钮 -->
  <view class="action-row" wx:if="{{dragon && dragon.status === 'ongoing'}}">
    <button class="action-btn secondary" bindtap="onStopDragon">截止接龙</button>
    <button class="action-btn primary" open-type="share">转发接龙</button>
  </view>
  <view class="action-row" wx:if="{{dragon && dragon.status === 'completed'}}">
    <button class="action-btn primary" bindtap="onExport">导出表格</button>
  </view>

  <!-- 参与用户列表 -->
  <view class="list-section">
    <view class="section-header">
      <text class="section-title">参与用户</text>
      <text class="section-count">共{{participants.length}}人</text>
    </view>

    <view class="participant-list">
      <block wx:for="{{participants}}" wx:key="userId">
        <view class="participant-card">
          <image class="user-avatar" src="{{item.avatarUrl || '/images/avatar.png'}}" mode="aspectFill" />
          <view class="user-info">
            <text class="user-name">{{item.userName}}</text>
            <text class="user-time">参与时间：{{item.joinTime}}</text>
          </view>
          <view class="user-qty">×{{item.qty}}</view>
        </view>
      </block>
    </view>

    <view wx:if="{{!participants || participants.length === 0}}" class="empty-state">
      暂无用户参与
    </view>
  </view>
</view>
