/* 引入商家首页公共样式 */
@import "../../index/index.wxss";

page {
  background: #f2f2f5;
  font-family: PingFang SC, Helvetica Neue, Arial, sans-serif;
  color: #333;
}
.page {
  padding: 20rpx 20rpx 40rpx;
  box-sizing: border-box;
  min-height: 100vh;
}
.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}
.back {
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
}
.placeholder {
  width: 60rpx;
}
.title {
  flex: 1;
  text-align: center;
  font-size: 32rpx;
  font-weight: 600;
}

/* 接龙信息卡片 */
.info-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx;
  display: flex;
  gap: 20rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 6rpx 16rpx rgba(0, 0, 0, 0.08);
}
.dragon-img {
  width: 180rpx;
  height: 180rpx;
  border-radius: 16rpx;
  flex-shrink: 0;
}
.info-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  position: relative;
}
.dragon-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 10rpx;
}
.dragon-spec {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 12rpx;
}
.price-row {
  display: flex;
  gap: 20rpx;
  margin-bottom: 10rpx;
}
.price {
  font-size: 26rpx;
  color: #333;
}
.stats-row {
  display: flex;
  gap: 20rpx;
  margin-bottom: 10rpx;
}
.stat {
  font-size: 24rpx;
  color: #333;
}
.arrival {
  font-size: 24rpx;
  color: #ff9500;
  margin-bottom: 10rpx;
}
.status-badge {
  position: absolute;
  top: 0;
  right: 0;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  font-weight: 500;
}
.status-ongoing {
  background: #e8f5e9;
  color: #34c759;
}
.status-completed {
  background: #ffebee;
  color: #ff3b30;
}

/* 操作按钮 */
.action-row {
  display: flex;
  gap: 16rpx;
  margin-bottom: 30rpx;
}
.action-btn {
  flex: 1;
  height: 70rpx;
  border-radius: 16rpx;
  font-size: 28rpx;
  font-weight: bold;
  border: none;
}
.action-btn::after {
  border: none;
}
.action-btn.primary {
  background: #33c266;
  color: #fff;
}
.action-btn.secondary {
  background: #333;
  color: #fff;
}

/* 参与用户列表 */
.list-section {
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx;
  box-shadow: 0 6rpx 16rpx rgba(0, 0, 0, 0.08);
}
.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #f0f0f0;
}
.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}
.section-count {
  font-size: 24rpx;
  color: #999;
}
.participant-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}
.participant-card {
  display: flex;
  align-items: center;
  padding: 16rpx;
  background: #fafafa;
  border-radius: 16rpx;
}
.user-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  flex-shrink: 0;
  margin-right: 16rpx;
}
.user-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}
.user-name {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 6rpx;
}
.user-time {
  font-size: 22rpx;
  color: #999;
}
.user-qty {
  font-size: 32rpx;
  font-weight: 700;
  color: #ff9500;
}
.empty-state {
  text-align: center;
  color: #999;
  font-size: 26rpx;
  padding: 60rpx 0;
}
