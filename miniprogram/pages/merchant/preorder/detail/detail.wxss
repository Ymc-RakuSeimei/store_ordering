@import "../../index/index.wxss";

page {
  background-color: #F5F7FA;
  font-family: PingFang SC, Helvetica Neue, Arial, sans-serif;
  color: #333;
}

.page {
  min-height: 100vh;
  padding: 20rpx 20rpx 40rpx;
  box-sizing: border-box;
}

.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.back {
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
}

.placeholder {
  width: 60rpx;
}

.title {
  flex: 1;
  text-align: center;
  font-size: 32rpx;
  font-weight: 600;
}

.loading-state,
.empty-state {
  text-align: center;
  color: #999;
  margin-top: 120rpx;
  font-size: 28rpx;
}

.card {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 5rpx 14rpx rgba(0, 0, 0, 0.08);
}

/* 商品头部信息 */
.goods-header {
  display: flex;
  margin-bottom: 20rpx;
}

.goods-img {
  width: 160rpx;
  height: 160rpx;
  border-radius: 16rpx;
  flex-shrink: 0;
  background: #f0f0f0;
}

.goods-info {
  flex: 1;
  margin-left: 16rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
  min-width: 0;
}

.goods-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #222;
  margin-bottom: 8rpx;
  line-height: 1.2;
}

.goods-spec {
  font-size: 24rpx;
  color: #666;
  margin-bottom: 4rpx;
}

.goods-desc {
  font-size: 22rpx;
  color: #888;
  line-height: 1.4;
}

/* 商品元信息 */
.goods-meta {
  display: flex;
  flex-wrap: wrap;
  padding-top: 16rpx;
  border-top: 1rpx solid #f0f0f0;
}

.goods-meta + .goods-meta {
  margin-top: 8rpx;
}

.meta-row {
  width: 50%;
  display: flex;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.meta-row:nth-last-child(-n+2):last-child {
  margin-bottom: 0;
}

.meta-label {
  font-size: 24rpx;
  color: #888;
}

.meta-value {
  font-size: 24rpx;
  color: #333;
  font-weight: 500;
}

/* 统计卡片 */
.stats-card {
  background: linear-gradient(135deg, #33c266 0%, #28a745 100%);
}

.stats-title {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.9);
  margin-bottom: 16rpx;
}

.stats-row {
  display: flex;
  align-items: center;
  justify-content: center;
}

.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-number {
  font-size: 48rpx;
  font-weight: 700;
  color: #fff;
  line-height: 1;
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
}

.stat-divider {
  width: 1rpx;
  height: 60rpx;
  background: rgba(255, 255, 255, 0.3);
}

/* 订单列表 */
.orders-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #222;
  margin-bottom: 16rpx;
}

.orders-count {
  font-size: 24rpx;
  font-weight: 400;
  color: #888;
  margin-left: 8rpx;
}

.empty-orders {
  text-align: center;
  color: #999;
  padding: 40rpx 0;
  font-size: 26rpx;
}

.order-item {
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.order-item:last-child {
  border-bottom: none;
  padding-bottom: 0;
}

.order-item:first-child {
  padding-top: 0;
}

/* 订单头部 */
.order-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.customer-info {
  display: flex;
  align-items: center;
  flex: 1;
  min-width: 0;
}

.customer-avatar {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  flex-shrink: 0;
  background: #f0f0f0;
}

.placeholder-avatar {
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.avatar-text {
  font-size: 28rpx;
  font-weight: 600;
  color: #fff;
}

.customer-name {
  font-size: 28rpx;
  font-weight: 500;
  color: #222;
  margin-left: 12rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.order-time {
  font-size: 22rpx;
  color: #999;
  flex-shrink: 0;
  margin-left: 12rpx;
}

/* 订单详情 */
.order-detail {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

.qty-info {
  display: flex;
  align-items: baseline;
}

.qty-label {
  font-size: 24rpx;
  color: #666;
}

.qty-value {
  font-size: 28rpx;
  font-weight: 600;
  color: #222;
  margin-left: 8rpx;
}

.status-badge {
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
  font-weight: 500;
}

.status-waiting {
  background: #fff3cd;
  color: #856404;
}

.status-pending {
  background: #cce5ff;
  color: #004085;
}

.status-arrived {
  background: #d4edda;
  color: #155724;
}

.status-picked,
.status-completed {
  background: #e2e3e5;
  color: #383d41;
}

/* 联系电话 */
.order-phone {
  display: flex;
  align-items: baseline;
  font-size: 24rpx;
  margin-bottom: 4rpx;
}

.phone-label {
  color: #888;
}

.phone-value {
  color: #333;
  margin-left: 4rpx;
}

/* 备注 */
.order-remark {
  display: flex;
  align-items: baseline;
  font-size: 24rpx;
  margin-bottom: 4rpx;
}

.remark-label {
  color: #888;
}

.remark-value {
  color: #666;
  margin-left: 4rpx;
  flex: 1;
}

/* 订单号 */
.order-no {
  font-size: 20rpx;
  color: #ccc;
}
