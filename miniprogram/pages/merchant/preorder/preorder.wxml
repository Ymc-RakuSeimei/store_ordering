<view class="page">

  <!-- 正在接龙区域 -->
  <view class="panel">
    <view class="panel-head">
      <text class="panel-title" style="color: #34c759;">正在接龙</text>
    </view>
    <block wx:for="{{currentDragons}}" wx:key="id">
      <view class="goods-card" bindtap="onViewDetail" data-id="{{item.id}}">
        <image class="goods-img" src="{{item.img}}" mode="aspectFill" />

        <view class="goods-info">
          <text class="name">{{item.name}}</text>
          <text class="spec">规格：{{item.spec}}</text>
        </view>

        <view class="goods-action-area">
          <text class="item-qty">x{{item.totalQty}}</text>
          <view class="action-buttons">
            <button
              class="action-btn action-btn--share"
              catchtap="stopPropagation"
              data-id="{{item.id}}"
              data-item="{{item}}"
              open-type="share"
            >
              转发
            </button>
            <button
              class="action-btn action-btn--stop"
              catchtap="onStopCurrent"
              data-id="{{item.id}}">
              截止
            </button>
          </view>
        </view>
      </view>
    </block>
    <view wx:if="{{!currentDragons || currentDragons.length===0}}" class="empty-state">暂无正在接龙数据</view>
  </view>

  <!-- 已截单区域 -->
  <view class="panel">
    <view class="panel-head">
      <text class="panel-title" style="color: #ff3b30;">已截单</text>
    </view>
    <block wx:for="{{completedDragons}}" wx:key="id">
      <view class="goods-card goods-card--completed" bindtap="onViewDetail" data-id="{{item.id}}">
        <image class="goods-img" src="{{item.img}}" mode="aspectFill" />

        <view class="goods-info">
          <text class="name">{{item.name}}</text>
          <text class="spec">规格：{{item.spec}}</text>
          <text wx:if="{{item.closedAt}}" class="summary">截止时间：{{item.closedAt}}</text>
          <text wx:if="{{item.arrivalTime}}" class="summary arrival">到货时间：{{item.arrivalTime}}</text>
        </view>

        <view class="goods-action-area">
          <text class="item-qty">x{{item.totalQty}}</text>
          <view class="action-buttons">
            <button
              wx:if="{{item.status !== '已到货'}}"
              class="action-btn action-btn--arrive"
              catchtap="onMarkArrival"
              data-id="{{item.id}}"
            >
              到货
            </button>
            <view wx:else class="arrival-badge">
              已到货
            </view>
            <button
              class="action-btn action-btn--delete"
              catchtap="onDeleteCompleted"
              data-id="{{item.id}}"
            >
              删除
            </button>
          </view>
        </view>
      </view>
    </block>
    <view wx:if="{{!completedDragons || completedDragons.length===0}}" class="empty-state">暂无已截单数据</view>
  </view>

  <!-- 底部创建接龙按钮 -->
  <button class="big-btn" bindtap="toCreatePreorder">创建接龙</button>
</view>
