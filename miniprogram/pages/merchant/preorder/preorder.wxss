page {
  background: #f2f2f5; /* 和商家首页背景统一 */
  font-family: PingFang SC, Helvetica Neue, Arial, sans-serif;
  color: #333;
}
.page {
  padding: 20rpx;
  min-height: 100vh;
}
.header {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}
.back {
  color: #007AFF;
  font-size: 30rpx;
}
.title {
  flex: 1;
  text-align: center;
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}
.panel {
  margin-bottom: 30rpx;
  background: transparent;
  box-shadow: none;
  padding: 0;
}
.panel-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}
.panel-title {
  font-size: 28rpx;
  font-weight: bold;
}
.small-btn {
  padding: 8rpx 24rpx;
  border-radius: 24rpx;
  background: #ffcc00;
  color: #000;
  font-size: 24rpx;
  font-weight: bold;
  border: none;
}
.small-btn::after {
  border: none;
}
.item-card {
  display: flex;
  justify-content: space-between;
  align-items: center;
  border: none;
  border-radius: 20rpx;
  padding: 20rpx 20rpx 20rpx 40rpx; /* 左侧预留序号位置 */
  margin-bottom: 16rpx;
  background: #fff;
  box-shadow: 0 6rpx 16rpx rgba(0, 0, 0, 0.08);
  border-left: 6rpx solid #e5e5e5; /* 左侧灰色分隔线 */
  position: relative;
}
.item-card.simple {
  background: #fafafa;
}
.item-left {
  display: flex;
  flex-direction: column;
}
.item-order {
  position: absolute;
  left: 14rpx;
  top: 50%;
  transform: translateY(-50%);
  font-size: 28rpx;
  color: #333;
  font-weight: bold;
}
.item-name {
  font-size: 26rpx;
  color: #333;
  font-weight: 600;
}
.item-spec {
  font-size: 22rpx;
  color: #666;
  margin-top: 4rpx;
}
.item-right {
  display: flex;
  flex-direction: row; /* 数量和按钮组横向排列 */
  align-items: center;
  gap: 30rpx; /* 数量和按钮组之间的间距 */
}
.btn-group {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  align-items: flex-end;
}
.item-qty {
  font-size: 32rpx;
  color: #24b24d; /* 正在接龙时数量为灰色 */
  font-weight: 700;
  
}
/* 已截单时数量为红色 */
.item-card.simple .item-qty {
  color: #ff3b30;
}
.btn-handle {
  background: #ffcc00;
  color: #000;
  border: none;
  border-radius: 20rpx;
  padding: 10rpx 20rpx;
  font-size: 24rpx;
  font-weight: bold;
}
.btn-handle::after {
  border: none;
}
.btn-stop {
  background: #333;
  color: #fff;
  border: none;
  border-radius: 20rpx;
  padding: 10rpx 20rpx;
  font-size: 24rpx;
  font-weight: bold;
}
.btn-stop::after {
  border: none;
}
.empty-state {
  text-align: center;
  color: #999;
  font-size: 24rpx;
  padding: 20rpx 0;
}
.big-btn {
  width: 100%;
  height: 70rpx;
  background: #333;
  color: #fff;
  border: none;
  border-radius: 18rpx;
  font-size: 30rpx;
  margin-top: 10rpx;
}
