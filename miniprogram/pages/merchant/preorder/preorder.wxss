/* 引入商家首页公共样式 */
@import "../index/index.wxss";

page {
  background-color: #F5F7FA;
  font-family: PingFang SC, Helvetica Neue, Arial, sans-serif;
  color: #333;
}
.page {
  padding: 20rpx 20rpx 120rpx;
  min-height: 100vh;
  box-sizing: border-box;
}
.header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}
.title {
  flex: 1;
  text-align: center;
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}
.panel {
  margin-bottom: 30rpx;
  background: transparent;
  box-shadow: none;
  padding: 0;
}
.panel-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}
.panel-title {
  font-size: 30rpx;
  font-weight: bold;
}
.small-btn {
  padding: 10rpx 28rpx;
  border-radius: 24rpx;
  background: #ffcc00;
  color: #000;
  font-size: 24rpx;
  font-weight: bold;
  border: none;
}
.small-btn::after {
  border: none;
}

/* 接龙卡片 */
.item-card {
  display: flex;
  justify-content: flex-start;
  align-items: center;
  border: none;
  border-radius: 20rpx;
  padding: 20rpx;
  margin-bottom: 16rpx;
  background: #fff;
  box-shadow: 0 6rpx 16rpx rgba(0, 0, 0, 0.08);
  position: relative;
  min-height: 160rpx;
}
.item-card.simple {
  background: #fafafa;
}

/* 序号 */
.card-index {
  font-size: 28rpx;
  color: #333;
  font-weight: 600;
  margin-right: 16rpx;
  flex-shrink: 0;
}

/* 商品图片 */
.item-img {
  width: 100rpx;
  height: 100rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
  margin-right: 16rpx;
}

.item-left {
  display: flex;
  flex-direction: column;
  flex: 1;
  margin-right: 16rpx;
}
.item-name {
  font-size: 28rpx;
  color: #333;
  font-weight: 600;
  margin-bottom: 6rpx;
}
.item-spec {
  font-size: 24rpx;
  color: #666;
}

.item-right {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 12rpx;
  flex-shrink: 0;
}
.btn-group {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  align-items: flex-end;
}
.item-qty {
  font-size: 32rpx;
  color: #999;
  font-weight: 700;
}
/* 已截单时数量为红色 */
.item-card.simple .item-qty {
  color: #ff3b30;
}
.btn-handle {
  background: #ffcc00;
  color: #000;
  border: none;
  border-radius: 16rpx;
  padding: 8rpx 20rpx;
  font-size: 22rpx;
  font-weight: bold;
}
.btn-handle::after {
  border: none;
}

.btn-stop {
  background: #333;
  color: #fff;
  border: none;
  border-radius: 16rpx;
  padding: 8rpx 20rpx;
  font-size: 22rpx;
  font-weight: bold;
}
.btn-stop::after {
  border: none;
}
.empty-state {
  text-align: center;
  color: #999;
  font-size: 26rpx;
  padding: 60rpx 0;
}
.big-btn {
  width: 90%;
  height: 80rpx;
  background: #333;
  color: #fff;
  border: none;
  border-radius: 18rpx;
  font-size: 30rpx;
  font-weight: bold;
  position: fixed;
  bottom: 40rpx;
  left: 20rpx;
  right: 20rpx;
  z-index: 100;
}
.big-btn::after {
  border: none;
}
