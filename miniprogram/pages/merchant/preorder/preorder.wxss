@import "../index/index.wxss";

page {
  background: #f2f2f5;
  font-family: PingFang SC, Helvetica Neue, Arial, sans-serif;
  color: #333;
}

.page {
  min-height: 100vh;
  padding: 20rpx 20rpx 190rpx;
  box-sizing: border-box;
}


.panel {
  margin-bottom: 30rpx;
  background: transparent;
  box-shadow: none;
  padding: 0;
}

.panel-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.panel-title {
  font-size: 30rpx;
  font-weight: bold;
}

/* 商品卡片 - 复用订单处理页的视觉骨架 */
.goods-card {
  display: flex;
  align-items: center;
  background: #ffffff;
  border-radius: 20rpx;
  box-shadow: 0 5rpx 14rpx rgba(0, 0, 0, 0.08);
  overflow: hidden;
  margin-bottom: 14rpx;
  height: 176rpx;
  padding: 10rpx 14rpx 10rpx 10rpx;
  box-sizing: border-box;
}

.goods-card--completed {
  background: #fafafa;
}

.goods-img {
  width: 146rpx;
  height: 146rpx;
  flex-shrink: 0;
  border-radius: 18rpx;
  display: block;
  background: #f0f0f0;
}

.goods-info {
  flex: 1;
  margin-left: 16rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
  min-width: 0;
  align-self: stretch;
}

.name {
  font-size: 29rpx;
  font-weight: 600;
  color: #020202;
  margin-bottom: 2rpx;
  line-height: 1.14;
}

.spec,
.summary {
  font-size: 23rpx;
  color: #666;
  margin-bottom: 2rpx;
  line-height: 1.12;
}

.summary {
  color: #111;
  font-weight: 500;
}

.summary.arrival {
  color: #34c759;
}

.goods-info text:last-child {
  margin-bottom: 0;
}

.goods-action-area {
  width: 200rpx;
  min-height: 146rpx;
  margin-left: 10rpx;
  display: flex;
  align-items: center;
  justify-content: flex-end;
  flex-shrink: 0;
  gap: 12rpx;
  align-self: stretch;
}

.item-qty {
  font-size: 32rpx;
  color: #999;
  font-weight: 700;
  flex-shrink: 0;
  width: 70rpx;
  text-align: right;
  display: flex;
  align-items: center;
  justify-content: flex-end;
  height: 100%;
}

.goods-card--completed .item-qty {
  color: #f47676;
}

.action-buttons {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  width: 110rpx;
  height: 100%;
}

.action-btn {
  width: 110rpx;
  height: 74rpx;
  line-height: 60rpx;
  border-radius: 12rpx;
  font-size: 25rpx;
  font-weight: 600;
  text-align: center;
  border: none;
  padding: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.action-btn::after {
  border: none;
}

.action-btn--share {
  background: #007aff;
  color: #fff;
}

.action-btn--stop {
  background: #ff9500;
  color: #fff;
}

.action-btn--arrive {
  background: #33c266;
  color: #fff;
}

.action-btn--delete {
  background: #ff3b30;
  color: #fff;
}

.arrive-btn {
  width: 110rpx;
  height: 60rpx;
  line-height: 60rpx;
  border-radius: 12rpx;
  background: #33c266;
  color: #fff;
  font-size: 25rpx;
  font-weight: 600;
  text-align: center;
  border: none;
  padding: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.arrive-btn::after {
  border: none;
}

.arrival-badge {
  width: 110rpx;
  height: 60rpx;
  line-height: 60rpx;
  border-radius: 12rpx;
  background: #e9f7ee;
  color: #2c9b54;
  font-size: 25rpx;
  font-weight: 600;
  text-align: center;
  box-sizing: border-box;
}

.empty-state {
  text-align: center;
  color: #999;
  margin-top: 80rpx;
  font-size: 24rpx;
}

.big-btn {
  width: 90%;
  height: 84rpx;
  background: #333;
  color: #fff;
  border: none;
  border-radius: 30rpx;
  font-size: 30rpx;
  font-weight: 600;
  position: fixed;
  bottom: 40rpx;
  left: 20rpx;
  right: 20rpx;
  z-index: 100;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.3);
  transition: all 0.3s ease;
}

.big-btn::after {
  border: none;
}

.big-btn:active {
  background: #555;
  transform: scale(0.98);
}
