<!-- 订单核销页 - 商家扫描顾客取货码后核销商品 -->
<view class="container">

  <!-- 加载状态 -->
  <view class="loading-container" wx:if="{{loading}}">
    <view class="loading-spinner"></view>
    <text class="loading-text">加载中...</text>
  </view>

  <!-- 错误状态 -->
  <view class="error-container" wx:if="{{!loading && errorMsg}}">
    <view class="error-icon">!</view>
    <text class="error-text">{{errorMsg}}</text>
    <button class="retry-btn" bindtap="onRetry">重新加载</button>
  </view>

  <!-- 主内容 -->
  <view class="content" wx:if="{{!loading && !errorMsg}}">

    <!-- 顾客信息 -->
    <view class="customer-card" wx:if="{{customerInfo}}">
      <view class="customer-avatar">
        <text class="avatar-text">{{customerInfo.name ? customerInfo.name[0] : '顾'}}</text>
      </view>
      <view class="customer-info">
        <view class="customer-name-row">
          <text class="customer-name">{{customerInfo.name || '未知用户'}}</text>
          <view class="customer-tag">顾客</view>
        </view>
        <view class="customer-phone" wx:if="{{customerInfo.phone}}">
          <text class="phone-icon">📞</text>
          <text class="phone-text">{{customerInfo.phone}}</text>
        </view>
      </view>
    </view>

    <!-- 统计栏 -->
    <view class="stats-bar" wx:if="{{pickupGoods.length > 0 || waitingGoods.length > 0}}">
      <view class="stat-item">
        <text class="stat-value">{{pickupGoods.length}}</text>
        <text class="stat-label">可取货</text>
      </view>
      <view class="stat-divider"></view>
      <view class="stat-item">
        <text class="stat-value">{{waitingGoods.length}}</text>
        <text class="stat-label">未到货</text>
      </view>
      <view class="stat-divider"></view>
      <view class="stat-item">
        <text class="stat-value">{{pickupGoods.length + waitingGoods.length}}</text>
        <text class="stat-label">总计</text>
      </view>
    </view>

    <!-- 可取货列表 -->
    <view class="section pickup-section" wx:if="{{pickupGoods.length > 0}}">
      <view class="section-header">
        <view class="section-icon pickup-icon">
          <text class="icon-text">✓</text>
        </view>
        <text class="section-title">可取货</text>
        <view class="section-badge">{{pickupGoods.length}}</view>
      </view>
      <view class="goods-list">
        <view class="goods-item" wx:for="{{pickupGoods}}" wx:key="id">
          <view class="goods-image-wrap">
            <image class="goods-image" src="{{item.image}}" mode="aspectFill" lazy-load/>
          </view>
          <view class="goods-content">
            <view class="goods-name">{{item.name}}</view>
            <view class="goods-meta">
              <text class="goods-price" wx:if="{{item.price}}">¥{{item.price}}</text>
              <text class="goods-qty">×{{item.quantity}}</text>
            </view>
          </view>
          <view class="goods-action">
            <button class="pickup-btn" bindtap="onPickupItem" data-id="{{item.id}}">
              <text class="btn-text">取货</text>
            </button>
          </view>
        </view>
      </view>
    </view>

    <!-- 未到货列表 -->
    <view class="section waiting-section" wx:if="{{waitingGoods.length > 0}}">
      <view class="section-header">
        <view class="section-icon waiting-icon">
          <text class="icon-text">⏱</text>
        </view>
        <text class="section-title">未到货</text>
        <view class="section-badge waiting-badge">{{waitingGoods.length}}</view>
      </view>
      <view class="goods-list">
        <view class="goods-item waiting-item" wx:for="{{waitingGoods}}" wx:key="id">
          <view class="goods-image-wrap">
            <image class="goods-image" src="{{item.image}}" mode="aspectFill" lazy-load/>
            <view class="image-overlay"></view>
          </view>
          <view class="goods-content">
            <view class="goods-name">{{item.name}}</view>
            <view class="goods-meta">
              <text class="goods-price" wx:if="{{item.price}}">¥{{item.price}}</text>
              <text class="goods-qty">×{{item.quantity}}</text>
            </view>
          </view>
          <view class="goods-action">
            <view class="waiting-tag">等待中</view>
          </view>
        </view>
      </view>
    </view>

    <!-- 空状态 -->
    <view class="empty-state" wx:if="{{pickupGoods.length === 0 && waitingGoods.length === 0}}">
      <view class="empty-icon">
        <text>📦</text>
      </view>
      <text class="empty-title">暂无待取货物</text>
      <text class="empty-subtitle">该顾客当前没有待取的商品</text>
    </view>
  </view>

  <!-- 底部操作栏 -->
  <view class="bottom-action" wx:if="{{!loading && !errorMsg && pickupGoods.length > 0}}">
    <view class="pickup-summary">
      <text class="summary-text">共 {{pickupGoods.length}} 件商品待取货</text>
    </view>
    <button class="pickup-all-btn" bindtap="onPickupAll">
      <text class="btn-icon">✓</text>
      <text class="btn-text">一键取货</text>
    </button>
  </view>
</view>
