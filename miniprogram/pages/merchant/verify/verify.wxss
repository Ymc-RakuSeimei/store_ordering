/* 订单核销页样式 - 高级简约扁平化设计 */

/* 变量：设计系统变量 */
page {
  --primary: #07c160;
  --primary-dark: #05a850;
  --primary-light: #e6f7ed;
  --warning: #ff9500;
  --warning-light: #fff5e6;
  --danger: #ff4d4f;
  --text-primary: #1a1a1a;
  --text-secondary: #666666;
  --text-tertiary: #999999;
  --bg-primary: #f8f9fa;
  --bg-white: #ffffff;
  --border-color: #f0f0f0;
  --shadow-sm: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
  --shadow-md: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
  --shadow-lg: 0 8rpx 32rpx rgba(0, 0, 0, 0.08);
  --radius-sm: 12rpx;
  --radius-md: 20rpx;
  --radius-lg: 28rpx;
  --radius-xl: 40rpx;

  background-color: var(--bg-primary);
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Helvetica Neue", Helvetica, Arial, sans-serif;
  -webkit-font-smoothing: antialiased;
}

/* 容器 */
.container {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  padding-bottom: 180rpx;
}

/* 加载状态 */
.loading-container {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 160rpx 40rpx;
}

.loading-spinner {
  width: 64rpx;
  height: 64rpx;
  border: 4rpx solid var(--border-color);
  border-top-color: var(--primary);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  margin-top: 24rpx;
  font-size: 28rpx;
  color: var(--text-tertiary);
  animation: pulse 1.5s ease-in-out infinite;
}

@keyframes pulse {
  0%, 100% { opacity: 0.6; }
  50% { opacity: 1; }
}

/* 错误状态 */
.error-container {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 160rpx 60rpx;
  animation: fadeInUp 0.5s ease-out;
}

.error-icon {
  width: 120rpx;
  height: 120rpx;
  background: linear-gradient(135deg, #ff4d4f 0%, #ff7875 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 60rpx;
  color: #fff;
  font-weight: 600;
  margin-bottom: 32rpx;
  box-shadow: 0 8rpx 24rpx rgba(255, 77, 79, 0.3);
  animation: shake 0.5s ease-in-out;
}

@keyframes shake {
  0%, 100% { transform: translateX(0); }
  25% { transform: translateX(-10rpx); }
  75% { transform: translateX(10rpx); }
}

.error-text {
  font-size: 30rpx;
  color: var(--text-secondary);
  margin-bottom: 40rpx;
  text-align: center;
  line-height: 1.6;
}

.retry-btn {
  padding: 24rpx 56rpx;
  background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);
  color: #fff;
  border-radius: var(--radius-xl);
  font-size: 30rpx;
  font-weight: 500;
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(7, 193, 96, 0.3);
  transition: all 0.3s ease;
}

.retry-btn:active {
  transform: scale(0.96);
  box-shadow: 0 4rpx 12rpx rgba(7, 193, 96, 0.2);
}

/* 主内容区 */
.content {
  flex: 1;
  padding: 24rpx;
  animation: fadeIn 0.4s ease-out;
}

@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(30rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

/* 顾客信息卡片 */
.customer-card {
  background: var(--bg-white);
  border-radius: var(--radius-lg);
  padding: 32rpx;
  margin-bottom: 24rpx;
  display: flex;
  align-items: center;
  box-shadow: var(--shadow-md);
  animation: slideInLeft 0.5s ease-out;
}

@keyframes slideInLeft {
  from {
    opacity: 0;
    transform: translateX(-30rpx);
  }
  to {
    opacity: 1;
    transform: translateX(0);
  }
}

.customer-avatar {
  width: 96rpx;
  height: 96rpx;
  background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
  flex-shrink: 0;
  box-shadow: 0 8rpx 24rpx rgba(7, 193, 96, 0.25);
}

.avatar-text {
  font-size: 40rpx;
  color: #fff;
  font-weight: 600;
}

.customer-info {
  flex: 1;
}

.customer-name-row {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.customer-name {
  font-size: 36rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-right: 16rpx;
}

.customer-tag {
  padding: 4rpx 16rpx;
  background: var(--primary-light);
  color: var(--primary);
  font-size: 22rpx;
  font-weight: 500;
  border-radius: 20rpx;
}

.customer-phone {
  display: flex;
  align-items: center;
}

.phone-icon {
  font-size: 24rpx;
  margin-right: 8rpx;
  opacity: 0.7;
}

.phone-text {
  font-size: 26rpx;
  color: var(--text-secondary);
}

/* 统计栏 */
.stats-bar {
  background: var(--bg-white);
  border-radius: var(--radius-lg);
  padding: 28rpx 24rpx;
  margin-bottom: 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-around;
  box-shadow: var(--shadow-sm);
  animation: slideInRight 0.5s ease-out 0.1s both;
}

@keyframes slideInRight {
  from {
    opacity: 0;
    transform: translateX(30rpx);
  }
  to {
    opacity: 1;
    transform: translateX(0);
  }
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.stat-value {
  font-size: 44rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 8rpx;
  transition: all 0.3s ease;
}

.stat-label {
  font-size: 24rpx;
  color: var(--text-tertiary);
}

.stat-divider {
  width: 2rpx;
  height: 48rpx;
  background: var(--border-color);
}

/* 商品区域卡片 */
.section {
  background: var(--bg-white);
  border-radius: var(--radius-lg);
  padding: 28rpx;
  margin-bottom: 24rpx;
  box-shadow: var(--shadow-sm);
  animation: fadeInUp 0.5s ease-out;
}

.section:nth-child(3) { animation-delay: 0.15s; }
.section:nth-child(4) { animation-delay: 0.2s; }

.section-header {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
  padding-bottom: 20rpx;
  border-bottom: 2rpx solid var(--border-color);
}

.section-icon {
  width: 48rpx;
  height: 48rpx;
  border-radius: var(--radius-sm);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
}

.pickup-icon {
  background: var(--primary-light);
}

.waiting-icon {
  background: var(--warning-light);
}

.icon-text {
  font-size: 28rpx;
  font-weight: 600;
}

.pickup-icon .icon-text {
  color: var(--primary);
}

.waiting-icon .icon-text {
  color: var(--warning);
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
  flex: 1;
}

.section-badge {
  min-width: 40rpx;
  height: 40rpx;
  padding: 0 12rpx;
  background: var(--primary);
  color: #fff;
  font-size: 24rpx;
  font-weight: 600;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.waiting-badge {
  background: var(--warning);
}

/* 商品列表 */
.goods-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.goods-item {
  display: flex;
  align-items: center;
  padding: 20rpx;
  background: var(--bg-primary);
  border-radius: var(--radius-md);
  transition: all 0.3s ease;
  animation: slideInUp 0.4s ease-out;
}

.goods-item:nth-child(1) { animation-delay: 0.05s; }
.goods-item:nth-child(2) { animation-delay: 0.1s; }
.goods-item:nth-child(3) { animation-delay: 0.15s; }
.goods-item:nth-child(4) { animation-delay: 0.2s; }

@keyframes slideInUp {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.goods-item:active {
  transform: scale(0.98);
  background: #f0f1f2;
}

.waiting-item {
  opacity: 0.85;
}

/* 商品图片 */
.goods-image-wrap {
  position: relative;
  width: 120rpx;
  height: 120rpx;
  border-radius: var(--radius-sm);
  overflow: hidden;
  margin-right: 20rpx;
  flex-shrink: 0;
  background: #f0f0f0;
}

.goods-image {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.3s ease;
}

.goods-item:active .goods-image {
  transform: scale(1.05);
}

.image-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.15);
}

/* 商品内容 */
.goods-content {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.goods-name {
  font-size: 30rpx;
  font-weight: 500;
  color: var(--text-primary);
  line-height: 1.4;
  margin-bottom: 12rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.goods-meta {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.goods-price {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--danger);
}

.goods-qty {
  font-size: 26rpx;
  color: var(--text-tertiary);
  font-weight: 500;
}

/* 商品操作 */
.goods-action {
  margin-left: 16rpx;
  flex-shrink: 0;
}

.pickup-btn {
  min-width: 100rpx;
  height: 64rpx;
  padding: 0 28rpx;
  background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);
  color: #fff;
  border-radius: var(--radius-xl);
  font-size: 26rpx;
  font-weight: 500;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 12rpx rgba(7, 193, 96, 0.3);
  transition: all 0.2s ease;
}

.pickup-btn:active {
  transform: scale(0.92);
  box-shadow: 0 2rpx 8rpx rgba(7, 193, 96, 0.2);
}

.btn-text {
  line-height: 1;
}

.waiting-tag {
  padding: 8rpx 20rpx;
  background: var(--warning-light);
  color: var(--warning);
  font-size: 24rpx;
  font-weight: 500;
  border-radius: var(--radius-xl);
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 40rpx;
  animation: fadeInUp 0.5s ease-out;
}

.empty-icon {
  width: 160rpx;
  height: 160rpx;
  background: var(--bg-primary);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 80rpx;
  margin-bottom: 32rpx;
  animation: float 3s ease-in-out infinite;
}

@keyframes float {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-10rpx); }
}

.empty-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 12rpx;
}

.empty-subtitle {
  font-size: 26rpx;
  color: var(--text-tertiary);
}

/* 底部操作栏 */
.bottom-action {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: var(--bg-white);
  padding: 24rpx 32rpx calc(24rpx + env(safe-area-inset-bottom));
  display: flex;
  align-items: center;
  gap: 24rpx;
  box-shadow: 0 -4rpx 24rpx rgba(0, 0, 0, 0.06);
  animation: slideUp 0.4s ease-out;
}

@keyframes slideUp {
  from {
    opacity: 0;
    transform: translateY(100%);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.pickup-summary {
  flex: 1;
}

.summary-text {
  font-size: 26rpx;
  color: var(--text-secondary);
}

.pickup-all-btn {
  flex-shrink: 0;
  min-width: 240rpx;
  height: 88rpx;
  padding: 0 40rpx;
  background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);
  color: #fff;
  border-radius: var(--radius-xl);
  font-size: 30rpx;
  font-weight: 600;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  box-shadow: 0 8rpx 24rpx rgba(7, 193, 96, 0.35);
  transition: all 0.2s ease;
}

.pickup-all-btn:active {
  transform: scale(0.96);
  box-shadow: 0 4rpx 16rpx rgba(7, 193, 96, 0.25);
}

.btn-icon {
  font-size: 28rpx;
  font-weight: 700;
}

/* 响应式适配 */
@media screen and (max-width: 375px) {
  .content {
    padding: 16rpx;
  }

  .customer-card {
    padding: 24rpx;
  }

  .customer-avatar {
    width: 80rpx;
    height: 80rpx;
  }

  .avatar-text {
    font-size: 32rpx;
  }

  .customer-name {
    font-size: 32rpx;
  }

  .goods-image-wrap {
    width: 100rpx;
    height: 100rpx;
  }

  .goods-name {
    font-size: 28rpx;
  }

  .pickup-btn {
    min-width: 88rpx;
    height: 56rpx;
    padding: 0 20rpx;
    font-size: 24rpx;
  }

  .pickup-all-btn {
    min-width: 200rpx;
    height: 80rpx;
    font-size: 28rpx;
  }
}

@media screen and (min-width: 768px) {
  .content {
    max-width: 720rpx;
    margin: 0 auto;
    padding: 32rpx;
  }

  .bottom-action {
    max-width: 720rpx;
    left: 50%;
    transform: translateX(-50%);
    border-radius: var(--radius-lg) var(--radius-lg) 0 0;
  }
}
