/* pages/merchant/verify/verify.wxss */
page {
  background-color: #f5f7fa;
  font-family: -apple-system, BlinkMacSystemFont, "Helvetica Neue", Helvetica, Arial, sans-serif;
}

.container {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  padding-top: 0rpx;
}

/* 页面标题栏 */
.page-header {
  padding: 24rpx 0;
  text-align: center;
}

.page-title {
  font-size: 36rpx;
  font-weight: 500;
  color: #333333;
}

/* 加载中状态 */
.loading-container {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid #e5e5e5;
  border-top: 4rpx solid #07c160;
  border-radius: 50%;
  animation: loading-spin 1s linear infinite;
  margin-bottom: 24rpx;
}

@keyframes loading-spin {
  0% {
    transform: rotate(0deg);
  }

  100% {
    transform: rotate(360deg);
  }
}

.loading-text {
  font-size: 28rpx;
  color: #999999;
}

/* 错误提示状态 */
.error-container {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 40rpx;
}

.error-text {
  font-size: 28rpx;
  color: #f56c6c;
  margin-bottom: 40rpx;
  text-align: center;
}

.retry-btn {
  padding: 20rpx 40rpx;
  background-color: #07c160;
  color: #ffffff;
  border-radius: 8rpx;
  font-size: 28rpx;
  border: none;
}

/* 主内容区域 */
.content {
  flex: 1;
  padding: 10rpx 0 100rpx;
  margin: 0 10rpx;
}

/* 顾客信息卡片 */
.customer-card {
  background-color: #ffffffd0;
  border-radius: 16rpx;
  padding: 60rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.customer-header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
  flex-wrap: wrap;
}

.customer-label {
  font-size: 34rpx;
  color: #999999;
}

.customer-name {
  font-size: 40rpx;
  color: #333333;
  font-weight: 600;
  margin: 0 16rpx;
}

.customer-phone {
  font-size: 32rpx;
  color: #666666;
  margin-top: 12rpx;
  width: 100%;
}

/* 通用区域样式 */
.section {
  background-color: #ffffffd0;
  border-radius: 16rpx;
  padding: 60rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.section-header {
  margin-bottom: 20rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
  display: flex;
}

.section-title {
  font-size: 34rpx;
  font-weight: 600;

}

.pickup-title {
  color: #07c160;
  /* 可取货绿色标识 */
}

.waiting-title {
  color: #999999;
  /* 待到货灰色标识 */
}

/* 商品列表项 */
.goods-list {
  width: 100%;
}

.goods-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 26rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
  transition: all 0.3s ease;
}

.goods-item:last-child {
  border-bottom: none;
}

.goods-item:hover {
  background-color: #f9f9f9;
}

.goods-info {
  display: flex;
  align-items: center;
  flex: 1;
}

.goods-index {
  font-size: 32rpx;
  color: #333333;
  margin-right: 20rpx;
  min-width: 48rpx;
}

.goods-name {
  font-size: 32rpx;
  color: #333333;
  flex: 1;
}

.goods-action {
  display: flex;
  align-items: center;
}

.goods-qty {
  font-size: 32rpx;
  color: #666666;
  margin-right: 28rpx;
  min-width: 72rpx;
  text-align: right;
}

.pickup-btn {
  padding: 20rpx 36rpx;
  background-color: #07c160;
  color: #ffffff;
  border-radius: 10rpx;
  font-size: 30rpx;
  border: none;
  line-height: 1;
  transition: all 0.3s ease;
  min-width: 96rpx;
  text-align: center;
}

.pickup-btn:hover {
  background-color: #05a850;
  transform: translateY(-2rpx);
}

.pickup-btn:active {
  transform: translateY(0);
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 120rpx 0;
}

.empty-text {
  font-size: 28rpx;
  color: #999999;
}

/* 底部一键取货按钮 */
.bottom-action {
  position: fixed;
  bottom: 20rpx;
  left: 50%;
  right: auto;
  transform: translateX(-50%);
  width: calc(100% - 40rpx);
  max-width: 840rpx;
  padding: 16rpx;
  background-color: #ffffff;
  border-radius: 16rpx;
  border: 1rpx solid #e5e5e5;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
}

.pickup-all-btn {
  width: 100%;
  padding: 24rpx 0;
  background-color: #07c160;
  color: #ffffff;
  border-radius: 12rpx;
  font-size: 28rpx;
  font-weight: 500;
  border: none;
  transition: all 0.3s ease;
}

.pickup-all-btn:hover {
  background-color: #05a850;
}

.pickup-all-btn:active {
  transform: translateY(2rpx);
}

/* 动画效果 */
@keyframes fadeIn {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }

  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.section,
.customer-card {
  animation: fadeIn 0.5s ease-out;
}

/* 响应式设计 */
@media screen and (max-width: 375px) {
  .customer-name {
    font-size: 32rpx;
  }

  .goods-name {
    font-size: 28rpx;
  }

  .pickup-btn {
    padding: 12rpx 24rpx;
    font-size: 26rpx;
  }
}

@media screen and (min-width: 768px) {
  .content {
    max-width: 880rpx;
    margin: 0 auto;
  }

  .bottom-action {
    max-width: 840rpx;
  }
}