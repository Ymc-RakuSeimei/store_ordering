/* pages/customer/preorder/detail/detail.wxss */

.container {
  padding: 20rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
}

/* 商品卡片 */
.product-card {
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  margin-bottom: 20rpx;
}

.product-img {
  width: 100%;
  height: 400rpx;
  object-fit: cover;
}

.product-info {
  padding: 24rpx;
}

.product-name {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 12rpx;
}

.product-spec {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 20rpx;
}

.price-row {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
}

.price-group {
  display: flex;
  align-items: baseline;
}

.sale-price {
  font-size: 40rpx;
  font-weight: bold;
  color: #ff4d4f;
}

.sale-price::before {
  content: '¥';
  font-size: 24rpx;
  margin-right: 4rpx;
}

.cost-price {
  font-size: 24rpx;
  color: #999;
  text-decoration: line-through;
  margin-left: 12rpx;
}

.cost-price::before {
  content: '¥';
  margin-right: 2rpx;
}

/* 统计信息 */
.stats-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.stats-row {
  display: flex;
  justify-content: space-between;
}

.stat-item {
  text-align: center;
  flex: 1;
}

.stat-value {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.stat-label {
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}

.arrival-date {
  text-align: center;
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #f0f0f0;
  color: #666;
  font-size: 28rpx;
}

/* 参与表单 */
.form-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.form-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 24rpx;
}

.form-item {
  margin-bottom: 24rpx;
}

.form-label {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 12rpx;
}

/* 数量选择器 */
.quantity-selector {
  display: flex;
  align-items: center;
}

.qty-btn {
  width: 64rpx;
  height: 64rpx;
  background: #f5f5f5;
  border: none;
  border-radius: 8rpx;
  font-size: 36rpx;
  color: #333;
  display: flex;
  align-items: center;
  justify-content: center;
}

.qty-input {
  width: 120rpx;
  height: 64rpx;
  text-align: center;
  font-size: 32rpx;
  margin: 0 20rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
}

/* 备注输入 */
.remark-input {
  width: 100%;
  min-height: 120rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
  padding: 16rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

/* 参与列表 */
.participants-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.participants-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.participants-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.view-all {
  font-size: 24rpx;
  color: #999;
}

.participant-item {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.participant-item:last-child {
  border-bottom: none;
}

.participant-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  margin-right: 16rpx;
}

.participant-info {
  flex: 1;
}

.participant-name {
  font-size: 28rpx;
  color: #333;
}

.participant-time {
  font-size: 22rpx;
  color: #999;
  margin-top: 4rpx;
}

.participant-qty {
  font-size: 28rpx;
  color: #333;
  font-weight: bold;
}

/* 底部按钮 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  padding: 16rpx 24rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -2rpx 10rpx rgba(0, 0, 0, 0.05);
  display: flex;
}

.submit-btn {
  flex: 1;
  height: 88rpx;
  background: linear-gradient(135deg, #007AFF 0%, #0056CC 100%);
  color: #fff;
  border: none;
  border-radius: 44rpx;
  font-size: 32rpx;
  font-weight: bold;
}

.submit-btn:disabled {
  background: #ccc;
}

/* 状态标签 */
.status-tag {
  display: inline-block;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
}

.status-ongoing {
  background: #e6f7ff;
  color: #1890ff;
}

.status-completed {
  background: #f0f0f0;
  color: #999;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 80rpx 0;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}
