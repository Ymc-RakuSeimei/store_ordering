/* pages/preorder/join/join.wxss */

.container {
  padding: 20rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
  padding-bottom: 140rpx;
}

/* 商品卡片 */
.product-card {
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  margin-bottom: 20rpx;
}

.product-img {
  width: 100%;
  height: 400rpx;
  object-fit: cover;
}

.product-info {
  padding: 24rpx;
}

.product-name {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 12rpx;
}

.product-spec {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 20rpx;
}

.price-row {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
}

.price-group {
  display: flex;
  align-items: baseline;
}

.sale-price {
  font-size: 40rpx;
  font-weight: bold;
  color: #ff4d4f;
}

.sale-price::before {
  content: '¥';
  font-size: 24rpx;
  margin-right: 4rpx;
}

.stats-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.stats-row {
  display: flex;
  justify-content: space-around;
}

.stat-item {
  text-align: center;
}

.stat-value {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.stat-label {
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}

/* 参与表单 */
.form-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.form-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 24rpx;
}

.form-item {
  margin-bottom: 24rpx;
}

.form-label {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 12rpx;
}

/* 数量选择器 */
.quantity-selector {
  display: flex;
  align-items: center;
}

.qty-btn {
  width: 80rpx;
  height: 80rpx;
  background: #f5f5f5;
  border: none;
  border-radius: 12rpx;
  font-size: 40rpx;
  color: #333;
  display: flex;
  align-items: center;
  justify-content: center;
}

.qty-input {
  width: 150rpx;
  height: 80rpx;
  text-align: center;
  font-size: 36rpx;
  margin: 0 24rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
}

/* 备注输入 */
.remark-input {
  width: 100%;
  min-height: 150rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  padding: 20rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

/* 已参与提示 */
.joined-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 60rpx 24rpx;
  text-align: center;
}

.joined-icon {
  font-size: 100rpx;
  margin-bottom: 20rpx;
}

.joined-text {
  font-size: 32rpx;
  color: #333;
  margin-bottom: 12rpx;
}

.joined-qty {
  font-size: 28rpx;
  color: #666;
}

/* 已结束提示 */
.ended-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 60rpx 24rpx;
  text-align: center;
}

.ended-icon {
  font-size: 100rpx;
  margin-bottom: 20rpx;
}

.ended-text {
  font-size: 32rpx;
  color: #999;
}

/* 底部按钮 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  padding: 16rpx 24rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -2rpx 10rpx rgba(0, 0, 0, 0.05);
  display: flex;
}

.submit-btn {
  flex: 1;
  height: 88rpx;
  background: linear-gradient(135deg, #007AFF 0%, #0056CC 100%);
  color: #fff;
  border: none;
  border-radius: 44rpx;
  font-size: 32rpx;
  font-weight: bold;
}

.submit-btn:disabled {
  background: #ccc;
}

/* 状态标签 */
.status-tag {
  display: inline-block;
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
}

.status-ongoing {
  background: #e6f7ff;
  color: #1890ff;
}

.status-completed {
  background: #f0f0f0;
  color: #999;
}

/* 加载/空状态 */
.loading-state,
.error-state {
  text-align: center;
  padding: 120rpx 0;
}

.state-icon {
  font-size: 120rpx;
  margin-bottom: 20rpx;
}

.state-text {
  font-size: 28rpx;
  color: #999;
}
