/* pages/preorder/join/join.wxss */

.container {
  min-height: 100vh;
  background-color: #f8f9fa;
}

/* ========== 占位加载状态 - 无文字无转圈，只用于占位 ========== */
.loading-placeholder {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: #f8f9fa;
  z-index: 999;
}

/* ========== 错误状态 ========== */
.error-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100vh;
  padding: 0 60rpx;
}

.error-icon {
  font-size: 100rpx;
  margin-bottom: 32rpx;
  opacity: 0.6;
}

.error-text {
  font-size: 28rpx;
  color: #999;
  text-align: center;
  margin-bottom: 48rpx;
}

.retry-btn {
  width: 240rpx;
  height: 80rpx;
  background: #ff6b35;
  color: white;
  border-radius: 40rpx;
  font-size: 28rpx;
  font-weight: 500;
  border: none;
}

/* ========== 已结束 ========== */
.ended-container {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
  padding: 0 48rpx;
}

.ended-card {
  background: white;
  border-radius: 32rpx;
  padding: 64rpx 48rpx;
  text-align: center;
  width: 100%;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.04);
}

.ended-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.ended-title {
  display: block;
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 12rpx;
}

.ended-desc {
  display: block;
  font-size: 26rpx;
  color: #999;
}

/* ========== 已参与 ========== */
.joined-container {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
  padding: 0 48rpx;
}

.joined-card {
  background: white;
  border-radius: 32rpx;
  padding: 64rpx 48rpx;
  text-align: center;
  width: 100%;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.04);
}

.joined-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.joined-title {
  display: block;
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 12rpx;
}

.joined-desc {
  display: block;
  font-size: 26rpx;
  color: #ff6b35;
  margin-bottom: 48rpx;
}

.back-btn {
  width: 100%;
  height: 88rpx;
  background: #ff6b35;
  color: white;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: 500;
  border: none;
}

/* ========== 正常内容 ========== */
.content {
  padding-bottom: 140rpx;
}

/* 沉浸式头图 */
.hero-section {
  position: relative;
  width: 100%;
  height: 520rpx;
  overflow: hidden;
}

.hero-image {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.hero-overlay {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 120rpx;
  background: linear-gradient(to top, rgba(0,0,0,0.3), transparent);
}

.hero-badge {
  position: absolute;
  top: 32rpx;
  right: 32rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
  background: rgba(0,0,0,0.6);
  backdrop-filter: blur(10px);
  padding: 8rpx 20rpx;
  border-radius: 40rpx;
  color: white;
  font-size: 24rpx;
}

.badge-dot {
  width: 12rpx;
  height: 12rpx;
  background: #4caf50;
  border-radius: 50%;
}

/* 信息卡片 */
.info-card {
  background: white;
  margin: -32rpx 24rpx 0 24rpx;
  border-radius: 32rpx;
  padding: 32rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.06);
}

.product-name {
  font-size: 40rpx;
  font-weight: 700;
  color: #1a1a1a;
  display: block;
  margin-bottom: 20rpx;
}

.price-section {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
  margin-bottom: 24rpx;
}

.price-group {
  display: flex;
  align-items: baseline;
}

.price-symbol {
  font-size: 32rpx;
  font-weight: 600;
  color: #ff4d4f;
}

.price-value {
  font-size: 56rpx;
  font-weight: 700;
  color: #ff4d4f;
}

.price-unit {
  font-size: 26rpx;
  color: #999;
}

.meta-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #f0f0f0;
}

.meta-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
  background: #f5f5f5;
  padding: 12rpx 20rpx;
  border-radius: 60rpx;
}

.meta-icon {
  font-size: 26rpx;
}

.meta-text {
  font-size: 24rpx;
  color: #666;
}

/* 统计卡片 */
.stats-card {
  background: white;
  margin: 20rpx 24rpx;
  border-radius: 32rpx;
  padding: 32rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}

.stats-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.stats-number {
  font-size: 56rpx;
  font-weight: 800;
  color: #ff6b35;
}

.stats-label {
  font-size: 26rpx;
  color: #999;
}

/* 商品描述 */
.desc-card {
  background: white;
  margin: 0 24rpx 20rpx 24rpx;
  border-radius: 32rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}

.desc-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 16rpx;
}

.desc-content {
  display: block;
  font-size: 26rpx;
  color: #666;
  line-height: 1.5;
}

/* 表单卡片 */
.form-card {
  background: white;
  margin: 0 24rpx 20rpx 24rpx;
  border-radius: 32rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}

.form-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1a1a1a;
  margin-bottom: 32rpx;
}

.form-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 32rpx;
}

.row-label {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
}

/* 数量控制器 */
.quantity-control {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.qty-btn {
  width: 64rpx;
  height: 64rpx;
  border-radius: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f5f5f5;
  transition: all 0.2s;
}

.qty-btn text {
  font-size: 40rpx;
  font-weight: 500;
  color: #333;
}

.qty-btn.minus.disabled {
  opacity: 0.4;
}

.qty-btn.plus {
  background: #ff6b35;
}

.qty-btn.plus text {
  color: white;
}

/* 数量输入框 - 修复滚动漂移 */
.qty-input {
  width: 80rpx;
  height: 64rpx;
  text-align: center;
  font-size: 32rpx;
  font-weight: 600;
  color: #1a1a1a;
  background-color: #f5f5f5;
  border-radius: 32rpx;
  line-height: 64rpx;
  position: relative;
  transform: translateZ(0);
  -webkit-transform: translateZ(0);
}

.remark-row {
  align-items: flex-start;
}

.remark-input {
  flex: 1;
  background: #f5f5f5;
  border-radius: 20rpx;
  padding: 20rpx;
  font-size: 26rpx;
  color: #333;
  min-height: 120rpx;
  margin-left: 24rpx;
}

/* 底部安全区 */
.safe-bottom {
  height: 40rpx;
}

/* 底部固定按钮 */
.bottom-fixed {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  background: white;
  border-top: 1rpx solid #f0f0f0;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.04);
}

.submit-btn {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #ff6b35, #ff4d4f);
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  font-size: 32rpx;
  font-weight: 600;
  color: white;
  box-shadow: 0 4rpx 16rpx rgba(255, 77, 79, 0.3);
}

.submit-btn:active {
  opacity: 0.9;
  transform: scale(0.98);
}